# TODO: Replace with your actual Lambda function URLs
lambda.cpp.url=https://your-cpp-lambda.lambda-url.us-east-1.on.aws
lambda.java.url=https://your-java-lambda.lambda-url.us-east-1.on.aws
lambda.javascript.url=https://your-javascript-lambda.lambda-url.us-east-1.on.aws
lambda.python.url=https://your-python-lambda.lambda-url.us-east-1.on.aws
lambda.timeout.seconds=90
logging.level.com.focusedai.grading=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.root=INFO
management.endpoints.web.exposure.include=health,info,metricslambda.python.url=https://bm24ekxzany4wm62yen2aqzlxe0reunf.lambda-url.us-east-1.on.aws/
server.port=8080
spring.application.name=teacher-grading-system
spring.mvc.async.request-timeout=900000
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
spring.web.cors.allow-credentials=true
spring.web.cors.allowed-headers=*
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.web.cors.allowed-origins=http://localhost:3000
