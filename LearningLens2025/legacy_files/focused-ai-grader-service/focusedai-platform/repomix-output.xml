      decoration: BoxDecoration(
        color: similarity >= 90 ? Colors.green[50] : (similarity >= 70 ? Colors.orange[50] : Colors.red[50]),
        border: Border.all(
          color: similarity >= 90 ? Colors.green[200]! : (similarity >= 70 ? Colors.orange[200]! : Colors.red[200]!),
