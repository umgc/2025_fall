  Future<void> _ensurePlatformContext() async {
  final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
  final authProvider = Provider.of<AuthProvider>(context, listen: false);
  
  print('🔧 Checking platform context...');
  print('   Auth platform: ${authProvider.platform}');
  print('   Current platform: $_currentPlatform');
  
  if (_currentPlatform != null) {
    print('🔧 Setting platform context: $_currentPlatform');
    gradingProvider.setPlatformContext(_currentPlatform!);
    
    if (_currentPlatform!.toLowerCase() == 'google' || _currentPlatform!.toLowerCase() == 'google_classroom') {
      final classroomService = authProvider.getClassroomService();
      if (classroomService != null) {
        print('🔧 Initializing Google Classroom service...');
        gradingProvider.initializeGoogleClassroom(classroomService);
      } else {
        print('❌ Google Classroom service not available');
      }
    }
  } else {
    print('❌ No platform context available');
  }
}



