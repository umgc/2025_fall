  // Grading Methods (same as original but adapted for unified screen)
  Future<void> _gradeSelectedSubmission() async {
    if (_selectedSubmission == null) {
      _showGradingError('Please select a submission first', Icons.person_outline);
      return;
    }

    if (!_isGradingEnabled) {
      _showGradingError(_getGradingStatusMessage(), _getGradingStatusIcon());
      return;
    }

    if (_selectedSubmission!.files.isEmpty) {
      _showGradingError('Selected submission has no files', Icons.description);
      return;
    }

    setState(() {
      _isGrading = true;
    });

    try {
      final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
      
      Map<String, dynamic> gradingPayload = {
        'submissionId': _selectedSubmission!.id,
        'assignmentId': _selectedAssignment?.id ?? '',
        'files': _selectedSubmission!.files.map((file) => {
          'filename': file.filename,
          'content': file.content,
          'language': file.language,
        }).toList(),
        'input': _testFiles['inputContent'].toString().trim(),
        'expectedOutput': _testFiles['outputContent'].toString().trim(),
        'testInput': _testFiles['inputContent'].toString().trim(),
        'useUploadedTestFiles': true,
        'inputFilename': _testFiles['inputFilename'],
        'outputFilename': _testFiles['outputFilename'],
        'studentName': _selectedSubmission!.studentName,
        'executionMode': 'GRADING',
        'autoGrade': true,
      };
      
      await gradingProvider.executeCode(_selectedSubmission!.primaryLanguage, gradingPayload);
      
      if (gradingProvider.executionResult != null) {
        _gradingResults[_selectedSubmission!.id] = gradingProvider.executionResult!;
        
        if (mounted) {
          _showGradeSubmissionDialog(gradingProvider.executionResult!);
        }
      }

    } catch (e) {
      if (mounted) {
        _showGradingError('Grading failed: ${e.toString()}', Icons.error);
      }
    } finally {
      if (mounted) {
        setState(() {
          _isGrading = false;
        });
      }
    }
  }

  Future<void> _gradeAllSubmissions() async {
    final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
    
    if (!_isGradingEnabled) {
      _showGradingError(_getGradingStatusMessage(), _getGradingStatusIcon());
      return;
    }

    if (gradingProvider.submissions.isEmpty) {
      _showGradingError('No submissions found to grade', Icons.assignment);
      return;
    }

    final confirmed = await _showGradeAllConfirmationDialog(gradingProvider.submissions.length);
    if (confirmed != true) return;

    setState(() {
      _isGradingAll = true;
      _gradingResults.clear();
    });

    int completed = 0;
    int successful = 0;
    List<Map<String, dynamic>> allGradingResults = [];
    late BuildContext dialogContext;

    try {
      final submissions = gradingProvider.submissions;
      
      showDialog(
        context: context,
        barrierDismissible: false,
        builder: (context) {
          dialogContext = context;
          return StatefulBuilder(
            builder: (context, setDialogState) => AlertDialog(
              title: const Row(
                children: [
                  CircularProgressIndicator(),
                  SizedBox(width: 16),
                  Text('Grading Progress'),
                ],
              ),
              content: Column(
                mainAxisSize: MainAxisSize.min,
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text('Processing submissions: $completed / ${submissions.length}'),
                  const SizedBox(height: 8),
                  LinearProgressIndicator(
                    value: submissions.isNotEmpty ? completed / submissions.length : 0,
                  ),
                  const SizedBox(height: 12),
                  Text('Successful: $successful'),
                  Text('Failed: ${completed - successful}'),
                  if (completed > 0 && completed <= submissions.length) ...[
                    const SizedBox(height: 8),
                    Text(
                      'Current: ${submissions[completed - 1].studentName}',
                      style: const TextStyle(fontSize: 12, fontStyle: FontStyle.italic),
                    ),
                  ],
                ],
              ),
            ),
          );
        },
      );

      for (int i = 0; i < submissions.length; i++) {
        final submission = submissions[i];
        
        try {
          Map<String, dynamic> gradingPayload = {
            'submissionId': submission.id,
            'assignmentId': _selectedAssignment?.id ?? '',
            'files': submission.files.map((file) => {
              'filename': file.filename,
              'content': file.content,
              'language': file.language,
            }).toList(),
            'input': _testFiles['inputContent'].toString().trim(),
            'expectedOutput': _testFiles['outputContent'].toString().trim(),
            'testInput': _testFiles['inputContent'].toString().trim(),
            'useUploadedTestFiles': true,
            'inputFilename': _testFiles['inputFilename'],
            'outputFilename': _testFiles['outputFilename'],
            'studentName': submission.studentName,
            'executionMode': 'GRADING',
            'autoGrade': true,
          };

          await gradingProvider.executeCode(submission.primaryLanguage, gradingPayload);
          
          if (gradingProvider.executionResult != null) {
            final resultWithSubmission = Map<String, dynamic>.from(gradingProvider.executionResult!);
            resultWithSubmission['submission'] = submission;
            resultWithSubmission['assignment'] = _selectedAssignment;
            allGradingResults.add(resultWithSubmission);
            
            _gradingResults[submission.id] = Map<String, dynamic>.from(gradingProvider.executionResult!);
            successful++;
          } else {
            final failedResult = {
              'success': false,
              'error': 'No execution result returned',
              'studentName': submission.studentName,
              'grade': 'F',
              'feedback': 'Grading failed: No execution result returned',
              'testPassed': false,
              'outputSimilarity': 0,
              'submission': submission,
              'assignment': _selectedAssignment,
            };
            allGradingResults.add(failedResult);
            _gradingResults[submission.id] = Map<String, dynamic>.from(failedResult);
          }
          
          completed++;
          
          if (mounted) {
            setState(() {});
          }
          
          await Future.delayed(const Duration(milliseconds: 1000));
          
        } catch (e) {
          completed++;
          
          final errorResult = {
            'success': false,
            'error': e.toString(),
            'studentName': submission.studentName,
            'grade': 'F',
            'feedback': 'Grading failed: $e',
            'testPassed': false,
            'outputSimilarity': 0,
            'submission': submission,
            'assignment': _selectedAssignment,
          };
          allGradingResults.add(errorResult);
          _gradingResults[submission.id] = Map<String, dynamic>.from(errorResult);
        }
      }

      if (mounted) {
        Navigator.of(dialogContext).pop();
      }

      await _showBatchGradingResultsDialog(allGradingResults, successful, submissions.length - successful);

    } catch (e) {
      if (mounted) {
        try {
          Navigator.of(dialogContext).pop();
        } catch (e) {
          // Dialog might already be closed
        }
        
        _showGradingError(
          'Batch grading failed: ${e.toString().length > 100 ? '${e.toString().substring(0, 100)}...' : e.toString()}',
          Icons.error,
        );
      }
    } finally {
      if (mounted) {
        setState(() {
          _isGradingAll = false;
        });
      }
    }
  }

  // Helper methods
  String _getGradingStatusMessage() {
    if (!_useUploadedTestFiles) {
      return 'No test files uploaded';
    }
    if (_testFiles['hasFiles'] != true) {
      return 'Test files not properly loaded';
    }
    if (_testFiles['inputContent'] == null || _testFiles['inputContent'].toString().trim().isEmpty) {
      return 'Input file is empty or missing';
    }
    if (_testFiles['outputContent'] == null || _testFiles['outputContent'].toString().trim().isEmpty) {
      return 'Output file is empty or missing';
    }
    if (_testFiles['inputFilename'] == null) {
      return 'Input filename missing';
    }
    if (_testFiles['outputFilename'] == null) {
      return 'Output filename missing';
    }
    return 'Ready for grading';
  }

