  bool courseHasAssignments(String courseId) {
    try {
      final course = _courses.firstWhere((c) => c.id == courseId);
      return course.assignments.isNotEmpty;
    } catch (e) {
      return false;
    }
  }

  Assignment? getAssignmentById(String assignmentId) {
    for (final course in _courses) {
      try {
        return course.assignments.firstWhere((a) => a.id == assignmentId);
      } catch (e) {
        continue;
      }
    }
    return null;
  }

  void clearError() {
    _error = null;
    notifyListeners();
  }

  void reset() {
    _courses = [];
    _selectedCourse = null;
    _selectedAssignment = null;
    _isLoading = false;
    _error = null;
    notifyListeners();
  }

  Future<void> autoMapGoogleClassroomAssignments(String courseId, BuildContext context) async {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    
    if (!authProvider.canAccessGoogleClassroom) {
      return;
    }

    try {
      final classroomService = authProvider.getClassroomService();
      if (classroomService == null) return;

      final courses = await classroomService.getCourses();
      
      if (courses.isEmpty) {
        return;
      }

      final googleCourse = courses.first;
      final assignments = await classroomService.getAssignments(googleCourse.id);

      if (_selectedCourse != null) {
        for (var assignment in _selectedCourse!.assignments) {
          final matchingGoogleAssignment = assignments.firstWhere(
            (ga) => _assignmentNamesMatch(assignment.name, ga['title']),
            orElse: () => <String, dynamic>{},
          );

          if (matchingGoogleAssignment.isNotEmpty) {
            final updatedAssignment = Assignment(
              id: assignment.id,
              courseId: assignment.courseId,
              name: assignment.name,
              description: assignment.description,
              language: assignment.language,
              packageName: assignment.packageName,
              dueDate: assignment.dueDate,
              maxScore: assignment.maxScore,
              testCases: assignment.testCases,
              submissions: assignment.submissions,
              createdAt: assignment.createdAt,
              googleClassroomCourseId: googleCourse.id,
              googleClassroomId: matchingGoogleAssignment['id'],
            );

            final courseAssignments = List<Assignment>.from(_selectedCourse!.assignments);
            final index = courseAssignments.indexWhere((a) => a.id == assignment.id);
            if (index != -1) {
              courseAssignments[index] = updatedAssignment;
              
              _selectedCourse = Course(
                id: _selectedCourse!.id,
                name: _selectedCourse!.name,
                description: _selectedCourse!.description,
                platform: _selectedCourse!.platform,
                instructor: _selectedCourse!.instructor,
                enrollmentCount: _selectedCourse!.enrollmentCount,
                createdAt: _selectedCourse!.createdAt,
                assignments: courseAssignments,
              );
            }
          }
        }
        
        notifyListeners();
      }

    } catch (e) {
      // Silently handle mapping errors
    }
  }

  bool _assignmentNamesMatch(String name1, String? name2) {
    if (name2 == null) return false;
    
    final normalized1 = name1.toLowerCase().replaceAll(RegExp(r'[^a-z0-9]'), '');
    final normalized2 = name2.toLowerCase().replaceAll(RegExp(r'[^a-z0-9]'), '');
    
    if (normalized1 == normalized2) return true;
    
    if (normalized1.contains(normalized2) || normalized2.contains(normalized1)) {
      return true;
    }
    
    return false;
  }
}
