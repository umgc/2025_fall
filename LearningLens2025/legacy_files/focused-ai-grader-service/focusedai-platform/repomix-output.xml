import 'package:flutter/material.dart';
import '../models/submission.dart';
import '../models/code_file.dart';
import '../models/grade.dart';
import '../services/api_service.dart';
import '../services/google_classroom_service.dart';

class GradingProvider extends ChangeNotifier {
  List<Submission> _submissions = [];
  Submission? _selectedSubmission;
  bool _isLoading = false;
  bool _isGrading = false;
  String? _error;
  Map<String, dynamic>? _executionResult;
  Map<String, dynamic>? _fileAccessStats;
  String? _currentPlatform;
  GoogleClassroomService? _classroomService;
  
  List<Submission> get submissions => _submissions;
  Submission? get selectedSubmission => _selectedSubmission;
  bool get isLoading => _isLoading;
  bool get isGrading => _isGrading;
  String? get error => _error;
  Map<String, dynamic>? get executionResult => _executionResult;
  Map<String, dynamic>? get fileAccessStats => _fileAccessStats;
  String? get currentPlatform => _currentPlatform;

  void initializeGoogleClassroom(GoogleClassroomService classroomService) {
    _classroomService = classroomService;
  }

  void setPlatformContext(String platform) {
    _currentPlatform = platform;
    notifyListeners();
  }

  String get uploadButtonText {
    switch (_currentPlatform?.toLowerCase()) {
      case 'moodle':
        return 'Upload to Moodle';
      case 'google':
      case 'google_classroom':
        return 'Upload to Google Classroom';
      default:
        return 'Upload Grade';
    }
  }

  IconData get uploadButtonIcon {
    switch (_currentPlatform?.toLowerCase()) {
      case 'moodle':
        return Icons.school;
      case 'google':
      case 'google_classroom':
        return Icons.cloud_upload;
      default:
        return Icons.cloud_upload;
    }
  }

  Future<Map<String, dynamic>> uploadGradeToPlatform(
    String submissionId,
    Map<String, dynamic> gradeData,
  ) async {
    if (_currentPlatform == null) {
      throw Exception('Platform context not set');
    }
    
    switch (_currentPlatform?.toLowerCase()) {
      case 'moodle':
        return await _uploadGradeToMoodle(submissionId, gradeData);
      case 'google':
      case 'google_classroom':
        return await _uploadGradeToGoogleClassroom(submissionId, gradeData);
      default:
        throw Exception('Unsupported platform: $_currentPlatform');
    }
  }

  Future<Map<String, dynamic>> _uploadGradeToGoogleClassroom(
    String submissionId,
    Map<String, dynamic> gradeData,
  ) async {
    try {
      if (_classroomService == null) {
        throw Exception('Google Classroom service not initialized');
      }

      final courseId = gradeData['googleClassroomCourseId'] as String?;
      final assignmentId = gradeData['googleClassroomId'] as String?;
      final studentId = gradeData['studentId'] as String?;
      final score = gradeData['score'] as double?;

      if (courseId == null || assignmentId == null || studentId == null || score == null) {
        throw Exception('Missing required Google Classroom data: courseId, assignmentId, studentId, or score');
      }

      final success = await _classroomService!.submitGradeToClassroom(
        courseId: courseId,
        assignmentId: assignmentId,
        submissionId: submissionId,
        studentId: studentId,
        grade: score,
        feedback: '',
      );

      if (success) {
        return {
          'success': true,
          'message': 'Grade uploaded to Google Classroom successfully (feedback disabled)',
          'platform': 'google_classroom',
          'feedbackDisabled': true,
        };
      } else {
        throw Exception('Google Classroom upload failed');
      }
    } catch (e) {
      return {
        'success': false,
        'error': e.toString(),
        'platform': 'google_classroom',
      };
    }
  }

  String getDetailedAccessReport() {
    final stats = _fileAccessStats;
    if (stats == null) return 'No statistics available';
    
    final buffer = StringBuffer();
    buffer.writeln('📊 File Access Report');
    buffer.writeln('====================');
    buffer.writeln('Platform: ${_currentPlatform?.toUpperCase() ?? 'Unknown'}');
    buffer.writeln('Total Submissions: ${stats['totalSubmissions']}');
    buffer.writeln('Submissions with Files: ${stats['submissionsWithFiles']}');
    buffer.writeln('Total Files: ${stats['totalFiles']}');
    buffer.writeln('Accessible Files: ${stats['accessibleFiles']}');
    buffer.writeln('Inaccessible Files: ${stats['inaccessibleFiles']}');
    buffer.writeln('Access Rate: ${stats['accessRate']}%');
    buffer.writeln('');
    buffer.writeln('Language Distribution:');
    final langDist = stats['languageDistribution'] as Map<String, int>;
    for (var entry in langDist.entries) {
      buffer.writeln('  ${entry.key}: ${entry.value} files');
    }
    buffer.writeln('');
    buffer.writeln('Last Updated: ${stats['lastUpdated']}');
    
    if (stats['accessRate'] < 50) {
      buffer.writeln('');
      buffer.writeln('⚠️ Low file access rate detected!');
      buffer.writeln('Recommendations:');
      if (_currentPlatform?.toLowerCase() == 'google') {
        buffer.writeln('1. Check Google Cloud Console OAuth scopes');
        buffer.writeln('2. Verify Drive API is enabled');
        buffer.writeln('3. Complete OAuth app verification for restricted scopes');
        buffer.writeln('4. Check file sharing permissions in Google Classroom');
      } else if (_currentPlatform?.toLowerCase() == 'moodle') {
        buffer.writeln('1. Check Moodle web services permissions');
        buffer.writeln('2. Verify file access capabilities in Moodle');
        buffer.writeln('3. Ensure proper assignment configuration');
      } else {
        buffer.writeln('1. Check platform-specific permissions');
        buffer.writeln('2. Verify API access rights');
      }
    }
    
    return buffer.toString();
  }

  Future<Map<String, dynamic>> testDriveConnectivity() async {
    try {
      final result = await ApiService.testDriveConnection();
