import 'package:flutter/material.dart';
import 'package:provider/provider.dart';

import 'config/theme.dart';
import 'providers/auth_provider.dart';
import 'providers/course_provider.dart';
import 'providers/grading_provider.dart';
import 'screens/auth/login_screen.dart';
import 'screens/grading/unified_grading_screen.dart'; // ✅ Only import UnifiedGradingScreen

void main() {
  runApp(const FocusedAIApp());
}

class FocusedAIApp extends StatelessWidget {
  const FocusedAIApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MultiProvider(
      providers: [
        ChangeNotifierProvider(create: (_) => AuthProvider()),
        ChangeNotifierProvider(create: (_) => CourseProvider()),
        ChangeNotifierProvider(create: (_) => GradingProvider()),
      ],
      child: Consumer<AuthProvider>(
        builder: (context, authProvider, child) {
          return MaterialApp(
            title: 'FocusEd AI Teacher',
            theme: AppTheme.lightTheme,
            darkTheme: AppTheme.darkTheme,
            themeMode: ThemeMode.system,
            home: _buildHome(authProvider),
            routes: {
              '/login': (context) => const LoginScreen(),
              '/grading': (context) => const UnifiedGradingScreen(), // ✅ CHANGED: Use UnifiedGradingScreen
              // ✅ REMOVED: Old '/grading' route that pointed to GradingScreen
            },
          );
        },
      ),
    );
  }

  Widget _buildHome(AuthProvider authProvider) {
    if (authProvider.isLoading) {
      return const Scaffold(
        body: Center(
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              CircularProgressIndicator(),
              SizedBox(height: 16),
              Text('Loading...'),
            ],
          ),
        ),
      );
    }

    return authProvider.isAuthenticated 
        ? const UnifiedGradingScreen() // ✅ CHANGED: Use UnifiedGradingScreen
        : const LoginScreen();
  }
}
