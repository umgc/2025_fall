import 'package:flutter/material.dart';
import 'package:focusedai_teacher/providers/grading_provider.dart';
import 'package:provider/provider.dart';
import 'package:focusedai_teacher/providers/course_provider.dart';
import 'package:focusedai_teacher/models/course.dart';
import 'package:focusedai_teacher/models/assignment.dart';
import 'package:focusedai_teacher/screens/grading/unified_grading_screen.dart'; // ✅ CHANGED: Import UnifiedGradingScreen
import 'package:focusedai_teacher/screens/assignments/create_assignment_screen.dart';

class AssignmentListScreen extends StatefulWidget {
  final String courseId;

  const AssignmentListScreen({
    super.key,
    required this.courseId,
  });

  @override
  State<AssignmentListScreen> createState() => _AssignmentListScreenState();
}

class _AssignmentListScreenState extends State<AssignmentListScreen> {
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _loadCourse();
    });
  }

  Future<void> _loadCourse() async {
    final courseProvider = Provider.of<CourseProvider>(context, listen: false);
    
    Course? existingCourse;
    try {
      existingCourse = courseProvider.courses.firstWhere(
        (course) => course.id == widget.courseId,
      );
    } catch (e) {
      existingCourse = null;
    }
    
    if (existingCourse != null) {
      courseProvider.selectCourse(existingCourse.id);
      return;
    }
    
    try {
      await courseProvider.selectCourse(widget.courseId);
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Failed to load course: $e'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  Future<void> _addTestDataToAssignment(Assignment assignment) async {
    try {
      final courseProvider = Provider.of<CourseProvider>(context, listen: false);
      final result = await courseProvider.addTestDataToAssignment(assignment.id);
      
      if (mounted && result['success'] == true) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(result['message']),
            backgroundColor: Colors.green,
          ),
        );
        
        final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
        await gradingProvider.loadSubmissions(assignment.id);
        
      } else if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(result['message']),
            backgroundColor: Colors.red,
          ),
        );
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Failed to add test data: $e'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Consumer<CourseProvider>(
          builder: (context, courseProvider, child) {
            if (courseProvider.selectedCourse != null) {
              return Text(courseProvider.selectedCourse!.name);
            }
            
            Course? course;
            try {
              course = courseProvider.courses.firstWhere(
                (c) => c.id == widget.courseId,
              );
            } catch (e) {
              course = null;
            }
            
            return Text(course?.name ?? 'Loading...');
          },
        ),
        actions: [
          IconButton(
            onPressed: () => _navigateToCreateAssignment(),
            icon: const Icon(Icons.add),
            tooltip: 'Create Assignment',
          ),
        ],
      ),
      body: Consumer<CourseProvider>(
        builder: (context, courseProvider, child) {
          if (courseProvider.isLoading) {
            return const Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  CircularProgressIndicator(),
                  SizedBox(height: 16),
                  Text('Loading course...'),
                ],
              ),
            );
          }

          if (courseProvider.error != null) {
            return Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.error_outline,
                    size: 64,
                    color: Colors.red[400],
                  ),
                  const SizedBox(height: 16),
                  Text(
                    'Error loading course',
                    style: Theme.of(context).textTheme.headlineSmall,
                  ),
                  const SizedBox(height: 8),
                  Padding(
                    padding: const EdgeInsets.symmetric(horizontal: 32),
                    child: Text(
                      courseProvider.error!,
                      textAlign: TextAlign.center,
                    ),
                  ),
                  const SizedBox(height: 24),
                  ElevatedButton(
                    onPressed: _loadCourse,
                    child: const Text('Retry'),
                  ),
                ],
              ),
            );
          }

          Course? course = courseProvider.selectedCourse;
          if (course == null) {
            try {
              course = courseProvider.courses.firstWhere(
                (c) => c.id == widget.courseId,
              );
            } catch (e) {
              course = null;
            }
          }

          if (course == null) {
            return Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.school_outlined,
                    size: 64,
                    color: Colors.grey[400],
                  ),
                  const SizedBox(height: 16),
                  Text(
                    'Course not found',
                    style: Theme.of(context).textTheme.headlineSmall,
                  ),
                  const SizedBox(height: 8),
                  Text('Course ID: ${widget.courseId}'),
                  const SizedBox(height: 24),
                  ElevatedButton(
                    onPressed: () => Navigator.of(context).pop(),
                    child: const Text('Go Back'),
                  ),
                ],
              ),
            );
          }

          final assignments = course.assignments;

          if (assignments.isEmpty) {
            return Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.assignment_outlined,
                    size: 64,
                    color: Colors.grey[400],
                  ),
                  const SizedBox(height: 16),
                  Text(
                    'No assignments yet',
                    style: Theme.of(context).textTheme.headlineSmall,
                  ),
                  const SizedBox(height: 8),
                  const Text('Create your first assignment to get started'),
                  const SizedBox(height: 24),
                  ElevatedButton.icon(
                    onPressed: _navigateToCreateAssignment,
                    icon: const Icon(Icons.add),
                    label: const Text('Create Assignment'),
                  ),
                ],
              ),
            );
          }

          return RefreshIndicator(
            onRefresh: _loadCourse,
            child: ListView.builder(
              padding: const EdgeInsets.all(16),
              itemCount: assignments.length,
              itemBuilder: (context, index) {
                final assignment = assignments[index];
                return _buildAssignmentCardWithTestStatus(assignment);
              },
            ),
          );
        },
      ),
    );
  }

  Widget _buildAssignmentCardWithTestStatus(Assignment assignment) {
    final hasTestFiles = TestFileTracker.hasTestFiles(assignment.id);
    
    return Card(
      margin: const EdgeInsets.only(bottom: 16),
      child: InkWell(
        onTap: () => _navigateToUnifiedGrading(assignment), // ✅ CHANGED: Use new navigation method
        borderRadius: BorderRadius.circular(12),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Row(
                children: [
                  Expanded(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          assignment.name,
                          style: Theme.of(context).textTheme.titleLarge?.copyWith(
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                        const SizedBox(height: 4),
                        Text(
                          assignment.description,
                          style: Theme.of(context).textTheme.bodyMedium?.copyWith(
                            color: Colors.grey[600],
                          ),
                          maxLines: 2,
                          overflow: TextOverflow.ellipsis,
                        ),
                      ],
                    ),
                  ),
                  Column(
                    children: [
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                        decoration: BoxDecoration(
                          color: _getLanguageColor(assignment.language),
                          borderRadius: BorderRadius.circular(16),
                        ),
                        child: Text(
                          assignment.language.toUpperCase(),
                          style: const TextStyle(
                            color: Colors.white,
                            fontSize: 12,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                      ),
                      const SizedBox(height: 8),
                      if (hasTestFiles) ...[
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                          decoration: BoxDecoration(
                            color: Colors.green[600],
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: const Row(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              Icon(Icons.check_circle, size: 12, color: Colors.white),
                              SizedBox(width: 4),
                              Text(
                                'Test Files',
                                style: TextStyle(
                                  color: Colors.white,
                                  fontSize: 10,
                                  fontWeight: FontWeight.bold,
                                ),
                              ),
                            ],
                          ),
                        ),
                      ] else ...[
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                          decoration: BoxDecoration(
                            color: Colors.grey[400],
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: const Text(
                            'No Tests',
                            style: TextStyle(
                              color: Colors.white,
                              fontSize: 10,
                              fontWeight: FontWeight.bold,
                            ),
                          ),
                        ),
                      ],
                    ],
                  ),
                ],
              ),
              const SizedBox(height: 16),
              
              Row(
                children: [
                  _buildStatChip(
                    Icons.people,
                    '${assignment.submissions.length} submissions',
                  ),
                  const SizedBox(width: 12),
                  _buildStatChip(
                    Icons.quiz,
                    '${assignment.testCases.length} test cases',
                  ),
                  const SizedBox(width: 12),
                  _buildStatChip(
                    Icons.score,
                    '${assignment.maxScore.toInt()} points',
                  ),
                ],
              ),
              const SizedBox(height: 16),
              
              Row(
                children: [
                  if (assignment.dueDate != null) ...[
                    Icon(
                      Icons.schedule,
                      size: 16,
                      color: Colors.grey[600],
                    ),
                    const SizedBox(width: 4),
                    Text(
                      'Due: ${_formatDate(assignment.dueDate!)}',
                      style: Theme.of(context).textTheme.bodySmall?.copyWith(
                        color: Colors.grey[600],
                      ),
                    ),
                  ],
                  const Spacer(),
                  if (assignment.submissions.isEmpty) ...[
                    TextButton.icon(
                      onPressed: () => _addTestDataToAssignment(assignment),
                      icon: const Icon(Icons.add_box),
                      label: const Text('Add Test Data'),
                      style: TextButton.styleFrom(
                        foregroundColor: Colors.orange[600],
                      ),
                    ),
                    const SizedBox(width: 8),
                  ],
                  TextButton.icon(
                    onPressed: () => _navigateToUnifiedGrading(assignment), // ✅ CHANGED: Use new navigation method
                    icon: const Icon(Icons.grading),
                    label: Text(assignment.submissions.isEmpty ? 'Setup' : 'Grade'),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildStatChip(IconData icon, String text) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: Colors.grey[100],
        borderRadius: BorderRadius.circular(12),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, size: 16, color: Colors.grey[600]),
          const SizedBox(width: 4),
          Text(
            text,
            style: TextStyle(
              fontSize: 12,
              color: Colors.grey[600],
            ),
          ),
        ],
      ),
    );
  }

  Color _getLanguageColor(String language) {
    switch (language.toLowerCase()) {
      case 'java':
        return Colors.orange[600]!;
      case 'python':
        return Colors.blue[600]!;
      case 'javascript':
        return Colors.yellow[700]!;
      case 'cpp':
      case 'c++':
        return Colors.purple[600]!;
      default:
        return Colors.grey[600]!;
    }
  }

  String _formatDate(DateTime date) {
    return '${date.day}/${date.month}/${date.year}';
  }

  void _navigateToCreateAssignment() {
    Navigator.of(context).push(
      MaterialPageRoute(
        builder: (context) => CreateAssignmentScreen(courseId: widget.courseId),
      ),
    );
  }

  // ✅ NEW: Updated navigation method to use UnifiedGradingScreen
  void _navigateToUnifiedGrading(Assignment assignment) {
    if (TestFileTracker.hasTestFiles(assignment.id)) {
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: const Row(
            children: [
              Icon(Icons.info, color: Colors.blue),
              SizedBox(width: 8),
              Text('Test Files Notice'),
            ],
          ),
          content: Text(
            'Opening "${assignment.name}" will take you to the unified grading interface. '
            'You can select this assignment from the dropdown once there.',
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Cancel'),
            ),
            ElevatedButton(
              onPressed: () {
                Navigator.of(context).pop();
                _performUnifiedNavigation(assignment);
              },
              child: const Text('Continue'),
            ),
          ],
        ),
      );
    } else {
      _performUnifiedNavigation(assignment);
    }
  }

  // ✅ NEW: Navigation logic for UnifiedGradingScreen
  void _performUnifiedNavigation(Assignment assignment) {
    // Navigate to UnifiedGradingScreen and let it handle course/assignment selection
    Navigator.of(context).pushReplacement(
      MaterialPageRoute(
        builder: (context) => const UnifiedGradingScreen(),
      ),
    );
    
    // Show a helpful message about assignment selection
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Row(
              children: [
                const Icon(Icons.info, color: Colors.white),
                const SizedBox(width: 8),
                Expanded(
                  child: Text('Select "${assignment.name}" from the assignment dropdown to continue grading'),
                ),
              ],
            ),
            backgroundColor: Colors.blue[600],
            duration: const Duration(seconds: 4),
            action: SnackBarAction(
              label: 'Got it',
              textColor: Colors.white,
              onPressed: () => ScaffoldMessenger.of(context).hideCurrentSnackBar(),
            ),
          ),
        );
      }
    });
  }
}

// Keep the existing TestFileTracker class as-is
class TestFileTracker {
  static final Map<String, Map<String, dynamic>> _assignmentTestFiles = {};
  
  static void saveTestFiles(String assignmentId, Map<String, dynamic> testFiles) {
    if (testFiles['hasFiles'] == true) {
      _assignmentTestFiles[assignmentId] = testFiles;
    } else {
      _assignmentTestFiles.remove(assignmentId);
    }
  }
  
  static bool hasTestFiles(String assignmentId) {
    return _assignmentTestFiles.containsKey(assignmentId);
  }
  
  static Map<String, dynamic>? getTestFiles(String assignmentId) {
    return _assignmentTestFiles[assignmentId];
  }
  
  static void clearAll() {
    _assignmentTestFiles.clear();
  }
  
  static Map<String, dynamic> getSummary() {
    return {
      'totalAssignments': _assignmentTestFiles.length,
      'assignments': _assignmentTestFiles.keys.toList(),
    };
  }
}
