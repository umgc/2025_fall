import 'dart:convert';
import 'dart:html' as html;
import 'package:http/http.dart' as http;

class GoogleAuthService {
  static const String clientId = '51530330417-a5kp7dl5rmasfh9748nh30ie3eaj3b45.apps.googleusercontent.com';
  static const String redirectUri = 'http://localhost:3000';
  
  static const String scope = 'https://www.googleapis.com/auth/userinfo.email '
                              'https://www.googleapis.com/auth/userinfo.profile '
                              'https://www.googleapis.com/auth/classroom.courses.readonly '
                              'https://www.googleapis.com/auth/classroom.coursework.students '
                              'https://www.googleapis.com/auth/classroom.rosters.readonly '
                              'https://www.googleapis.com/auth/classroom.student-submissions.students.readonly '
                              'https://www.googleapis.com/auth/classroom.coursework.me '
                              'https://www.googleapis.com/auth/classroom.courseworkmaterials '
                              'https://www.googleapis.com/auth/classroom.courseworkmaterials.readonly '
                              'https://www.googleapis.com/auth/drive.file '
                              'https://www.googleapis.com/auth/drive.readonly '
                              'https://www.googleapis.com/auth/drive.metadata.readonly '
                              'openid';

  static const String gradeUploadScopes = 'https://www.googleapis.com/auth/classroom.coursework.students '
                                         'https://www.googleapis.com/auth/classroom.courses.readonly '
                                         'https://www.googleapis.com/auth/classroom.coursework.me';

  static String getAuthUrl() {
    final params = {
      'client_id': clientId,
      'redirect_uri': redirectUri,
      'scope': scope,
      'response_type': 'code',
      'access_type': 'offline',
      'prompt': 'consent',
      'state': 'google_auth',
      'include_granted_scopes': 'true',
    };

    final query = params.entries
        .map((e) => '${Uri.encodeComponent(e.key)}=${Uri.encodeComponent(e.value)}')
        .join('&');

    return 'https://accounts.google.com/o/oauth2/v2/auth?$query';
  }

  static void initiateGoogleLogin() {
    final authUrl = getAuthUrl();
    html.window.location.href = authUrl;
  }

  static String? extractCodeFromUrl(String url) {
    final uri = Uri.parse(url);
    final state = uri.queryParameters['state'];
    if (state == 'google_auth') {
      return uri.queryParameters['code'];
    }
    return null;
  }

  static Future<Map<String, dynamic>> exchangeCodeForToken(String code) async {
    try {
      final response = await http.post(
        Uri.parse('http://localhost:8080/api/auth/google/callback'),
        headers: {'Content-Type': 'application/json'},
        body: json.encode({
          'code': code,
          'requestedScopes': scope,
        }),
      );

      if (response.statusCode == 200) {
        final result = json.decode(response.body);
        
        if (result['grantedScopes'] != null) {
          final grantedScopes = result['grantedScopes'] as String;
          final hasEssentialScopes = _verifyEssentialScopes(grantedScopes);
          
          if (!hasEssentialScopes) {
            result['scopeWarning'] = 'Some features may not work - missing grade upload permissions';
          }
        }
        
        return result;
      } else {
        final error = json.decode(response.body);
        throw Exception(error['error'] ?? 'Failed to exchange code for token');
      }
    } catch (e) {
      if (e.toString().contains('Failed to host lookup')) {
        throw Exception('Cannot connect to server. Please ensure the backend is running on localhost:8080');
      }
      throw Exception('Network error during token exchange: $e');
    }
  }

  static bool _verifyEssentialScopes(String grantedScopes) {
    final essentialScopes = [
      'classroom.coursework.students',
      'classroom.courses.readonly',
      'classroom.coursework.me',
    ];
    
    return essentialScopes.every((scope) => grantedScopes.contains(scope));
  }

  static bool isGoogleCallback() {
    final currentUrl = html.window.location.href;
    return currentUrl.contains('code=') && currentUrl.contains('state=google_auth');
  }

  static Future<Map<String, dynamic>> getUserInfo(String accessToken) async {
    try {
      final response = await http.get(
        Uri.parse('https://www.googleapis.com/oauth2/v2/userinfo'),
        headers: {'Authorization': 'Bearer $accessToken'},
      );

      if (response.statusCode == 200) {
        return json.decode(response.body);
      } else {
        throw Exception('Failed to get user info');
      }
    } catch (e) {
      throw Exception('Failed to get user info: $e');
    }
  }

  static Future<Map<String, dynamic>> testClassroomAccess(String accessToken) async {
    try {
      final coursesResponse = await http.get(
        Uri.parse('https://classroom.googleapis.com/v1/courses?pageSize=1'),
        headers: {'Authorization': 'Bearer $accessToken'},
      );

      if (coursesResponse.statusCode == 200) {
        final coursesData = json.decode(coursesResponse.body);
        
        return {
          'success': true,
          'message': 'Google Classroom API access confirmed',
          'canAccessCourses': true,
          'coursesFound': coursesData['courses']?.length ?? 0,
          'gradeUploadReady': true,
        };
      } else {
        return {
          'success': false,
          'error': 'Google Classroom API access denied: ${coursesResponse.statusCode}',
          'details': coursesResponse.body,
          'missingScopes': true,
        };
      }
    } catch (e) {
      return {
        'success': false,
        'error': 'Google Classroom API test failed: $e',
      };
    }
  }

  static bool isVerificationRequired() {
    return true;
  }

  static String getVerificationGuidance() {
    return 'For grade upload functionality, your OAuth app needs verification:\n\n'
           '1. Submit for OAuth verification in Google Cloud Console\n'
           '2. Select "Educational application" as use case\n'
           '3. Provide demo video showing automated grading workflow\n'
           '4. Explain that this is for teacher use to streamline grading\n'
           '5. Verification typically takes 1-2 weeks for educational apps\n\n'
           'Essential scopes needed: classroom.coursework.students, classroom.courses.readonly';
  }

  static Future<Map<String, dynamic>> testGradeUploadPermission(String accessToken, String courseId, String courseWorkId) async {
    try {
      final submissionsResponse = await http.get(
        Uri.parse('https://classroom.googleapis.com/v1/courses/$courseId/courseWork/$courseWorkId/studentSubmissions?pageSize=1'),
        headers: {'Authorization': 'Bearer $accessToken'},
      );

      if (submissionsResponse.statusCode == 200) {
        return {
          'success': true,
          'message': 'Grade upload permissions verified',
          'canModifyGrades': true,
        };
      } else if (submissionsResponse.statusCode == 403) {
        return {
          'success': false,
          'error': 'Permission denied for grade operations',
          'needsScopes': ['classroom.coursework.students'],
          'statusCode': 403,
        };
      } else {
        return {
          'success': false,
          'error': 'Cannot access submissions: ${submissionsResponse.statusCode}',
          'statusCode': submissionsResponse.statusCode,
        };
      }
    } catch (e) {
      return {
        'success': false,
        'error': 'Grade upload permission test failed: $e',
      };
    }
  }
}
