  }

  void setSubmissions(List<Submission> submissions) {
    _submissions = submissions;
    _error = null;
    _updateFileAccessStats();
    notifyListeners();
  }

  Future<void> loadSubmissions(String assignmentId) async {
    _isLoading = true;
    _error = null;
    notifyListeners();

    try {
      final submissionsData = await ApiService.getAssignmentSubmissionsEnhanced(assignmentId);
      
      _submissions = submissionsData.map((data) {
        try {
          final List<CodeFile> codeFiles = [];
          
          if (data['processedFiles'] != null) {
            for (var fileData in data['processedFiles']) {
              codeFiles.add(CodeFile(
                filename: fileData['filename'],
                content: fileData['content'],
                language: fileData['language'],
              ));
            }
          } else {
            final attachments = data['assignmentSubmission']?['attachments'] ?? [];
            for (var attachment in attachments) {
              if (attachment['driveFile'] != null) {
                final fileName = attachment['driveFile']['title'];
                codeFiles.add(CodeFile(
                  filename: fileName,
                  content: _generateFallbackContent(fileName),
                  language: _detectLanguageFromFilename(fileName),
                ));
              }
            }
          }
          
          return Submission(
            id: data['id'] ?? 'unknown-${DateTime.now().millisecondsSinceEpoch}',
            assignmentId: assignmentId,
            studentId: data['userId'] ?? 'unknown',
            studentName: _extractStudentName(data),
            files: codeFiles,
            submittedAt: DateTime.parse(data['updateTime'] ?? DateTime.now().toIso8601String()),
            status: _mapSubmissionStatus(data['state']),
          );
        } catch (e) {
          rethrow;
        }
      }).toList();
      
      _updateFileAccessStats();
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isLoading = false;
      notifyListeners();
      rethrow;
    }
  }

  void _updateFileAccessStats() {
    int accessibleFiles = 0;
    int totalFiles = 0;
    int submissionsWithFiles = 0;
    final languageDistribution = <String, int>{};
    
    for (var submission in _submissions) {
      if (submission.files.isNotEmpty) {
        submissionsWithFiles++;
        totalFiles += submission.files.length;
        
        for (var file in submission.files) {
          final language = file.language;
          languageDistribution[language] = (languageDistribution[language] ?? 0) + 1;
          
          if (!file.content.contains('original code inaccessible') &&
              !file.content.contains('REAL FILE FETCH FAILED') &&
              !file.content.contains('Placeholder')) {
            accessibleFiles++;
          }
        }
      }
    }
    
    _fileAccessStats = {
      'totalSubmissions': _submissions.length,
      'submissionsWithFiles': submissionsWithFiles,
      'totalFiles': totalFiles,
      'accessibleFiles': accessibleFiles,
      'inaccessibleFiles': totalFiles - accessibleFiles,
      'accessRate': totalFiles > 0 ? (accessibleFiles / totalFiles * 100).round() : 0,
      'languageDistribution': languageDistribution,
      'lastUpdated': DateTime.now().toIso8601String(),
    };
    
    if (accessibleFiles == 0 && totalFiles > 0) {
      _error = 'Files found but none accessible - check Google Drive permissions and OAuth scopes';
    }
  }

  String _extractStudentName(Map<String, dynamic> data) {
    final userId = data['userId']?.toString() ?? 'unknown';
    return 'Student ${userId.substring(userId.length >= 4 ? userId.length - 4 : 0)}';
  }
  
  String _mapSubmissionStatus(String? state) {
    switch (state) {
      case 'TURNED_IN':
        return 'submitted';
      case 'CREATED':
        return 'draft';
      case 'RECLAIMED_BY_STUDENT':
        return 'reclaimed';
      case 'RETURNED':
        return 'returned';
      default:
        return 'unknown';
    }
  }

  String _detectLanguageFromFilename(String filename) {
    final extension = filename.split('.').last.toLowerCase();
    switch (extension) {
      case 'java': return 'java';
      case 'py': return 'python';
      case 'js': return 'javascript';
      case 'cpp': case 'cc': case 'cxx': return 'cpp';
      case 'c': return 'c';
      default: return 'unknown';
    }
  }

  String _generateFallbackContent(String filename) {
    final language = _detectLanguageFromFilename(filename);
    final className = filename.split('.').first;
    
    switch (language) {
      case 'java':
        return '''
public class $className {
    // Original student code was inaccessible from Google Drive
    public static void main(String[] args) {
        System.out.println("File access failed - check OAuth scopes");
    }
}
''';
      case 'python':
        return '''
# $filename - Original code inaccessible
print("File access failed - check OAuth scopes")
''';
      default:
        return '// $filename - Original code inaccessible from Google Drive';
    }
  }

  void selectSubmission(Submission submission) {
    _selectedSubmission = submission;
    notifyListeners();
  }

  Future<void> executeCode(String language, Map<String, dynamic> codeData) async {
    _isLoading = true;
    _error = null;
    notifyListeners();

    try {
      _executionResult = await ApiService.executeCode(language, codeData);
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _executionResult = {
        'success': false,
        'error': e.toString(),
        'output': 'Execution failed: $e',
      };
      _isLoading = false;
      notifyListeners();
    }
  }

  Future<void> gradeSubmission(String submissionId, Map<String, dynamic> gradeData) async {
    _isGrading = true;
    _error = null;
    notifyListeners();

    try {
      await ApiService.gradeSubmission(submissionId, gradeData);
      
      final index = _submissions.indexWhere((s) => s.id == submissionId);
      if (index != -1) {
        try {
          final gradeResponse = await ApiService.getGrade(submissionId);
          final grade = Grade.fromJson(gradeResponse['grade']);
          
          final updatedSubmission = Submission(
            id: _submissions[index].id,
            assignmentId: _submissions[index].assignmentId,
            studentId: _submissions[index].studentId,
            studentName: _submissions[index].studentName,
            files: _submissions[index].files,
            submittedAt: _submissions[index].submittedAt,
            status: 'graded',
            grade: grade,
          );
          
          _submissions[index] = updatedSubmission;
          if (_selectedSubmission?.id == submissionId) {
            _selectedSubmission = updatedSubmission;
          }
        } catch (gradeError) {
          // Ignore grade fetch errors
        }
      }
      
      _isGrading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isGrading = false;
      notifyListeners();
    }
  }

  Future<void> gradeSubmissionWithFiles(String submissionId, Map<String, dynamic> submissionData) async {
    _isGrading = true;
    _error = null;
    notifyListeners();

    try {
      final response = await ApiService.gradeSubmissionWithFiles(submissionId, submissionData);
      
      if (response['success'] == true) {
        if (response['executionResult'] != null) {
          _executionResult = response['executionResult'];
        }
        
        final index = _submissions.indexWhere((s) => s.id == submissionId);
        if (index != -1 && response['grade'] != null) {
          final grade = Grade.fromJson(response['grade']);
          
          final updatedSubmission = Submission(
            id: _submissions[index].id,
            assignmentId: _submissions[index].assignmentId,
            studentId: _submissions[index].studentId,
            studentName: _submissions[index].studentName,
            files: _submissions[index].files,
            submittedAt: _submissions[index].submittedAt,
            status: 'graded',
            grade: grade,
            originalZipData: _submissions[index].originalZipData,
            isZipSubmission: _submissions[index].isZipSubmission,
          );
          
          _submissions[index] = updatedSubmission;
          if (_selectedSubmission?.id == submissionId) {
            _selectedSubmission = updatedSubmission;
          }
        }
      } else {
        throw Exception(response['error'] ?? 'Grading failed');
      }
      
      _isGrading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isGrading = false;
      notifyListeners();
    }
  }

  Future<void> gradeAllSubmissions(String assignmentId) async {
    _isGrading = true;
    _error = null;
    notifyListeners();

    try {
      final response = await ApiService.gradeAllSubmissions(assignmentId);
      
      await loadSubmissions(assignmentId);
      
      _isGrading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isGrading = false;
      notifyListeners();
    }
  }

  Future<void> testCodeExecution(String language, Map<String, dynamic> testPayload) async {
    _isLoading = true;
    _error = null;
    notifyListeners();

    try {
      _executionResult = await ApiService.executeCode(language, testPayload);
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _executionResult = {
        'success': false,
        'error': e.toString(),
        'output': 'Test execution failed: $e',
        'language': language,
      };
      _isLoading = false;
      notifyListeners();
    }
  }

  Future<Map<String, dynamic>> testLambdaConnections() async {
    try {
      final result = await ApiService.testAllLambdaConnections();
      return result;
    } catch (e) {
      rethrow;
    }
  }

  void addSubmission(Submission submission) {
    _submissions.add(submission);
    _updateFileAccessStats();
    notifyListeners();
  }

  void removeSubmission(String submissionId) {
    _submissions.removeWhere((s) => s.id == submissionId);
    if (_selectedSubmission?.id == submissionId) {
      _selectedSubmission = null;
    }
    _updateFileAccessStats();
    notifyListeners();
  }

  void updateSubmission(Submission updatedSubmission) {
    final index = _submissions.indexWhere((s) => s.id == updatedSubmission.id);
    if (index != -1) {
      _submissions[index] = updatedSubmission;
      if (_selectedSubmission?.id == updatedSubmission.id) {
        _selectedSubmission = updatedSubmission;
      }
      _updateFileAccessStats();
      notifyListeners();
    }
  }

  List<Submission> getSubmissionsByStatus(String status) {
    return _submissions.where((s) => s.status == status).toList();
  }

  bool submissionHasMultipleFiles(String submissionId) {
    try {
      final submission = _submissions.firstWhere((s) => s.id == submissionId);
      return submission.hasMultipleFiles;
    } catch (e) {
      return false;
    }
  }

  Submission? getSubmissionById(String submissionId) {
    try {
      return _submissions.firstWhere((s) => s.id == submissionId);
    } catch (e) {
      return null;
    }
  }

  Map<String, int> get submissionsByLanguage {
    final languageCount = <String, int>{};
    for (final submission in _submissions) {
      final language = submission.primaryLanguage;
      languageCount[language] = (languageCount[language] ?? 0) + 1;
    }
    return languageCount;
  }

  void clearExecutionResult() {
    _executionResult = null;
    notifyListeners();
  }

  void clearError() {
    _error = null;
    notifyListeners();
  }

  void setExecutionResult(Map<String, dynamic> result) {
    _executionResult = _processLambdaResponse(result);
    _isLoading = false;
    _error = null;
    notifyListeners();
  }

  Map<String, dynamic> _processLambdaResponse(Map<String, dynamic> response) {
    if (response.containsKey('lambdaResult')) {
      return response['lambdaResult'];
    }
    
    if (response.containsKey('results')) {
      Map<String, dynamic> results = response['results'];
      if (results.isNotEmpty) {
        String firstKey = results.keys.first;
        return results[firstKey];
      }
    }
    
    return response;
  }

  Map<String, dynamic> getAccessibilityReport() {
    return _fileAccessStats ?? {
      'totalSubmissions': _submissions.length,
      'accessRate': 0,
      'message': 'No file access statistics available',
    };
  }

  void reset() {
    _submissions = [];
    _selectedSubmission = null;
    _isLoading = false;
    _isGrading = false;
    _error = null;
    _executionResult = null;
    _fileAccessStats = null;
    _currentPlatform = null;
    _classroomService = null;
    notifyListeners();
  }

  int get gradedSubmissionsCount {
    return _submissions.where((s) => s.grade != null).length;
  }

  double get averageGrade {
    final gradedSubmissions = _submissions.where((s) => s.grade != null);
    if (gradedSubmissions.isEmpty) return 0.0;
    
    final totalScore = gradedSubmissions.fold(0.0, (sum, s) => sum + s.grade!.percentage);
    return totalScore / gradedSubmissions.length;
  }

  Map<String, int> get gradeDistribution {
    final distribution = <String, int>{
      'A': 0,
      'B': 0,
      'C': 0,
      'D': 0,
      'F': 0,
    };
    
    for (final submission in _submissions) {
      if (submission.grade != null) {
        final letterGrade = submission.grade!.letterGrade;
        distribution[letterGrade] = (distribution[letterGrade] ?? 0) + 1;
      }
    }
    
    return distribution;
  }
}
