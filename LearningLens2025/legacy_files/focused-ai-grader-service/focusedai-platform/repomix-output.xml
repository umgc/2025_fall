Future<void> _tryManualMappingAPI() async {
  try {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final token = authProvider.token;
    
    if (token == null || _selectedAssignment == null) {
      print('❌ No token or assignment for manual API');
      return;
    }
    
    final assignmentId = _selectedAssignment!.id;
    
    print('🔗 Manual API: Checking existing mapping...');
    
    // Check if mapping exists
    final checkResponse = await http.get(
      Uri.parse('http://localhost:8080/api/mappings/assignments/$assignmentId'),
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer $token',
      },
    );
    
    print('🔗 Manual API: Check response: ${checkResponse.statusCode}');
    
    if (checkResponse.statusCode == 404) {
      print('🔗 Manual API: No mapping exists, creating one...');
      
      // Try to create mapping
      final createResponse = await http.post(
        Uri.parse('http://localhost:8080/api/mappings/assignments/$assignmentId/auto-map'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
      );
      
      print('🔗 Manual API: Create response: ${createResponse.statusCode}');
      print('🔗 Manual API: Create body: ${createResponse.body}');
      
      if (createResponse.statusCode == 200 || createResponse.statusCode == 201) {
        print('✅ Manual API: Mapping created successfully');
      } else {
        print('❌ Manual API: Failed to create mapping');
      }
      
    } else if (checkResponse.statusCode == 200) {
      print('✅ Manual API: Mapping already exists');
      print('🔗 Manual API: Existing mapping: ${checkResponse.body}');
    }
    
  } catch (e) {
    print('❌ Manual API failed: $e');
  }
}

