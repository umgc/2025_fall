import 'package:provider/provider.dart';
import 'package:file_picker/file_picker.dart';
import 'package:http/http.dart' as http;
import '../../providers/course_provider.dart';
import '../../providers/grading_provider.dart';
import '../../models/assignment.dart';
import '../../models/submission.dart';
import '../../models/course.dart';
import '../../widgets/code_editor/code_editor.dart';
import '../../widgets/test_file_upload_widget.dart';
import '../../services/zip_submission_service.dart';
import 'package:csv/csv.dart'; 
import 'package:flutter/foundation.dart';
import 'package:path_provider/path_provider.dart';
import 'dart:io' as io;
import 'dart:html' as html;
import '../../widgets/grading/assignment_mapping_dialog.dart';
import '../../config/app_config.dart';

class UnifiedGradingScreen extends StatefulWidget {
  const UnifiedGradingScreen({super.key});

  @override
  State<UnifiedGradingScreen> createState() => _UnifiedGradingScreenState();
}

class _UnifiedGradingScreenState extends State<UnifiedGradingScreen> {
  bool _sidebarCollapsed = false;
  Course? _selectedCourse;
  Assignment? _selectedAssignment;
  Submission? _selectedSubmission;
  bool _isGrading = false;
  bool _isGradingAll = false;
  final Map<String, Map<String, dynamic>> _gradingResults = {};
  String? _currentPlatform;

  static const Color _primaryTextColor = Color(0xFF1A1A1A);
  static const Color _secondaryTextColor = Color(0xFF424242);
  static const Color _mutedTextColor = Color(0xFF616161);
  static const Color _lightBackgroundColor = Color(0xFFFAFAFA);
  static const Color _cardBackgroundColor = Colors.white;
  static const Color _borderColor = Color(0xFFE0E0E0);
  static const Color _successColor = Color(0xFF2E7D32);
  static const Color _warningColor = Color(0xFFFF8F00);
  static const Color _errorColor = Color(0xFFD32F2F);
  
  Map<String, dynamic> _testFiles = {};
  bool _useUploadedTestFiles = false;

  bool get _isGradingEnabled {
    return _useUploadedTestFiles && 
           _testFiles['hasFiles'] == true &&
           _testFiles['inputContent'] != null && 
           _testFiles['inputContent'].toString().trim().isNotEmpty &&
           _testFiles['outputContent'] != null && 
           _testFiles['outputContent'].toString().trim().isNotEmpty &&
           _testFiles['inputFilename'] != null &&
           _testFiles['outputFilename'] != null;
  }
  
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _initializePlatformContext();
      _loadInitialData();
    });
  }

  Future<void> _initializePlatformContext() async {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
    
    final platform = authProvider.platform;
    
    if (platform != null) {
      setState(() {
        _currentPlatform = platform;
      });
      
      gradingProvider.setPlatformContext(platform);
      
      if (platform.toLowerCase() == 'google' || platform.toLowerCase() == 'google_classroom') {
        final classroomService = authProvider.getClassroomService();
        if (classroomService != null) {
          gradingProvider.initializeGoogleClassroom(classroomService);
        }
      }
      
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Row(
              children: [
                Icon(
                  _getPlatformIcon(platform),
                  color: Colors.white,
                ),
                const SizedBox(width: 8),
                Text('Connected to ${_getPlatformDisplayName(platform)}'),
              ],
            ),
            backgroundColor: _getPlatformColor(platform),
            duration: const Duration(seconds: 2),
          ),
        );
      }
    }
  }

  IconData _getPlatformIcon(String platform) {
    switch (platform.toLowerCase()) {
      case 'moodle':
        return Icons.school;
      case 'google':
      case 'google_classroom':
        return Icons.cloud;
      default:
        return Icons.cloud;
    }
  }

  String _getPlatformDisplayName(String platform) {
    switch (platform.toLowerCase()) {
      case 'moodle':
        return 'Moodle';
      case 'google':
      case 'google_classroom':
        return 'Google Classroom';
      default:
        return platform;
    }
  }

  Color _getPlatformColor(String platform) {
    switch (platform.toLowerCase()) {
      case 'moodle':
        return Colors.orange[700]!;
      case 'google':
      case 'google_classroom':
        return Colors.blue[700]!;
      default:
        return Colors.grey[700]!;
    }
  }

  Widget _buildPlatformIndicator() {
    if (_currentPlatform == null) return const SizedBox.shrink();
    
    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 8, vertical: 8),
      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
      decoration: BoxDecoration(
        color: _getPlatformColor(_currentPlatform!).withOpacity(0.15),
        border: Border.all(
          color: _getPlatformColor(_currentPlatform!),
          width: 1.5,
        ),
        borderRadius: BorderRadius.circular(16),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(
            _getPlatformIcon(_currentPlatform!),
            size: 16,
            color: _getPlatformColor(_currentPlatform!),
          ),
          const SizedBox(width: 6),
          Text(
            _getPlatformDisplayName(_currentPlatform!),
            style: TextStyle(
              color: _getPlatformColor(_currentPlatform!).withOpacity(0.9),
              fontWeight: FontWeight.w700,
              fontSize: 13,
              letterSpacing: 0.2,
            ),
          ),
        ],
      ),
    );
  }

  Future<void> _loadInitialData() async {
    final courseProvider = Provider.of<CourseProvider>(context, listen: false);
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    
    try {
      if (authProvider.platform != null && authProvider.token != null) {
        await courseProvider.loadCourses(platform: authProvider.platform);
      }
    } catch (e) {
      if (mounted) {
        _showErrorMessage('Error loading courses: $e');
      }
    }
  }

  void _handleTestFilesChanged(Map<String, dynamic> files) {
  // ✅ FIXED: Use post-frame callback to avoid setState during build
  WidgetsBinding.instance.addPostFrameCallback((_) {
    if (mounted) {
      setState(() {
        _testFiles = files;
        _useUploadedTestFiles = files['filesReady'] == true;
      });
      
      if (files['filesReady'] == true && mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Row(
              children: [
                const Icon(Icons.check_circle, color: Colors.white),
                const SizedBox(width: 8),
                Text('Test files ready: ${files['inputFilename']} → ${files['outputFilename']}'),
              ],
            ),
            backgroundColor: Colors.green[600],
            duration: const Duration(seconds: 2),
          ),
        );
      }
    }
  });
}

  Future<void> _onCourseSelected(String? courseId) async {
  if (courseId == null) return;
  
  final courseProvider = Provider.of<CourseProvider>(context, listen: false);
  final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
  
  // Clear current state
  setState(() {
    _selectedCourse = null;
    _selectedAssignment = null;
    _selectedSubmission = null;
  });
  
  gradingProvider.reset();
  
  try {
    await courseProvider.selectCourse(courseId);
    setState(() {
      _selectedCourse = courseProvider.selectedCourse;
    });
    
    // Validate assignment selection after course change
    _validateAndUpdateAssignmentSelection();
    
  } catch (e) {
    _showErrorMessage('Failed to load course: $e');
  }
}

String? get _safeAssignmentDropdownValue {
  if (_selectedAssignment == null || _selectedCourse == null) {
    return null;
  }
  
  try {
    // Simple check - just verify the assignment exists in the current course
    final assignmentExists = _selectedCourse!.assignments.any(
      (assignment) => assignment.id == _selectedAssignment!.id
    );
    
    if (assignmentExists) {
      // ✅ FIXED: Don't clear selection aggressively - just return the ID
      return _selectedAssignment!.id;
    } else {
      // Only clear if assignment truly doesn't exist
      print('⚠️ Selected assignment not found in current course: ${_selectedAssignment!.id}');
      return null;
    }
  } catch (e) {
    print('⚠️ Error validating assignment dropdown value: $e');
    return null;
  }
}

  Future<void> _onAssignmentSelected(String? assignmentId) async {
  if (assignmentId == null || _selectedCourse == null) return;
  
  final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
  final courseProvider = Provider.of<CourseProvider>(context, listen: false);
  
  // Find the assignment
  Assignment? assignment;
  try {
    assignment = _selectedCourse!.assignments.firstWhere(
      (a) => a.id == assignmentId,
    );
  } catch (e) {
    _showErrorMessage('Assignment not found');
    return;
  }
  
  // ✅ CRITICAL: Set selection FIRST, then handle loading
  setState(() {
    _selectedAssignment = assignment;
    _selectedSubmission = null;
  });

  print('🔍 Assignment selected: ${assignment.name} (${assignment.id})');
  print('🔍 Platform: $_currentPlatform');

  // Handle Google Classroom mapping if needed
  if (_currentPlatform?.toLowerCase() == 'google' && 
      assignment.googleClassroomCourseId == null) {
    
    try {
      await courseProvider.autoMapGoogleClassroomAssignments(_selectedCourse!.id, context);
      await Future.delayed(const Duration(seconds: 1)); // Shorter delay
      
      final updatedAssignment = await _fetchAssignmentFromBackend(assignmentId);
      
      if (updatedAssignment != null && mounted) {
        final updatedCourseAssignments = _selectedCourse!.assignments.map((a) {
          return a.id == assignmentId ? updatedAssignment : a;
        }).toList();
        
        final updatedCourse = _createUpdatedCourse(updatedCourseAssignments);
        
        setState(() {
          _selectedCourse = updatedCourse;
          _selectedAssignment = updatedAssignment;
        });
        
        if (updatedAssignment.googleClassroomCourseId != null) {
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(
                content: Row(
                  children: [
                    const Icon(Icons.link, color: Colors.white),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text('✅ Google Classroom mapping: ${updatedAssignment.name}'),
                    ),
                  ],
                ),
                backgroundColor: Colors.green[600],
                duration: const Duration(seconds: 2),
              ),
            );
          }
        }
      }
    } catch (e) {
      print('❌ Auto-mapping failed: $e');
    }
  }

  // Load submissions
  try {
    await gradingProvider.loadSubmissions(assignmentId);
    
    final stats = gradingProvider.getAccessibilityReport();
    if (stats['accessRate'] < 100 && stats['totalFiles'] > 0) {
      _showFileAccessInfo(stats);
    }
    
    if (gradingProvider.submissions.isEmpty && assignment.submissions.isNotEmpty) {
      gradingProvider.setSubmissions(assignment.submissions);
    }
    
  } catch (e) {
    print('❌ Error loading submissions: $e');
    
    if (assignment.submissions.isNotEmpty) {
      gradingProvider.setSubmissions(assignment.submissions);
    } else {
      _showNoSubmissionsDialog(assignment.name);
    }
  }
}



Future<Assignment?> _fetchAssignmentFromBackend(String assignmentId) async {
  try {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final token = authProvider.token;
    
    if (token == null) {
      print('❌ No auth token available');
      return null;
    }
    
    print('🔗 Fetching assignment $assignmentId from backend...');
    
    // ✅ FIXED: Try multiple endpoints to get the assignment data
    Assignment? assignment;
    
    // Method 1: Try to get assignment through courses endpoint
    try {
      if (_selectedCourse != null) {
        print('🔗 Method 1: Fetching through courses endpoint...');
        final courseResponse = await http.get(
          Uri.parse('http://localhost:8080/api/courses/${_selectedCourse!.id}/assignments'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
        );
        
        print('🔗 Course assignments response: ${courseResponse.statusCode}');
        
        if (courseResponse.statusCode == 200) {
          final List<dynamic> assignmentsJson = json.decode(courseResponse.body);
          final assignments = assignmentsJson.map((json) => Assignment.fromJson(json)).toList();
          
          assignment = assignments.firstWhere(
            (a) => a.id == assignmentId,
            orElse: () => throw Exception('Assignment not found in course'),
          );
          
          print('🔗 Method 1: Found assignment with mapping data');
          print('🔗 Method 1: Google Classroom Course ID: ${assignment.googleClassroomCourseId}');
          print('🔗 Method 1: Google Classroom Assignment ID: ${assignment.googleClassroomId}');
        }
      }
    } catch (e) {
      print('🔗 Method 1 failed: $e');
    }
    
    // Method 2: Try direct assignment endpoint (if Method 1 failed)
    if (assignment == null) {
      try {
        print('🔗 Method 2: Trying direct assignment endpoint...');
        final response = await http.get(
          Uri.parse('http://localhost:8080/api/assignments/$assignmentId'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
        );
        
        print('🔗 Method 2: Direct assignment response: ${response.statusCode}');
        
        if (response.statusCode == 200) {
          final data = json.decode(response.body);
          assignment = Assignment.fromJson(data);
          print('🔗 Method 2: Google Classroom Course ID: ${assignment.googleClassroomCourseId}');
          print('🔗 Method 2: Google Classroom Assignment ID: ${assignment.googleClassroomId}');
        }
      } catch (e) {
        print('🔗 Method 2 failed: $e');
      }
    }
    
    // Method 3: Try to get the mapping data directly and apply it to current assignment
    if (assignment == null || (assignment.googleClassroomCourseId == null)) {
      try {
        print('🔗 Method 3: Fetching mapping data directly...');
        final mappingResponse = await http.get(
          Uri.parse('http://localhost:8080/api/mappings/assignments/$assignmentId'),
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer $token',
          },
        );
        
        print('🔗 Method 3: Mapping response: ${mappingResponse.statusCode}');
        
        if (mappingResponse.statusCode == 200) {
          final mappingData = json.decode(mappingResponse.body);
          print('🔗 Method 3: Mapping data: $mappingData');
          
          // Create updated assignment with mapping data using helper method
          assignment = _createUpdatedAssignmentWithMapping(mappingData);
          
          print('🔗 Method 3: Created assignment with mapping data');
          print('🔗 Method 3: Google Classroom Course ID: ${assignment.googleClassroomCourseId}');
          print('🔗 Method 3: Google Classroom Assignment ID: ${assignment.googleClassroomId}');
        }
      } catch (e) {
        print('🔗 Method 3 failed: $e');
      }
    }
    
    if (assignment != null) {
      print('✅ Successfully fetched assignment data');
      return assignment;
    } else {
      print('❌ All methods failed to fetch assignment data');
      return null;
    }
    
  } catch (e) {
    print('❌ Error fetching assignment from backend: $e');
    return null;
  }
}

Assignment _createUpdatedAssignmentWithMapping(Map<String, dynamic> mappingData) {
  final currentAssignment = _selectedAssignment!;
  
  // ✅ FIXED: Extract mapping data from the correct nested structure
  final mapping = mappingData['mapping'] ?? mappingData;
  final googleClassroomCourseId = mapping['courseId']?.toString();
  final googleClassroomId = mapping['courseWorkId']?.toString();
  
  print('🔧 Creating assignment with mapping:');
  print('   Course ID: $googleClassroomCourseId');
  print('   Assignment ID: $googleClassroomId');
  
  return Assignment(
    id: currentAssignment.id,
    courseId: currentAssignment.courseId,
    name: currentAssignment.name,
    description: currentAssignment.description,
    language: currentAssignment.language,
    maxScore: currentAssignment.maxScore,
    dueDate: currentAssignment.dueDate,
    createdAt: currentAssignment.createdAt,
    submissions: currentAssignment.submissions,
    googleClassroomCourseId: googleClassroomCourseId,
    googleClassroomId: googleClassroomId,
  );
}

