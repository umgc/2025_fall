  Future<void> _uploadSelectedGradesToPlatform(
  List<Map<String, dynamic>> selectedResults,
  GradingProvider gradingProvider,
) async {
  try {
    // ✅ FIXED: Ensure platform context is set before uploading
    await _ensurePlatformContext();
    
    final gradesData = selectedResults.map((result) {
      final submission = result['submission'] as Submission;
      final assignment = result['assignment'] as Assignment;
      
      final finalGrade = result['editedGrade'] ?? result['outputSimilarity'] ?? 0;
      
      // ✅ ADDED: Debug logging for each grade
      print('🔍 Processing grade for ${submission.studentName}:');
      print('   Assignment ID: ${assignment.id}');
      print('   Assignment Name: ${assignment.name}');
      print('   Google Classroom Course ID: ${assignment.googleClassroomCourseId}');
      print('   Google Classroom Assignment ID: ${assignment.googleClassroomId}');
      print('   Platform: $_currentPlatform');
      
      final gradeData = {
        'submissionId': submission.id,
        'assignmentId': assignment.id,
        'studentId': submission.studentId,
        'studentName': submission.studentName,
        'score': finalGrade,
        'maxScore': assignment.maxScore,
        'letterGrade': _calculateLetterGrade(finalGrade),
        'feedback': '',
        'gradingResults': result,
        'platform': _currentPlatform,
        'googleClassroomCourseId': assignment.googleClassroomCourseId,
        'googleClassroomId': assignment.googleClassroomId,
      };
      
      return gradeData;
    }).toList();
    
    // ✅ ENHANCED: Better logging for Google Classroom platform check
    print('🔍 Platform check: $_currentPlatform');
    print('🔍 Is Google platform: ${_currentPlatform?.toLowerCase() == 'google' || _currentPlatform?.toLowerCase() == 'google_classroom'}');
    
    if (_currentPlatform?.toLowerCase() == 'google' || _currentPlatform?.toLowerCase() == 'google_classroom') {
      final missingMappingEntries = gradesData.where((grade) => 
        grade['googleClassroomCourseId'] == null || 
        grade['googleClassroomId'] == null
      ).toList();
      
      print('🔍 Missing mapping entries: ${missingMappingEntries.length}');
      
      if (missingMappingEntries.isNotEmpty) {
        print('❌ Missing mappings for:');
        for (var entry in missingMappingEntries) {
          print('   ${entry['studentName']}: Course ID = ${entry['googleClassroomCourseId']}, Assignment ID = ${entry['googleClassroomId']}');
        }
        
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(
              '❌ Missing Google Classroom mapping for ${missingMappingEntries.length} submissions',
            ),
            backgroundColor: Colors.orange,
          ),
        );
        return;
      }
    }
    
    print('✅ All mappings present, proceeding with upload...');
    
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: const Row(
          children: [
            CircularProgressIndicator(),
            SizedBox(width: 16),
            Text('Uploading Grades...'),
          ],
        ),
        content: Text('Uploading ${selectedResults.length} selected grades...'),
      ),
    );
    
    final response = await gradingProvider.uploadBatchGradesToPlatform(gradesData);
    
    Navigator.of(context).pop();
    
    if (response['success'] == true) {
      final uploaded = response['uploaded'] ?? gradesData.length;
      final errors = response['errors'] as List<String>? ?? [];
      
      String message = '✅ Upload successful: $uploaded/${gradesData.length} grades uploaded';
      if (errors.isNotEmpty) {
        message += '\n${errors.length} errors occurred';
      }
      
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Row(
                children: [
                  Icon(gradingProvider.uploadButtonIcon, color: Colors.white),
                  const SizedBox(width: 8),
                  Expanded(child: Text(message)),
                ],
              ),
              if (errors.isNotEmpty) ...[
                const SizedBox(height: 8),
                Text(
                  'Errors: ${errors.take(3).join(", ")}${errors.length > 3 ? "..." : ""}',
                  style: const TextStyle(fontSize: 12),
                ),
              ],
            ],
          ),
          backgroundColor: errors.isEmpty ? Colors.green : Colors.orange,
          duration: const Duration(seconds: 6),
        ),
      );
    } else {
      throw Exception(response['error'] ?? 'Unknown error occurred');
    }
    
  } catch (e) {
    try {
      Navigator.of(context).pop();
    } catch (e) {
      // Dialog might already be closed
    }
    
    print('❌ Upload failed: $e');
    
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('❌ Failed to upload selected grades: $e'),
        backgroundColor: Colors.red,
        duration: const Duration(seconds: 5),
      ),
    );
  }
}

void _validateAndUpdateAssignmentSelection() {
  // Check if the currently selected assignment still exists in the current course
  if (_selectedAssignment != null && _selectedCourse != null) {
    final assignmentExists = _selectedCourse!.assignments.any(
      (assignment) => assignment.id == _selectedAssignment!.id
    );
    
    if (!assignmentExists) {
      print('🔧 Selected assignment no longer exists in course, clearing selection');
      setState(() {
        _selectedAssignment = null;
        _selectedSubmission = null;
      });
    }
  }
}

Future<void> _forceCreateMapping() async {
  if (_selectedAssignment == null) {
    _showErrorMessage('No assignment selected');
    return;
  }

  final courseProvider = Provider.of<CourseProvider>(context, listen: false);
  
  try {
    print('🔗 Force creating mapping for ${_selectedAssignment!.name}...');
    
    // Try to create mapping via the check and create endpoint
    await _checkAndCreateMappingIfNeeded();
    
    // Reload the course to get updated assignment data
    await courseProvider.selectCourse(_selectedCourse!.id);
    final updatedCourse = courseProvider.selectedCourse;
    
    if (updatedCourse != null) {
      final updatedAssignment = updatedCourse.assignments.firstWhere(
        (a) => a.id == _selectedAssignment!.id,
        orElse: () => _selectedAssignment!,
      );
      
      setState(() {
        _selectedCourse = updatedCourse;
        _selectedAssignment = updatedAssignment;
      });
      
      print('🔍 After force mapping:');
      print('   Google Classroom Course ID: ${updatedAssignment.googleClassroomCourseId}');
      print('   Google Classroom Assignment ID: ${updatedAssignment.googleClassroomId}');
      
      if (updatedAssignment.googleClassroomCourseId != null && 
          updatedAssignment.googleClassroomId != null) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('✅ Mapping created successfully!'),
            backgroundColor: Colors.green,
          ),
        );
      } else {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: const Text('⚠️ Mapping creation may have failed'),
            backgroundColor: Colors.orange,
            action: SnackBarAction(
              label: 'Manual Setup',
              onPressed: () => _showManualMappingDialog(),
            ),
          ),
        );
      }
    }
    
  } catch (e) {
    print('❌ Force mapping failed: $e');
    _showErrorMessage('Failed to create mapping: $e');
  }
}

Future<void> _checkAndCreateMappingIfNeeded() async {
  try {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    final token = authProvider.token;
    
    if (token == null || _selectedAssignment == null) return;
    
    final assignmentId = _selectedAssignment!.id;
    
    print('🔍 Checking mapping for assignment: $assignmentId');
    
    final checkResponse = await http.get(
      Uri.parse('http://localhost:8080/api/mappings/assignments/$assignmentId'),
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer $token',
      },
    );
    
    print('🔍 Check mapping response: ${checkResponse.statusCode}');
    
    if (checkResponse.statusCode == 404) {
      print('❌ No mapping exists, attempting to create one...');
      
      // Try to create a mapping
      final createResponse = await http.post(
        Uri.parse('http://localhost:8080/api/mappings/assignments/$assignmentId/auto-map'),
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer $token',
        },
      );
      
      print('🔍 Create mapping response: ${createResponse.statusCode}');
      print('🔍 Create mapping body: ${createResponse.body}');
      
      if (createResponse.statusCode == 200 || createResponse.statusCode == 201) {
        print('✅ Mapping created successfully');
      } else {
        print('❌ Failed to create mapping: ${createResponse.body}');
      }
      
    } else if (checkResponse.statusCode == 200) {
      print('✅ Mapping already exists');
      print('🔍 Existing mapping: ${checkResponse.body}');
    } else {
      print('❌ Unexpected response: ${checkResponse.statusCode} - ${checkResponse.body}');
    }
    
  } catch (e) {
    print('❌ Error in checkAndCreateMappingIfNeeded: $e');
    rethrow;
  }
}

