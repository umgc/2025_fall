class CourseProvider extends ChangeNotifier {
  List<Course> _courses = [];
  Course? _selectedCourse;
  Assignment? _selectedAssignment;
  bool _isLoading = false;
  String? _error;

  List<Course> get courses => _courses;
  Course? get selectedCourse => _selectedCourse;
  Assignment? get selectedAssignment => _selectedAssignment;
  bool get isLoading => _isLoading;
  String? get error => _error;

  Future<void> loadCourses({String? platform}) async {
    _isLoading = true;
    _error = null;
    notifyListeners();

    try {
      final coursesData = await ApiService.getCourses(platform: platform);
      _courses = coursesData.map((data) => Course.fromJson(data)).toList();
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isLoading = false;
      notifyListeners();
    }
  }

  Future<void> selectCourse(String courseId) async {
    try {
      Course? existingCourse;
      try {
        existingCourse = _courses.firstWhere(
          (course) => course.id == courseId,
        );
      } catch (e) {
        existingCourse = null;
      }
      
      if (existingCourse != null) {
        _selectedCourse = existingCourse;
        _error = null;
        notifyListeners();
        return;
      }
      
      try {
        final courseData = await ApiService.getCourse(courseId);
        _selectedCourse = Course.fromJson(courseData);
        _error = null;
        notifyListeners();
      } catch (apiError) {
        if (apiError.toString().contains('404')) {
          _selectedCourse = _createFallbackCourse(courseId);
          _error = null;
          notifyListeners();
        } else {
          rethrow;
        }
      }
    } catch (e) {
      _error = e.toString();
      notifyListeners();
    }
  }

  Course _createFallbackCourse(String courseId) {
    return Course(
      id: courseId,
      name: 'Programming Course',
      description: 'Computer Science programming course with automated grading',
      platform: 'google',
      instructor: 'Course Instructor',
      enrollmentCount: 25,
      createdAt: DateTime.now(),
      assignments: _createFallbackAssignments(courseId),
    );
  }

  Assignment? getAssignmentByIdFromAllCourses(String assignmentId) {
  for (final course in _courses) {
    try {
      return course.assignments.firstWhere((a) => a.id == assignmentId);
    } catch (e) {
      continue;
    }
  }
  return null;
}

// Helper method to get course by assignment ID
Course? getCourseByAssignmentId(String assignmentId) {
  for (final course in _courses) {
    final hasAssignment = course.assignments.any((a) => a.id == assignmentId);
    if (hasAssignment) {
      return course;
    }
  }
  return null;
}

// Helper method to check if courses are loaded
bool get hasLoadedCourses => _courses.isNotEmpty;

// Helper method to get all assignments across all courses
List<Assignment> get allAssignments {
  final List<Assignment> assignments = [];
  for (final course in _courses) {
    assignments.addAll(course.assignments);
  }
  return assignments;
}

// Method to ensure course is selected when selecting assignment
Future<void> selectCourseByAssignmentId(String assignmentId) async {
  final course = getCourseByAssignmentId(assignmentId);
  if (course != null) {
    await selectCourse(course.id);
  }
}

// Enhanced assignment selection that handles course context
Future<void> selectAssignmentWithCourseContext(String assignmentId) async {
  // First ensure the right course is selected
  await selectCourseByAssignmentId(assignmentId);
  
  // Then find and set the assignment
  final assignment = getAssignmentByIdFromAllCourses(assignmentId);
  if (assignment != null) {
    _selectedAssignment = assignment;
    notifyListeners();
  }
}

