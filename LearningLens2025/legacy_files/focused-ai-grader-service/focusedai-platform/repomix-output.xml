// This is a basic Flutter widget test for the FocusedAI Teacher app.
//
// To perform an interaction with a widget in your test, use the WidgetTester
// utility in the flutter_test package. For example, you can send tap and scroll
// gestures. You can also use WidgetTester to find child widgets in the widget
// tree, read text, and verify that the values of widget properties are correct.

import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:provider/provider.dart';

import 'package:focusedai_teacher/main.dart';
import 'package:focusedai_teacher/providers/auth_provider.dart';
import 'package:focusedai_teacher/providers/course_provider.dart';
import 'package:focusedai_teacher/providers/grading_provider.dart';

void main() {
  testWidgets('App loads and shows login screen', (WidgetTester tester) async {
    // Build our app and trigger a frame.
    await tester.pumpWidget(const FocusedAIApp());

    // Wait for the widget tree to settle
    await tester.pumpAndSettle();

    // Verify that the login screen is displayed
    expect(find.text('FocusEd AI Teacher'), findsOneWidget);
    expect(find.text('Intelligent Code Grading Platform'), findsOneWidget);
    
    // Verify platform selection is present
    expect(find.text('Moodle'), findsOneWidget);
    expect(find.text('Google Classroom'), findsOneWidget);
    
    // Verify login form elements are present for Moodle (default)
    expect(find.text('Username'), findsOneWidget);
    expect(find.text('Password'), findsOneWidget);
    expect(find.text('Sign In'), findsOneWidget);
  });

  testWidgets('Platform switch works correctly', (WidgetTester tester) async {
    // Build our app and trigger a frame.
    await tester.pumpWidget(const FocusedAIApp());
    await tester.pumpAndSettle();

    // Initially should show Moodle login form
    expect(find.text('Username'), findsOneWidget);
    expect(find.text('Password'), findsOneWidget);

    // Tap on Google Classroom platform
    await tester.tap(find.text('Google Classroom'));
    await tester.pump();

    // Should now show Google login button instead of username/password
    expect(find.text('Sign in with Google'), findsOneWidget);
    expect(find.text('Username'), findsNothing);
    expect(find.text('Password'), findsNothing);
  });

  testWidgets('Login form validation works', (WidgetTester tester) async {
    // Build our app and trigger a frame.
    await tester.pumpWidget(const FocusedAIApp());
    await tester.pumpAndSettle();

    // Try to submit empty form
    await tester.tap(find.text('Sign In'));
    await tester.pump();

    // Should show validation errors
    expect(find.text('Please enter your username'), findsOneWidget);
    expect(find.text('Please enter your password'), findsOneWidget);
  });

  group('Provider tests', () {
    testWidgets('AuthProvider initializes correctly', (WidgetTester tester) async {
      late AuthProvider authProvider;
      
      await tester.pumpWidget(
        ChangeNotifierProvider<AuthProvider>(
          create: (_) => authProvider = AuthProvider(),
          child: MaterialApp(
            home: Consumer<AuthProvider>(
              builder: (context, auth, child) {
                return Scaffold(
                  body: Text('Authenticated: ${auth.isAuthenticated}'),
                );
              },
            ),
          ),
        ),
      );

      await tester.pumpAndSettle();

      // Initially should not be authenticated
      expect(authProvider.isAuthenticated, false);
      expect(find.text('Authenticated: false'), findsOneWidget);
    });

    testWidgets('CourseProvider initializes correctly', (WidgetTester tester) async {
      late CourseProvider courseProvider;
      
      await tester.pumpWidget(
        ChangeNotifierProvider<CourseProvider>(
          create: (_) => courseProvider = CourseProvider(),
          child: MaterialApp(
            home: Consumer<CourseProvider>(
              builder: (context, courses, child) {
                return Scaffold(
                  body: Text('Courses: ${courses.courses.length}'),
                );
              },
            ),
          ),
        ),
      );

      await tester.pumpAndSettle();

      // Initially should have no courses
      expect(courseProvider.courses.length, 0);
      expect(find.text('Courses: 0'), findsOneWidget);
    });

    testWidgets('GradingProvider initializes correctly', (WidgetTester tester) async {
      late GradingProvider gradingProvider;
      
      await tester.pumpWidget(
        ChangeNotifierProvider<GradingProvider>(
          create: (_) => gradingProvider = GradingProvider(),
          child: MaterialApp(
            home: Consumer<GradingProvider>(
              builder: (context, grading, child) {
                return Scaffold(
                  body: Text('Submissions: ${grading.submissions.length}'),
                );
              },
            ),
          ),
        ),
      );

      await tester.pumpAndSettle();

      // Initially should have no submissions
      expect(gradingProvider.submissions.length, 0);
      expect(find.text('Submissions: 0'), findsOneWidget);
    });
  });
}
