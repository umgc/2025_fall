  void _showFileAccessInfo(Map<String, dynamic> stats) {
    if (mounted) {
      final accessRate = stats['accessRate'] ?? 0;
      final totalFiles = stats['totalFiles'] ?? 0;
      final accessibleFiles = stats['accessibleFiles'] ?? 0;
      
      Color backgroundColor;
      IconData icon;
      String message;
      
      if (accessRate >= 80) {
        backgroundColor = Colors.green[600]!;
        icon = Icons.check_circle;
        message = 'Good file access rate';
      } else if (accessRate >= 50) {
        backgroundColor = Colors.orange[600]!;
        icon = Icons.warning;
        message = 'Partial file access - some files inaccessible';
      } else {
        backgroundColor = Colors.red[600]!;
        icon = Icons.error;
        message = 'Poor file access - check OAuth permissions';
      }
      
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Row(
            children: [
              Icon(icon, color: Colors.white),
              const SizedBox(width: 8),
              Expanded(
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(message),
                    Text(
                      '$accessibleFiles/$totalFiles files accessible ($accessRate%)',
                      style: const TextStyle(fontSize: 12),
                    ),
                  ],
                ),
              ),
            ],
          ),
          backgroundColor: backgroundColor,
          duration: const Duration(seconds: 6),
        ),
      );
    }
  }

