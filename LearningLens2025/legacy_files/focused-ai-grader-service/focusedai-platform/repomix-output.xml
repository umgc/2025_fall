      return;
    }

    final gradingProvider = Provider.of<GradingProvider>(context, listen: false);
    
    try {
      Map<String, dynamic> testPayload = {
        'files': _selectedSubmission!.files.map((file) => {
          'filename': file.filename,
          'content': file.content,
          'language': file.language,
        }).toList(),
        'assignmentId': _selectedAssignment?.id ?? '',
        'submissionId': _selectedSubmission!.id,
      };

      if (_useUploadedTestFiles && _testFiles['hasFiles'] == true) {
        testPayload['input'] = _testFiles['inputContent'] ?? '';
        testPayload['expectedOutput'] = _testFiles['outputContent'] ?? '';
        testPayload['testInput'] = _testFiles['inputContent'] ?? '';
        testPayload['useUploadedTestFiles'] = true;
        testPayload['inputFilename'] = _testFiles['inputFilename'];
        testPayload['outputFilename'] = _testFiles['outputFilename'];
      } else {
        testPayload['input'] = '';
        testPayload['expectedOutput'] = '';
        testPayload['useUploadedTestFiles'] = false;
      }
      
      testPayload['executionMode'] = 'TESTING';
      
      await gradingProvider.executeCode(_selectedSubmission!.primaryLanguage, testPayload);
      
      if (mounted) {
        final result = gradingProvider.executionResult;
        String message = 'Code executed successfully!';
        
        if (result != null) {
          if (result['testPassed'] == true) {
            message = 'Code executed - Test PASSED! ✅';
          } else if (result['testPassed'] == false) {
            message = 'Code executed - Test FAILED ❌';
          } else if (_useUploadedTestFiles) {
            message = 'Code executed with test files!';
          }
        }
        
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(message),
            backgroundColor: result?['testPassed'] == true 
                ? Colors.green 
                : result?['testPassed'] == false 
                  ? Colors.orange 
                  : Colors.blue,
          ),
        );
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Execution failed: ${e.toString().length > 50 ? '${e.toString().substring(0, 50)}...' : e.toString()}'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

