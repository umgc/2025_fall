import 'package:flutter/material.dart';
import 'package:focusedai_teacher/providers/auth_provider.dart';
import 'package:focusedai_teacher/services/google_auth_service.dart';
import 'package:provider/provider.dart';
import 'dart:html' as html;
import '../../config/app_config.dart';

class LoginScreen extends StatefulWidget {
  const LoginScreen({super.key});

  @override
  State<LoginScreen> createState() => _LoginScreenState();
}

class _LoginScreenState extends State<LoginScreen> {
  final _formKey = GlobalKey<FormState>();
  final _usernameController = TextEditingController();
  final _passwordController = TextEditingController();
  String _selectedPlatform = 'moodle';
  bool _obscurePassword = true;
  bool _isProcessingCallback = false;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _checkForGoogleCallback();
    });
  }

  void _checkForGoogleCallback() {
    if (_isProcessingCallback) return;
    
    final currentUrl = html.window.location.href;
    
    if (currentUrl.contains('code=') && currentUrl.contains('state=google_auth')) {
      final code = GoogleAuthService.extractCodeFromUrl(currentUrl);
      if (code != null && !_isProcessingCallback) {
        setState(() {
          _isProcessingCallback = true;
        });
        _handleGoogleCallback(code);
      }
    }
  }

  Future<void> _handleGoogleCallback(String code) async {
    final authProvider = Provider.of<AuthProvider>(context, listen: false);
    
    try {
      final success = await authProvider.loginGoogle(code);
      if (success && mounted) {
        html.window.history.replaceState({}, '', '/');
        Navigator.of(context).pushReplacementNamed('/dashboard');
      } else if (mounted) {
        setState(() {
          _isProcessingCallback = false;
        });
        _showErrorMessage('Google authentication failed. Please try again.');
      }
    } catch (e) {
      if (mounted) {
        setState(() {
          _isProcessingCallback = false;
        });
        _showErrorMessage('Authentication error: $e');
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    if (_isProcessingCallback) {
      return Scaffold(
        body: Container(
          decoration: BoxDecoration(
            gradient: LinearGradient(
              begin: Alignment.topLeft,
              end: Alignment.bottomRight,
              colors: [
                Theme.of(context).primaryColor,
                Theme.of(context).primaryColor.withOpacity(0.8),
              ],
            ),
          ),
          child: const Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                CircularProgressIndicator(color: Colors.white),
                SizedBox(height: 16),
                Text(
                  'Processing Google authentication...',
                  style: TextStyle(color: Colors.white, fontSize: 16),
                ),
              ],
            ),
          ),
        ),
      );
    }

    return Scaffold(
      body: Container(
        decoration: BoxDecoration(
          gradient: LinearGradient(
            begin: Alignment.topLeft,
            end: Alignment.bottomRight,
            colors: [
              Theme.of(context).primaryColor,
              Theme.of(context).primaryColor.withOpacity(0.8),
            ],
          ),
        ),
        child: SafeArea(
          child: Center(
            child: SingleChildScrollView(
              padding: const EdgeInsets.all(24.0),
              child: Card(
                elevation: 8,
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(16),
                ),
                child: Padding(
                  padding: const EdgeInsets.all(32.0),
                  child: Column(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Icon(
                        Icons.school,
                        size: 64,
                        color: Theme.of(context).primaryColor,
                      ),
                      const SizedBox(height: 16),
                      Text(
                        AppConfig.appName,
                        style: Theme.of(context).textTheme.headlineMedium?.copyWith(
                          fontWeight: FontWeight.bold,
                          color: Theme.of(context).primaryColor,
                        ),
                      ),
                      const SizedBox(height: 8),
                      Text(
                        'Intelligent Code Grading Platform',
                        style: Theme.of(context).textTheme.bodyMedium?.copyWith(
                          color: Colors.grey[600],
                        ),
                      ),
                      const SizedBox(height: 32),
                      
                      _buildPlatformSelector(),
                      const SizedBox(height: 24),
                      
                      if (_selectedPlatform == 'moodle') ...[
                        _buildMoodleLoginForm(),
                      ] else ...[
                        _buildGoogleLoginButton(),
                      ],
                    ],
                  ),
                ),
              ),
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildPlatformSelector() {
    return Container(
      padding: const EdgeInsets.all(4),
      decoration: BoxDecoration(
        color: Colors.grey[200],
        borderRadius: BorderRadius.circular(8),
      ),
      child: Row(
        children: [
          Expanded(
            child: GestureDetector(
              onTap: () => setState(() => _selectedPlatform = 'moodle'),
              child: Container(
                padding: const EdgeInsets.symmetric(vertical: 12),
                decoration: BoxDecoration(
                  color: _selectedPlatform == 'moodle' 
                      ? Theme.of(context).primaryColor 
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(6),
                ),
                child: Text(
                  'Moodle',
                  textAlign: TextAlign.center,
                  style: TextStyle(
                    color: _selectedPlatform == 'moodle' 
                        ? Colors.white 
                        : Colors.black87,
                    fontWeight: FontWeight.w600,
                  ),
                ),
              ),
            ),
          ),
          Expanded(
            child: GestureDetector(
              onTap: () => setState(() => _selectedPlatform = 'google'),
              child: Container(
                padding: const EdgeInsets.symmetric(vertical: 12),
                decoration: BoxDecoration(
                  color: _selectedPlatform == 'google' 
                      ? Theme.of(context).primaryColor 
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(6),
                ),
                child: Text(
                  'Google Classroom',
                  textAlign: TextAlign.center,
                  style: TextStyle(
                    color: _selectedPlatform == 'google' 
                        ? Colors.white 
                        : Colors.black87,
                    fontWeight: FontWeight.w600,
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildMoodleLoginForm() {
    return Form(
      key: _formKey,
      child: Column(
        children: [
          TextFormField(
            controller: _usernameController,
            decoration: const InputDecoration(
              labelText: 'Username',
              prefixIcon: Icon(Icons.person),
              helperText: 'Enter your Moodle username',
            ),
            validator: (value) {
              if (value == null || value.isEmpty) {
                return 'Please enter your username';
              }
              return null;
            },
          ),
          const SizedBox(height: 16),
          TextFormField(
            controller: _passwordController,
            obscureText: _obscurePassword,
            decoration: InputDecoration(
              labelText: 'Password',
              prefixIcon: const Icon(Icons.lock),
              helperText: 'Enter your Moodle password',
              suffixIcon: IconButton(
                icon: Icon(
                  _obscurePassword ? Icons.visibility : Icons.visibility_off,
                ),
                onPressed: () {
                  setState(() {
                    _obscurePassword = !_obscurePassword;
                  });
                },
              ),
            ),
            validator: (value) {
              if (value == null || value.isEmpty) {
                return 'Please enter your password';
              }
              return null;
            },
          ),
          const SizedBox(height: 24),
          Consumer<AuthProvider>(
            builder: (context, authProvider, child) {
              return SizedBox(
                width: double.infinity,
                child: ElevatedButton(
                  onPressed: authProvider.isLoading ? null : _handleMoodleLogin,
                  child: authProvider.isLoading
                      ? const CircularProgressIndicator(color: Colors.white)
                      : const Text('Sign In to Moodle'),
                ),
              );
            },
          ),
          const SizedBox(height: 16),
          Text(
            'Use your Moodle credentials:\n• admin / UMGC2025teamc!\n• teacher0 / Teacher0pass!\n• teacher1 / Teacher1pass!',
            style: Theme.of(context).textTheme.bodySmall?.copyWith(
              color: Colors.grey[600],
            ),
            textAlign: TextAlign.center,
          ),
        ],
      ),
    );
  }

  Widget _buildGoogleLoginButton() {
    return Consumer<AuthProvider>(
      builder: (context, authProvider, child) {
        return Column(
          children: [
            SizedBox(
              width: double.infinity,
              child: ElevatedButton.icon(
                onPressed: authProvider.isLoading ? null : _handleGoogleLogin,
                icon: authProvider.isLoading
                    ? const SizedBox(
                        width: 16,
                        height: 16,
                        child: CircularProgressIndicator(
                          color: Colors.white,
                          strokeWidth: 2,
                        ),
                      )
                    : const Icon(Icons.account_circle),
                label: const Text('Sign in with Google'),
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.blue,
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 16),
                ),
              ),
            ),
            const SizedBox(height: 16),
            Text(
              GoogleAuthService.clientId == 'test-client-id' 
                  ? 'Google OAuth not configured.\nPlease set up credentials in Google Cloud Console.'
                  : 'Sign in with your Google account to access Google Classroom',
              style: Theme.of(context).textTheme.bodySmall?.copyWith(
                color: GoogleAuthService.clientId == 'test-client-id' 
                    ? Colors.orange[700] 
                    : Colors.grey[600],
              ),
              textAlign: TextAlign.center,
            ),
          ],
        );
      },
    );
  }

  Future<void> _handleMoodleLogin() async {
    if (_formKey.currentState!.validate()) {
      final authProvider = Provider.of<AuthProvider>(context, listen: false);
      
      final success = await authProvider.loginMoodle(
        _usernameController.text,
        _passwordController.text,
      );

      if (success) {
        if (mounted) {
          Navigator.of(context).pushReplacementNamed('/dashboard');
        }
      } else {
        if (mounted) {
          _showErrorMessage('Login failed. Please check your credentials and try again.');
        }
      }
    }
  }

  Future<void> _handleGoogleLogin() async {
    try {
      if (GoogleAuthService.clientId == 'test-client-id') {
        _showErrorMessage(
          'Google OAuth not configured. Please set up Google OAuth credentials in the Google Cloud Console and update the client ID in both frontend and backend.'
        );
        return;
      }
      
      GoogleAuthService.initiateGoogleLogin();
    } catch (e) {
      _showErrorMessage('Failed to initiate Google login: $e');
    }
  }

  void _showErrorMessage(String message) {
    if (!mounted) return;
    
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.red,
        behavior: SnackBarBehavior.floating,
        action: SnackBarAction(
          label: 'Dismiss',
          textColor: Colors.white,
          onPressed: () {
            ScaffoldMessenger.of(context).hideCurrentSnackBar();
          },
        ),
      ),
    );
  }

  @override
  void dispose() {
    _usernameController.dispose();
    _passwordController.dispose();
    super.dispose();
  }
}
