  bool get isAuthenticated => _isAuthenticated;
  String? get platform => _platform;
  String? get token => _token;
  Map<String, dynamic>? get userInfo => _userInfo;
  bool get isLoading => _isLoading;
  GoogleClassroomService? get classroomService => _classroomService;

  AuthProvider() {
    _loadAuthState();
  }

  Future<void> _loadAuthState() async {
    final prefs = await SharedPreferences.getInstance();
    _token = prefs.getString('auth_token');
    _platform = prefs.getString('auth_platform');
    
    if (_token != null) {
      ApiService.setAuthToken(_token!);
      
      if (_platform?.toLowerCase() == 'google' || _platform?.toLowerCase() == 'google_classroom') {
        _initializeGoogleClassroomService();
      }
      
      try {
        final status = await ApiService.getAuthStatus();
        _isAuthenticated = status['authenticated'] ?? false;
        if (!_isAuthenticated) {
          await logout();
        }
      } catch (e) {
        await logout();
      }
    }
    notifyListeners();
  }

  void _initializeGoogleClassroomService() {
    if (_token != null) {
      _classroomService = GoogleClassroomService(_token!);
      notifyListeners();
    }
  }

  Future<bool> loginMoodle(String username, String password) async {
    _isLoading = true;
    notifyListeners();

    try {
      final response = await ApiService.loginMoodle(username, password);
      
      if (response['success'] == true) {
        _token = response['token'];
        _platform = 'moodle';
        _isAuthenticated = true;
        _userInfo = {'username': response['username']};
        
        await _saveAuthState();
        ApiService.setAuthToken(_token!);
        _classroomService = null;
        
        _isLoading = false;
        notifyListeners();
        return true;
      } else {
        _isLoading = false;
        notifyListeners();
        return false;
      }
    } catch (e) {
      _isLoading = false;
      notifyListeners();
      return false;
    }
  }

  Future<bool> loginGoogle(String authCode) async {
    _isLoading = true;
    notifyListeners();

    try {
      final response = await ApiService.googleCallback(authCode);
      
      if (response['success'] == true) {
        _token = response['token'];
        _platform = 'google';
        _isAuthenticated = true;
        _userInfo = response['userInfo'];
        
        await _saveAuthState();
        ApiService.setAuthToken(_token!);
        _initializeGoogleClassroomService();
        
        _isLoading = false;
        notifyListeners();
        return true;
      } else {
        _isLoading = false;
        notifyListeners();
        return false;
      }
    } catch (e) {
      _isLoading = false;
      notifyListeners();
      return false;
    }
  }

  Future<bool> loginGoogleWithToken(String accessToken, Map<String, dynamic> userInfo) async {
    _isLoading = true;
    notifyListeners();

    try {
      _token = accessToken;
      _platform = 'google';
      _isAuthenticated = true;
      _userInfo = userInfo;
      
      await _saveAuthState();
      ApiService.setAuthToken(_token!);
      _initializeGoogleClassroomService();
      
      _isLoading = false;
      notifyListeners();
      return true;
    } catch (e) {
      _isLoading = false;
      notifyListeners();
      return false;
    }
  }

  Future<Map<String, dynamic>> testGoogleClassroomConnection() async {
    if (_classroomService == null) {
      return {
        'success': false,
        'error': 'Google Classroom service not initialized',
        'details': 'User not logged in with Google account or service not properly initialized'
      };
    }

    try {
      final courses = await _classroomService!.getCourses();
      
      return {
        'success': true,
        'message': 'Google Classroom connection successful',
        'coursesFound': courses.length,
        'details': 'Successfully connected to Google Classroom API'
      };
    } catch (e) {
      return {
        'success': false,
        'error': 'Connection test failed',
        'details': e.toString()
      };
    }
  }

  GoogleClassroomService? getClassroomService() {
    return _classroomService;
  }

  Future<List<Map<String, dynamic>>> getGoogleClassroomCourses() async {
    if (_classroomService == null) {
      throw Exception('Google Classroom service not initialized');
    }

    try {
      final courses = await _classroomService!.getCourses();
      return courses.map((course) => course.toJson()).toList();
    } catch (e) {
      rethrow;
    }
  }

  Future<bool> submitGradeToGoogleClassroom({
    required String courseId,
    required String assignmentId,
    required String submissionId,
    required String studentId,
    required double grade,
    String feedback = '',
  }) async {
    if (_classroomService == null) {
      throw Exception('Google Classroom service not initialized');
    }

    try {
      return await _classroomService!.submitGradeToClassroom(
        courseId: courseId,
        assignmentId: assignmentId,
        submissionId: submissionId,
        studentId: studentId,
        grade: grade,
        feedback: feedback,
      );
    } catch (e) {
      rethrow;
    }
  }

  Future<void> debugGoogleClassroomGrading({
    required String courseId,
    required String assignmentId,
    String? submissionId,
  }) async {
    if (_classroomService == null) {
      return;
    }

    await _classroomService!.debugAssignmentGradingIssues(
      courseId: courseId,
      assignmentId: assignmentId,
      submissionId: submissionId,
    );
  }

  Future<Map<String, dynamic>> testAssignmentGradingCapability({
    required String courseId,
    required String assignmentId,
  }) async {
    if (_classroomService == null) {
      return {
        'canGrade': false,
        'error': 'Google Classroom service not initialized',
        'details': 'User not logged in with Google account'
      };
    }

    return await _classroomService!.testAssignmentGradingCapability(
      courseId: courseId,
      assignmentId: assignmentId,
    );
  }

  Future<Map<String, dynamic>> getDetailedAuthStatus() async {
    final basicStatus = {
      'authenticated': _isAuthenticated,
      'platform': _platform,
      'hasToken': _token != null,
      'tokenLength': _token?.length ?? 0,
      'userInfo': _userInfo,
    };

    if (_platform?.toLowerCase() == 'google' && _classroomService != null) {
      try {
        final classroomTest = await testGoogleClassroomConnection();
        basicStatus['googleClassroom'] = {
          'serviceInitialized': true,
          'connectionTest': classroomTest,
        };
      } catch (e) {
        basicStatus['googleClassroom'] = {
          'serviceInitialized': true,
          'connectionTest': {
            'success': false,
            'error': e.toString(),
          },
        };
      }
    } else {
      basicStatus['googleClassroom'] = {
        'serviceInitialized': false,
        'reason': _platform?.toLowerCase() != 'google' 
            ? 'Not logged in with Google' 
            : 'Service not initialized',
      };
    }

    return basicStatus;
  }

  Future<void> logout() async {
    try {
      if (_token != null) {
        await ApiService.logout();
      }
    } catch (e) {
      // Ignore logout API errors
    }
    
    _isAuthenticated = false;
    _platform = null;
    _token = null;
    _userInfo = null;
    _classroomService = null;
    
    await _clearAuthState();
    ApiService.clearAuthToken();
    notifyListeners();
  }

  Future<void> _saveAuthState() async {
    final prefs = await SharedPreferences.getInstance();
    if (_token != null) {
      await prefs.setString('auth_token', _token!);
    }
    if (_platform != null) {
      await prefs.setString('auth_platform', _platform!);
    }
  }

  Future<void> _clearAuthState() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.remove('auth_token');
    await prefs.remove('auth_platform');
  }

  bool get canAccessGoogleClassroom {
    return _isAuthenticated && 
           (_platform?.toLowerCase() == 'google' || _platform?.toLowerCase() == 'google_classroom') && 
           _classroomService != null;
  }

  String get platformDisplayName {
    switch (_platform?.toLowerCase()) {
      case 'google':
      case 'google_classroom':
        return 'Google Classroom';
      case 'moodle':
        return 'Moodle';
      default:
        return _platform ?? 'Unknown';
    }
  }

  void refreshGoogleClassroomService() {
    if (_platform?.toLowerCase() == 'google' && _token != null) {
      _initializeGoogleClassroomService();
    }
  }
}
