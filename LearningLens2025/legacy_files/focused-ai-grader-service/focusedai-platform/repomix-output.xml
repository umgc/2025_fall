  Future<Map<String, dynamic>> uploadBatchGradesToPlatform(
    List<Map<String, dynamic>> gradesData,
  ) async {
    if (_currentPlatform == null) {
      throw Exception('Platform context not set');
    }
    
    switch (_currentPlatform?.toLowerCase()) {
      case 'moodle':
        return await _uploadBatchGradesToMoodle(gradesData);
      case 'google':
      case 'google_classroom':
        return await _uploadBatchGradesToGoogleClassroom(gradesData);
      default:
        throw Exception('Unsupported platform: $_currentPlatform');
    }
  }

  Future<Map<String, dynamic>> _uploadBatchGradesToGoogleClassroom(
    List<Map<String, dynamic>> gradesData,
  ) async {
    try {
      if (_classroomService == null) {
        throw Exception('Google Classroom service not initialized');
      }

      int successCount = 0;
      List<String> errors = [];

      for (int i = 0; i < gradesData.length; i++) {
        final gradeData = gradesData[i];
        
        try {
          final result = await _uploadGradeToGoogleClassroom(
            gradeData['submissionId'],
            gradeData,
          );
          
          if (result['success'] == true) {
            successCount++;
          } else {
            errors.add('${gradeData['studentName']}: ${result['error']}');
          }
        } catch (e) {
          errors.add('${gradeData['studentName']}: $e');
        }
        
        if (i < gradesData.length - 1) {
          await Future.delayed(const Duration(milliseconds: 500));
        }
      }

      if (successCount > 0) {
        return {
          'success': true,
          'message': 'Batch grades uploaded to Google Classroom: $successCount/${gradesData.length} successful',
          'platform': 'google_classroom',
          'uploaded': successCount,
          'errors': errors,
        };
      } else {
        throw Exception('All batch uploads failed');
      }
    } catch (e) {
      return {
        'success': false,
        'error': e.toString(),
        'platform': 'google_classroom',
      };
    }
  }

  Future<Map<String, dynamic>> _uploadBatchGradesToMoodle(
    List<Map<String, dynamic>> gradesData,
  ) async {
    try {
      final response = await ApiService.uploadBatchGradesToMoodle(gradesData);
      
      if (response['success'] == true) {
