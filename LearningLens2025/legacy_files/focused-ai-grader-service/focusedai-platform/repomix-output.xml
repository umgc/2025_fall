  Widget _buildEnhancedExecutionResult(Map<String, dynamic> result) {
    final output = result['output'] ?? '';
    final expectedOutput = result['expectedOutput'] ?? '';
    final hasError = result['error'] != null && result['error'].toString().isNotEmpty;
    final success = result['success'] ?? !hasError;
    final testPassed = result['testPassed'] ?? false;
    final similarity = result['outputSimilarity'] ?? 0;
    final feedback = result['feedback'] ?? '';
    final executionTime = result['executionTimeMs'] ?? result['executionTime'] ?? 0;
    final grade = result['grade'] ?? '';
    
    return SingleChildScrollView(
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Container(
            width: double.infinity,
            padding: const EdgeInsets.all(12),
            decoration: BoxDecoration(
              color: testPassed ? Colors.green[50] : (success ? Colors.orange[50] : Colors.red[50]),
              border: Border.all(
                color: testPassed ? Colors.green[200]! : (success ? Colors.orange[200]! : Colors.red[200]!),
              ),
              borderRadius: BorderRadius.circular(8),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Icon(
                      testPassed ? Icons.check_circle : (success ? Icons.warning : Icons.error),
                      size: 20,
                      color: testPassed ? Colors.green[600] : (success ? Colors.orange[600] : Colors.red[600]),
                    ),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text(
                        testPassed ? 'Test Passed ✅' : (success ? 'Code Executed (Test Issues)' : 'Execution Failed ❌'),
                        style: TextStyle(
                          fontWeight: FontWeight.bold,
                          fontSize: 16,
                          color: testPassed ? Colors.green[700] : (success ? Colors.orange[700] : Colors.red[700]),
                        ),
                      ),
                    ),
                    if (executionTime > 0) ...[
                      Icon(Icons.timer, size: 16, color: Colors.grey[600]),
                      const SizedBox(width: 4),
                      Text(
                        '${executionTime}ms',
                        style: TextStyle(
                          fontSize: 12,
                          color: Colors.grey[600],
                          fontWeight: FontWeight.w500,
                        ),
                      ),
                    ],
                  ],
                ),
                
                if (grade.isNotEmpty || similarity > 0) ...[
                  const SizedBox(height: 8),
                  Row(
                    children: [
                      if (grade.isNotEmpty) ...[
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                          decoration: BoxDecoration(
                            color: _getGradeColor(grade),
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: Text(
                            'Grade: $grade',
                            style: const TextStyle(
                              color: Colors.white,
                              fontWeight: FontWeight.bold,
                              fontSize: 12,
                            ),
                          ),
                        ),
                        const SizedBox(width: 12),
                      ],
                      if (similarity > 0) ...[
                        Container(
                          padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                          decoration: BoxDecoration(
                            color: _getSimilarityColor(similarity.toDouble()),
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: Text(
                            'Similarity: ${similarity.toStringAsFixed(2)}%',
                            style: const TextStyle(
                              color: Colors.white,
                              fontWeight: FontWeight.bold,
                              fontSize: 12,
                            ),
                          ),
                        ),
                      ],
                    ],
                  ),
                ],
              ],
            ),
          ),
          
          const SizedBox(height: 16),
          
          if (feedback.isNotEmpty) ...[
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: Colors.blue[50],
                border: Border.all(color: Colors.blue[200]!),
                borderRadius: BorderRadius.circular(8),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
