    /**
     * Store student chat log and share with teacher
     */
    public Map<String, Object> storeChatLogWithSharing(String studentAccessToken, String courseId, 
                                                      String studentId, String prompt, String response) {
        try {
            System.out.println("🚀 Starting chat log storage for student: " + studentId);
            
            String chatContent = buildChatLogContent(courseId, studentId, prompt, response);
            String chatFileId = createOrUpdateChatFile(studentAccessToken, courseId, studentId, chatContent, prompt, response);
            
            if (chatFileId == null) {
                return Map.of("success", false, "error", "Failed to create/update chat log file");
            }
            
            System.out.println("✅ Chat file created/updated: " + chatFileId);
            
            String teacherEmail = getTeacherEmailImproved(studentAccessToken, courseId);
            System.out.println("🔍 Teacher email found: " + teacherEmail);
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("fileId", chatFileId);
            result.put("location", "Student's Google Drive");
            result.put("contentLength", chatContent.length());
            
            if (teacherEmail != null && !teacherEmail.trim().isEmpty()) {
                Map<String, Object> shareResult = shareFileWithTeacher(studentAccessToken, chatFileId, teacherEmail);
                
                if ((Boolean) shareResult.get("success")) {
                    System.out.println("✅ Chat log shared with teacher: " + teacherEmail);
                    result.put("shared", true);
                    result.put("sharedWith", teacherEmail);
                    result.put("message", "Chat logged successfully and shared with teacher");
                } else {
                    System.out.println("⚠️ Failed to share with teacher: " + shareResult.get("error"));
                    result.put("shared", false);
                    result.put("shareError", shareResult.get("error"));
                    result.put("message", "Chat logged but sharing failed");
                }
            } else {
                result.put("shared", false);
                result.put("shareError", "Could not identify teacher email");
                result.put("message", "Chat logged but could not share (teacher not found)");
            }
            
            return result;

        } catch (Exception e) {
            System.out.println("💥 Exception in chat log storage: " + e.getMessage());
            e.printStackTrace();
            return Map.of("success", false, "error", "Failed to store and share chat log: " + e.getMessage());
        }
    }

    /**
     * Get student's own chat logs
     */
    public Map<String, Object> getStudentOwnChatLogs(String studentAccessToken, String courseId, 
                                                String studentId, String assignmentId) {
        try {
            System.out.println("🔍 Student retrieving own chat logs for course: " + courseId);
            
            List<Map<String, Object>> studentChatFiles = findStudentOwnChatFiles(studentAccessToken, courseId, studentId);
            List<Map<String, Object>> chatSummaries = new ArrayList<>();
            
            for (Map<String, Object> file : studentChatFiles) {
                String fileId = (String) file.get("id");
                String fileName = (String) file.get("name");
                
                if (fileId == null || fileName == null) continue;
                
                if (assignmentId != null && !fileName.contains(assignmentId)) {
                    continue;
                }
                
                try {
                    String content = getFileContent(studentAccessToken, fileId);
                    List<Map<String, Object>> parsedEntries = parseChatLogContent(content);
                    
                    if (parsedEntries.isEmpty()) continue;
                    
                    Map<String, Object> summary = new HashMap<>();
                    summary.put("fileId", fileId);
                    summary.put("fileName", fileName);
                    summary.put("courseId", courseId);
                    summary.put("lastModified", file.get("modifiedTime"));
                    summary.put("chatCount", parsedEntries.size());
                    summary.put("recentChats", parsedEntries.size() > 3 ? 
                        parsedEntries.subList(parsedEntries.size() - 3, parsedEntries.size()) : parsedEntries);
                    summary.put("assignmentContext", extractAssignmentFromFileName(fileName));
                    
                    if (!parsedEntries.isEmpty()) {
                        summary.put("firstChatTime", parsedEntries.get(0).get("timestamp"));
                        summary.put("lastChatTime", parsedEntries.get(parsedEntries.size() - 1).get("timestamp"));
                    }
                    
                    chatSummaries.add(summary);
                    
                } catch (Exception fileEx) {
                    System.out.println("⚠️ Error processing chat file " + fileId + ": " + fileEx.getMessage());
                }
            }
            
            chatSummaries.sort((a, b) -> {
                String timeA = (String) a.get("lastModified");
                String timeB = (String) b.get("lastModified");
                if (timeA == null || timeB == null) return 0;
                return timeB.compareTo(timeA);
            });
            
            Map<String, Object> dataMap = new HashMap<>();
            dataMap.put("studentId", studentId);
            dataMap.put("courseId", courseId);
            dataMap.put("assignmentFilter", assignmentId);
            dataMap.put("chatFiles", chatSummaries);
            dataMap.put("totalFiles", chatSummaries.size());
            dataMap.put("accessType", "student_own_logs");
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", dataMap);
            
            return result;

        } catch (Exception e) {
            System.out.println("❌ Error getting student's own chat logs: " + e.getMessage());
            e.printStackTrace();
            
            Map<String, Object> errorResult = new HashMap<>();
            errorResult.put("success", false);
            errorResult.put("error", "Failed to get your chat logs: " + e.getMessage());
            return errorResult;
        }
    }

