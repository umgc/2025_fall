// Enhanced CourseTeacherMappingService.java with better persistence
package com.focusedai.caila_service.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.*;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.core.env.Environment;

import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.ConcurrentHashMap;
import java.io.*;
import java.nio.file.*;

@Service
public class CourseTeacherMappingService {
    
    private final Map<String, String> courseTeacherMapping = new ConcurrentHashMap<>();
    private final RestTemplate restTemplate;
    
    @Value("${caila.mapping.file.path:./course-teacher-mappings.properties}")
    private String mappingFilePath;
    
    @Autowired
    private Environment environment;
    
    @Autowired
    public CourseTeacherMappingService(RestTemplate restTemplate) {
        this.restTemplate = restTemplate;
    }
    
    @jakarta.annotation.PostConstruct
    public void loadMappingsFromFile() {
        try {
            File mappingFile = new File(mappingFilePath);
            if (mappingFile.exists()) {
                List<String> lines = Files.readAllLines(mappingFile.toPath());
                for (String line : lines) {
                    if (line.contains("=") && !line.startsWith("#")) {
                        String[] parts = line.split("=", 2);
                        if (parts.length == 2) {
                            String courseId = parts[0].trim();
                            String teacherEmail = parts[1].trim();
                            courseTeacherMapping.put(courseId, teacherEmail);
                            System.out.println("📂 Loaded mapping: " + courseId + " -> " + teacherEmail);
                        }
                    }
                }
                System.out.println("✅ Loaded " + courseTeacherMapping.size() + " course-teacher mappings from file");
            } else {
                System.out.println("📂 No existing mapping file found, starting fresh");
            }
        } catch (Exception e) {
            System.out.println("⚠️ Could not load mappings from file: " + e.getMessage());
        }
        
        // Also load from application.properties as fallback
        loadFromApplicationProperties();
    }
    
    private void loadFromApplicationProperties() {
        try {
            // Load any configured mappings from application.properties
            String defaultEmail = environment.getProperty("caila.default.teacher.email");
            if (defaultEmail != null && !defaultEmail.trim().isEmpty()) {
                System.out.println("📋 Default teacher email configured: " + defaultEmail);
            }
            
            // Load course-specific mappings
            // This would work with properties like: caila.course.770500699199.teacher.email=teacher@email.com
            Map<String, Object> allProperties = ((org.springframework.core.env.AbstractEnvironment) environment).getPropertySources()
                .stream()
                .filter(ps -> ps instanceof org.springframework.core.env.EnumerablePropertySource)
                .map(ps -> ((org.springframework.core.env.MapPropertySource) ps).getPropertyNames())
                .flatMap(java.util.Arrays::stream)
                .filter(propName -> propName.startsWith("caila.course.") && propName.endsWith(".teacher.email"))
                .collect(java.util.stream.Collectors.toMap(
                    propName -> propName,
                    propName -> environment.getProperty(propName)
                ));
                
            for (Map.Entry<String, Object> entry : allProperties.entrySet()) {
                String propName = entry.getKey();
                String email = (String) entry.getValue();
                
                // Extract course ID from property name
                // caila.course.770500699199.teacher.email -> 770500699199
                String courseId = propName.replace("caila.course.", "").replace(".teacher.email", "");
                
                if (email != null && !email.trim().isEmpty()) {
                    courseTeacherMapping.put(courseId, email);
                    System.out.println("📋 Loaded from config: " + courseId + " -> " + email);
                }
            }
        } catch (Exception e) {
            System.out.println("⚠️ Could not load from application properties: " + e.getMessage());
        }
    }
    
    @jakarta.annotation.PreDestroy
    public void saveMappingsToFile() {
        try {
            File mappingFile = new File(mappingFilePath);
            try (PrintWriter writer = new PrintWriter(new FileWriter(mappingFile))) {
                writer.println("# Course-Teacher Mappings");
                writer.println("# Generated automatically by CAILA");
                writer.println("# Format: courseId=teacherEmail");
                writer.println();
                
                for (Map.Entry<String, String> entry : courseTeacherMapping.entrySet()) {
                    writer.println(entry.getKey() + "=" + entry.getValue());
                }
            }
            System.out.println("💾 Saved " + courseTeacherMapping.size() + " mappings to file");
        } catch (Exception e) {
            System.out.println("⚠️ Could not save mappings to file: " + e.getMessage());
        }
    }
    
    /**
     * Register teacher email for a course when teacher authenticates
     */
    public void registerTeacherForCourse(String courseId, String teacherEmail, String teacherToken) {
        courseTeacherMapping.put(courseId, teacherEmail);
        
        // Also verify the teacher has access to this course
        if (verifyTeacherCourseAccess(teacherToken, courseId)) {
            System.out.println("✅ Registered teacher " + teacherEmail + " for course " + courseId);
            
            // Save immediately to persist the mapping
            saveMappingsToFile();
        } else {
            System.out.println("⚠️ Teacher registration failed - no course access");
        }
    }
    
    /**
     * Get teacher email for a course
     */
    public String getTeacherForCourse(String courseId) {
        String email = courseTeacherMapping.get(courseId);
        if (email != null) {
            System.out.println("✅ Found teacher mapping: " + courseId + " -> " + email);
            return email;
        }
        
        // Fallback to configuration
        String configEmail = environment.getProperty("caila.course." + courseId + ".teacher.email");
        if (configEmail != null && !configEmail.trim().isEmpty()) {
            System.out.println("✅ Found teacher in config: " + courseId + " -> " + configEmail);
            // Store it for future use
            courseTeacherMapping.put(courseId, configEmail);
            return configEmail;
        }
        
        // Fallback to default
        String defaultEmail = environment.getProperty("caila.default.teacher.email");
        if (defaultEmail != null && !defaultEmail.trim().isEmpty()) {
            System.out.println("✅ Using default teacher email: " + defaultEmail);
            return defaultEmail;
        }
        
        System.out.println("❌ No teacher found for course: " + courseId);
        return null;
    }
    
    /**
     * Verify teacher has access to course
     */
    private boolean verifyTeacherCourseAccess(String teacherToken, String courseId) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + teacherToken);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            ResponseEntity<Map> response = restTemplate.exchange(
                "https://classroom.googleapis.com/v1/courses/" + courseId,
                HttpMethod.GET, 
                entity, 
                Map.class
            );

            return response.getStatusCode() == HttpStatus.OK;
        } catch (Exception e) {
            return false;
        }
    }
    
    /**
     * Initialize teacher mappings from existing courses (call this when teacher logs in)
     */
    public void initializeTeacherMappings(String teacherToken, String teacherEmail) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + teacherToken);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            // Get all courses where this user is a teacher
            ResponseEntity<Map> coursesResponse = restTemplate.exchange(
                "https://classroom.googleapis.com/v1/courses?teacherId=me",
                HttpMethod.GET, 
                entity, 
                Map.class
            );

            if (coursesResponse.getStatusCode() == HttpStatus.OK && coursesResponse.getBody() != null) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> courses = (List<Map<String, Object>>) coursesResponse.getBody().get("courses");
                
                if (courses != null) {
                    for (Map<String, Object> course : courses) {
                        String courseId = (String) course.get("id");
                        registerTeacherForCourse(courseId, teacherEmail, teacherToken);
                    }
                }
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error initializing teacher mappings: " + e.getMessage());
        }
    }
    
    /**
     * Debug method to show all current mappings
     */
    public Map<String, String> getAllMappings() {
        return new HashMap<>(courseTeacherMapping);
    }
    
    /**
     * Manual method to add a mapping (for testing/debugging)
     */
    public void addMapping(String courseId, String teacherEmail) {
        courseTeacherMapping.put(courseId, teacherEmail);
        saveMappingsToFile();
        System.out.println("🔧 Manually added mapping: " + courseId + " -> " + teacherEmail);
    }
}
