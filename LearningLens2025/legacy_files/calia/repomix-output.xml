    // Google Authentication - Exchange code for tokens
    public Map<String, Object> authenticateGoogle(String authCode) {
        try {
            String tokenUrl = "https://oauth2.googleapis.com/token";
            
            // Create Spring Framework HttpHeaders
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            MultiValueMap<String, String> formData = new LinkedMultiValueMap<>();
            formData.add("code", authCode);
            formData.add("client_id", googleClientId);
            formData.add("client_secret", googleClientSecret);
            formData.add("redirect_uri", googleRedirectUri);
            formData.add("grant_type", "authorization_code");

            HttpEntity<MultiValueMap<String, String>> entity = new HttpEntity<>(formData, headers);
            
            ResponseEntity<Map> responseEntity = restTemplate.postForEntity(tokenUrl, entity, Map.class);
            Map<String, Object> response = responseEntity.getBody();
            
            if (response != null && response.containsKey("access_token")) {
                String accessToken = (String) response.get("access_token");
                String refreshToken = (String) response.get("refresh_token");
                Integer expiresIn = (Integer) response.get("expires_in");
                
                Map<String, Object> userInfo = getUserInfoFromGoogle(accessToken);
                
                if (userInfo != null) {
                    Map<String, Object> tokenInfo = new HashMap<>();
                    tokenInfo.put("token", accessToken);
                    tokenInfo.put("refreshToken", refreshToken);
                    tokenInfo.put("platform", "google");
                    tokenInfo.put("userInfo", userInfo);
                    tokenInfo.put("timestamp", System.currentTimeMillis());
                    tokenInfo.put("expiresIn", expiresIn);
                    
                    tokenStore.put(accessToken, tokenInfo);
                    
                    // NEW: Initialize teacher mappings if this user is a teacher
                    String userEmail = (String) userInfo.get("email");
                    if (userEmail != null) {
                        System.out.println("🔧 Initializing teacher mappings for: " + userEmail);
                        courseTeacherMappingService.initializeTeacherMappings(accessToken, userEmail);
                    }
                    
                    return Map.of(
                        "success", true,
                        "token", accessToken,
                        "refreshToken", refreshToken,
                        "platform", "google",
                        "userInfo", userInfo,
                        "expiresIn", expiresIn != null ? expiresIn : 3600
                    );
                }
            }
            
            return Map.of("success", false, "error", "Failed to exchange authorization code");
            
        } catch (Exception e) {
            return Map.of("success", false, "error", "Google authentication failed: " + e.getMessage());
        }
    }

    // Refresh Google token
    public Map<String, Object> refreshGoogleToken(String refreshToken) {
        try {
            String tokenUrl = "https://oauth2.googleapis.com/token";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            MultiValueMap<String, String> formData = new LinkedMultiValueMap<>();
            formData.add("refresh_token", refreshToken);
            formData.add("client_id", googleClientId);
            formData.add("client_secret", googleClientSecret);
            formData.add("grant_type", "refresh_token");

            HttpEntity<MultiValueMap<String, String>> entity = new HttpEntity<>(formData, headers);
            
            ResponseEntity<Map> responseEntity = restTemplate.postForEntity(tokenUrl, entity, Map.class);
            Map<String, Object> response = responseEntity.getBody();
            
            if (response != null && response.containsKey("access_token")) {
                String newAccessToken = (String) response.get("access_token");
                
                Map<String, Object> existingTokenInfo = findTokenInfoByRefreshToken(refreshToken);
                if (existingTokenInfo != null) {
                    existingTokenInfo.put("token", newAccessToken);
                    existingTokenInfo.put("timestamp", System.currentTimeMillis());
                    existingTokenInfo.put("expiresIn", response.get("expires_in"));
                    
                    tokenStore.put(newAccessToken, existingTokenInfo);
                }
                
                return Map.of(
                    "success", true,
                    "token", newAccessToken,
                    "expiresIn", response.get("expires_in")
                );
            }
            
            return Map.of("success", false, "error", "Failed to refresh token");
            
        } catch (Exception e) {
            return Map.of("success", false, "error", "Token refresh failed: " + e.getMessage());
        }
    }

    private Map<String, Object> validateMoodleToken(String token) {
    try {
        String validationUrl = moodleBaseUrl + "/webservice/rest/server.php"
                + "?wstoken=" + token
                + "&wsfunction=core_webservice_get_site_info"
                + "&moodlewsrestformat=json";

        // Use ResponseEntity and manual JSON parsing here too
        ResponseEntity<String> responseEntity = restTemplate.getForEntity(validationUrl, String.class);
        
        if (responseEntity.getStatusCode() == HttpStatus.OK) {
            String responseBody = responseEntity.getBody();
            
            try {
                ObjectMapper objectMapper = new ObjectMapper();
                @SuppressWarnings("unchecked")
                Map<String, Object> siteInfo = objectMapper.readValue(responseBody, Map.class);
                
                if (siteInfo != null && siteInfo.containsKey("userid")) {
                    Map<String, Object> userInfo = new HashMap<>();
                    userInfo.put("userId", siteInfo.get("userid"));
                    userInfo.put("username", siteInfo.get("username"));
                    userInfo.put("fullname", siteInfo.get("fullname"));
                    userInfo.put("email", siteInfo.get("email"));
                    
                    return Map.of("valid", true, "userInfo", userInfo);
                } else if (siteInfo != null && siteInfo.containsKey("exception")) {
                    // Handle Moodle exception response
                    String errorMessage = (String) siteInfo.get("message");
                    return Map.of("valid", false, "error", "Moodle validation error: " + errorMessage);
                }
            } catch (Exception jsonEx) {
                System.out.println("🔧 Token validation JSON parsing failed, response: " + responseBody);
                return Map.of("valid", false, "error", "Invalid validation response format");
            }
        }
        
        return Map.of("valid", false, "error", "Token validation request failed");
        
    } catch (Exception e) {
        System.out.println("🔧 Token validation exception: " + e.getMessage());
        e.printStackTrace();
        return Map.of("valid", false, "error", "Token validation failed: " + e.getMessage());
    }
}

    private Map<String, Object> getUserInfoFromGoogle(String accessToken) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + accessToken);
            HttpEntity<String> entity = new HttpEntity<>(headers);
            
            ResponseEntity<Map> response = restTemplate.exchange(
                "https://www.googleapis.com/oauth2/v2/userinfo",
                HttpMethod.GET, entity, Map.class
            );
            
            return response.getBody();
            
        } catch (Exception e) {
            return null;
        }
    }

    private String generateState() {
        return java.util.UUID.randomUUID().toString();
    }

    private Map<String, Object> findTokenInfoByRefreshToken(String refreshToken) {
        return tokenStore.values().stream()
                .filter(tokenInfo -> refreshToken.equals(tokenInfo.get("refreshToken")))
                .findFirst()
                .orElse(null);
    }

    public Map<String, Object> getTokenInfo(String token) {
    Map<String, Object> tokenInfo = tokenStore.get(token);
    
    if (tokenInfo == null) {
        // Return null if token doesn't exist
        return null;
    }
    
    // Create a copy of the token info and ensure it has a "valid" field
    Map<String, Object> enrichedTokenInfo = new HashMap<>(tokenInfo);
    
    // Add "valid" field if it doesn't exist (assume valid if token exists in store)
    if (!enrichedTokenInfo.containsKey("valid")) {
        enrichedTokenInfo.put("valid", true);
    }
    
    // Optionally check if token is expired for Google tokens
    String platform = (String) enrichedTokenInfo.get("platform");
    if ("google".equals(platform)) {
        // Check if Google token needs refresh
        Long timestamp = (Long) enrichedTokenInfo.get("timestamp");
        Integer expiresIn = (Integer) enrichedTokenInfo.get("expiresIn");
        
        if (timestamp != null && expiresIn != null) {
            long currentTime = System.currentTimeMillis();
            long tokenAge = currentTime - timestamp;
            long expirationTime = expiresIn * 1000L; // Convert to milliseconds
            
            if (tokenAge > expirationTime) {
                // Token is expired
                enrichedTokenInfo.put("valid", false);
                enrichedTokenInfo.put("expired", true);
            }
        }
    }
    
    return enrichedTokenInfo;
}
    
    public Map<String, Object> getAuthStatus(String token) {
        if (token == null) {
            return Map.of("authenticated", false);
        }
        
        Map<String, Object> tokenInfo = tokenStore.get(token);
        if (tokenInfo == null) {
            return Map.of("authenticated", false);
        }
        
        return Map.of(
            "authenticated", true,
            "platform", tokenInfo.get("platform"),
            "userInfo", tokenInfo.get("userInfo")
        );
    }
    
    public void logout(String token) {
        tokenStore.remove(token);
    }

    public boolean isGoogleTokenValid(String token) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + token);
            HttpEntity<String> entity = new HttpEntity<>(headers);
            
            ResponseEntity<Map> response = restTemplate.exchange(
                "https://www.googleapis.com/oauth2/v1/tokeninfo?access_token=" + token,
                HttpMethod.GET, entity, Map.class
            );
            
            return response.getStatusCode() == HttpStatus.OK;
            
        } catch (Exception e) {
            return false;
        }
    }
}
