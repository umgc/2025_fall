    /**
     * Get specific student's chat logs for teacher
     */
    public Map<String, Object> getStudentChatLogs(String token, String courseId, String studentId, Object assignmentId) {
        try {
            System.out.println("🔍 Teacher requesting specific student chat logs");
            System.out.println("🔍 Student ID: " + studentId + ", Course ID: " + courseId);
            
            List<Map<String, Object>> studentChatFiles = findStudentChatFilesForTeacher(token, courseId, studentId);
            
            if (studentChatFiles.isEmpty()) {
                Map<String, Object> emptyData = new HashMap<>();
                emptyData.put("studentId", studentId);
                emptyData.put("courseId", courseId);
                emptyData.put("entries", new ArrayList<>());
                emptyData.put("totalEntries", 0);
                emptyData.put("platform", "google");
                emptyData.put("fullContent", "");
                emptyData.put("fileCount", 0);
                
                return Map.of("success", true, "data", emptyData, "message", "No chat logs found for this student");
            }
            
            List<Map<String, Object>> allChatEntries = new ArrayList<>();
            String lastUpdated = null;
            StringBuilder fullContent = new StringBuilder();
            
            for (Map<String, Object> file : studentChatFiles) {
                String fileId = (String) file.get("id");
                String fileName = (String) file.get("name");
                String modifiedTime = (String) file.get("modifiedTime");
                
                try {
                    String content = getFileContent(token, fileId);
                    if (content != null && !content.trim().isEmpty()) {
                        List<Map<String, Object>> fileEntries = parseChatLogContent(content);
                        allChatEntries.addAll(fileEntries);
                        
                        if (fullContent.length() > 0) {
                            fullContent.append("\n\n=== FILE: ").append(fileName).append(" ===\n\n");
                        }
                        fullContent.append(content);
                        
                        if (modifiedTime != null) {
                            if (lastUpdated == null || modifiedTime.compareTo(lastUpdated) > 0) {
                                lastUpdated = modifiedTime;
                            }
                        }
                    }
                } catch (Exception fileError) {
                    System.out.println("❌ Error reading file " + fileName + ": " + fileError.getMessage());
                }
            }
            
            allChatEntries.sort((a, b) -> {
                String timeA = (String) a.get("timestamp");
                String timeB = (String) b.get("timestamp");
                if (timeA == null && timeB == null) return 0;
                if (timeA == null) return 1;
                if (timeB == null) return -1;
                return timeB.compareTo(timeA);
            });
            
            if (assignmentId != null && !assignmentId.toString().trim().isEmpty()) {
                String assignmentFilter = assignmentId.toString();
                allChatEntries = allChatEntries.stream()
                    .filter(entry -> {
                        String studentMsg = (String) entry.get("student");
                        String cailaMsg = (String) entry.get("caila");
                        return (studentMsg != null && studentMsg.contains(assignmentFilter)) ||
                               (cailaMsg != null && cailaMsg.contains(assignmentFilter));
                    })
                    .collect(ArrayList::new, (list, entry) -> list.add(entry), ArrayList::addAll);
            }
            
            Map<String, Object> data = new HashMap<>();
            data.put("studentId", studentId);
            data.put("courseId", courseId);
            data.put("entries", allChatEntries);
            data.put("totalEntries", allChatEntries.size());
            data.put("lastUpdated", lastUpdated);
            data.put("platform", "google");
            data.put("fullContent", fullContent.toString());
            data.put("fileCount", studentChatFiles.size());
            data.put("assignmentFilter", assignmentId);
            
            return Map.of("success", true, "data", data);
            
        } catch (Exception e) {
            System.out.println("❌ Error getting student chat logs: " + e.getMessage());
            e.printStackTrace();
            return Map.of("success", false, "error", "Failed to retrieve student chat logs: " + e.getMessage());
        }
    }

