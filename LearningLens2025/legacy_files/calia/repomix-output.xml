package com.focusedai.caila_service.service;

import com.focusedai.caila_service.model.Course;
import com.focusedai.caila_service.model.Assignment;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.*;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import java.time.Instant;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.*;

@Service
public class CourseService {
    
    @Autowired
    private AuthService authService;
    
    private final RestTemplate restTemplate = new RestTemplate();
    
    @Value("${lms.moodle.base-url:http://18.188.18.80/moodle}")
    private String moodleBaseUrl;

    public List<Course> getAllCourses(String token, String platform) {
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        if (tokenInfo == null) {
            throw new RuntimeException("Invalid token");
        }

        String tokenPlatform = (String) tokenInfo.get("platform");
        if (platform != null && !platform.equals(tokenPlatform)) {
            throw new RuntimeException("Platform mismatch");
        }

        if ("moodle".equals(tokenPlatform)) {
            return getMoodleCourses(token);
        } else if ("google".equals(tokenPlatform)) {
            return getGoogleClassroomCourses(token);
        }

        return new ArrayList<>();
    }

    // Moodle Course Implementation
    private List<Course> getMoodleCourses(String token) {
        try {
            // Get user info first
            String userInfoUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_webservice_get_site_info"
                    + "&moodlewsrestformat=json";

            @SuppressWarnings("unchecked")
            Map<String, Object> siteInfo = restTemplate.getForObject(userInfoUrl, Map.class);
            
            if (siteInfo == null || siteInfo.containsKey("exception")) {
                throw new RuntimeException("Failed to get user info from Moodle");
            }
            
            String userId = String.valueOf(siteInfo.get("userid"));
            
            // Get courses for user
            String coursesUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_enrol_get_users_courses"
                    + "&userid=" + userId
                    + "&moodlewsrestformat=json";

            @SuppressWarnings("unchecked")
            List<Map<String, Object>> moodleCourses = restTemplate.getForObject(coursesUrl, List.class);
            
            List<Course> courses = new ArrayList<>();
            if (moodleCourses != null) {
                for (Map<String, Object> moodleCourse : moodleCourses) {
                    Course course = new Course();
                    course.setId(String.valueOf(moodleCourse.get("id")));
                    course.setName((String) moodleCourse.get("fullname"));
                    course.setDescription((String) moodleCourse.get("summary"));
                    course.setPlatform("moodle");
                    
                    courses.add(course);
                }
            }
            
            return courses;
            
        } catch (Exception e) {
            throw new RuntimeException("Failed to fetch Moodle courses: " + e.getMessage());
        }
    }

    // Google Classroom Course Implementation
    private List<Course> getGoogleClassroomCourses(String token) {
        try {
            String coursesUrl = "https://classroom.googleapis.com/v1/courses?courseStates=ACTIVE";
            
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + token);
            HttpEntity<String> entity = new HttpEntity<>(headers);
            
            ResponseEntity<Map> coursesResponse = restTemplate.exchange(
                coursesUrl, HttpMethod.GET, entity, Map.class
            );
            
            List<Course> courses = new ArrayList<>();
            Map<String, Object> response = coursesResponse.getBody();
            
            if (response != null && response.containsKey("courses")) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> googleCourses = (List<Map<String, Object>>) response.get("courses");
                
                for (Map<String, Object> googleCourse : googleCourses) {
                    Course course = new Course();
                    course.setId((String) googleCourse.get("id"));
                    course.setName((String) googleCourse.get("name"));
                    course.setDescription((String) googleCourse.get("description"));
                    course.setPlatform("google");
                    
                    courses.add(course);
                }
            }
            
            return courses;
            
        } catch (Exception e) {
            throw new RuntimeException("Failed to fetch Google Classroom courses: " + e.getMessage());
        }
    }
    
    public Course getCourse(String token, String courseId) {
        List<Course> courses = getAllCourses(token, null);
        return courses.stream()
                .filter(course -> course.getId().equals(courseId))
                .findFirst()
                .orElseThrow(() -> new RuntimeException("Course not found"));
    }
}
