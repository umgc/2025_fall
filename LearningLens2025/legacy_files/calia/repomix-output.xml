    // Fallback method
    private Map<String, Object> getMoodleAssignmentsOnly(String token, String courseId) {
        try {
            System.out.println("🔧 Fallback: Using assignments-only approach");
            
            String url = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=mod_assign_get_assignments"
                    + "&courseids[0]=" + courseId
                    + "&moodlewsrestformat=json";

            @SuppressWarnings("unchecked")
            Map<String, Object> response = restTemplate.getForObject(url, Map.class);
            
            List<Map<String, Object>> assignments = new ArrayList<>();

            if (response != null && response.containsKey("courses")) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> courses = (List<Map<String, Object>>) response.get("courses");

                for (Map<String, Object> course : courses) {
                    if (course.containsKey("assignments")) {
                        @SuppressWarnings("unchecked")
                        List<Map<String, Object>> moodleAssignments = (List<Map<String, Object>>) course.get("assignments");

                        for (Map<String, Object> assign : moodleAssignments) {
                            Map<String, Object> assignment = new HashMap<>();
                            assignment.put("id", String.valueOf(assign.get("id")));
                            assignment.put("name", assign.get("name"));
                            
                            // Enhanced description for assignments
                            String intro = (String) assign.get("intro");
                            if (intro != null && !intro.trim().isEmpty()) {
                                assignment.put("description", cleanHtmlDescription(intro));
                            } else {
                                assignment.put("description", "Assignment instructions not available. Please check the original course.");
                            }
                            
                            assignment.put("maxScore", assign.get("grade"));
                            assignment.put("platform", "moodle");
                            assignment.put("courseId", courseId);
                            assignment.put("status", "assigned");
                            assignment.put("activityType", "assign");
                            assignment.put("type", "Assignment");

                            // Handle due date
                            if (assign.containsKey("duedate") && assign.get("duedate") != null) {
                                Object dueDateObj = assign.get("duedate");
                                if (dueDateObj instanceof Number) {
                                    Long dueTimestamp = ((Number) dueDateObj).longValue();
                                    if (dueTimestamp > 0) {
                                        LocalDateTime dueDate = LocalDateTime.ofEpochSecond(dueTimestamp, 0, java.time.ZoneOffset.UTC);
                                        assignment.put("dueDate", dueDate.format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));
                                    }
                                }
                            }

                            assignments.add(assignment);
                        }
                    }
                }
            }

            return Map.of(
                "success", true,
                "data", assignments,
                "count", assignments.size(),
                "platform", "moodle",
                "note", "Assignments only (fallback mode)"
            );

        } catch (Exception e) {
            System.out.println("🔧 Fallback method also failed: " + e.getMessage());
            return Map.of("success", false, "error", "Both methods failed: " + e.getMessage());
        }
    }

    // Rest of the existing methods (getAssignmentDetails, submitAssignment, etc.) remain unchanged...
    public Map<String, Object> getAssignmentDetails(String token, String courseId, String assignmentId) {
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        if (tokenInfo == null) {
            return Map.of("success", false, "error", "Invalid token");
        }

        String platform = (String) tokenInfo.get("platform");

        if ("google".equals(platform)) {
            return getGoogleAssignmentDetails(token, courseId, assignmentId);
        } else if ("moodle".equals(platform)) {
            return getMoodleAssignmentDetails(token, courseId, assignmentId);
        }

        return Map.of("success", false, "error", "Unsupported platform");
    }

    private Map<String, Object> getGoogleAssignmentDetails(String token, String courseId, String assignmentId) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + token);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            ResponseEntity<Map> response = restTemplate.exchange(
                "https://classroom.googleapis.com/v1/courses/" + courseId + "/courseWork/" + assignmentId,
                HttpMethod.GET, entity, Map.class
            );

            if (response.getStatusCode() == HttpStatus.OK) {
                Map<String, Object> assignment = response.getBody();
                
                Map<String, Object> formattedAssignment = new HashMap<>();
                formattedAssignment.put("id", assignment.get("id"));
                formattedAssignment.put("name", assignment.get("title"));
                formattedAssignment.put("description", assignment.get("description"));
                formattedAssignment.put("maxScore", assignment.get("maxPoints"));
                formattedAssignment.put("platform", "google");
                formattedAssignment.put("courseId", courseId);

                return Map.of(
                    "success", true,
                    "data", formattedAssignment
                );
            }

            return Map.of("success", false, "error", "Assignment not found");

        } catch (Exception e) {
            return Map.of("success", false, "error", "Google Classroom error: " + e.getMessage());
        }
    }

    private Map<String, Object> getMoodleAssignmentDetails(String token, String courseId, String assignmentId) {
        try {
            String url = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=mod_assign_get_assignments"
                    + "&assignmentids[0]=" + assignmentId
                    + "&moodlewsrestformat=json";

            @SuppressWarnings("unchecked")
            Map<String, Object> response = restTemplate.getForObject(url, Map.class);

            if (response != null && response.containsKey("assignments")) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> assignments = (List<Map<String, Object>>) response.get("assignments");

                if (!assignments.isEmpty()) {
                    Map<String, Object> assignment = assignments.get(0);
                    
                    Map<String, Object> formattedAssignment = new HashMap<>();
                    formattedAssignment.put("id", assignment.get("id"));
                    formattedAssignment.put("name", assignment.get("name"));
                    
                    // Enhanced description
                    String intro = (String) assignment.get("intro");
                    if (intro != null && !intro.trim().isEmpty()) {
                        formattedAssignment.put("description", cleanHtmlDescription(intro));
                    } else {
                        formattedAssignment.put("description", "Assignment details not available.");
                    }
                    
                    formattedAssignment.put("maxScore", assignment.get("grade"));
                    formattedAssignment.put("platform", "moodle");
                    formattedAssignment.put("courseId", courseId);

                    return Map.of(
                        "success", true,
                        "data", formattedAssignment
                    );
                }
            }

            return Map.of("success", false, "error", "Assignment not found");

        } catch (Exception e) {
            return Map.of("success", false, "error", "Moodle error: " + e.getMessage());
        }
    }

    public Map<String, Object> submitAssignment(String token, String courseId, String assignmentId, Map<String, Object> submission) {
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        if (tokenInfo == null) {
            return Map.of("success", false, "error", "Invalid token");
        }

        return Map.of(
            "success", true,
            "message", "Assignment submitted successfully",
            "submissionId", "sub_" + System.currentTimeMillis(),
            "submittedAt", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME),
            "platform", tokenInfo.get("platform")
        );
    }

    private String formatGoogleDate(Map<String, Object> dateMap) {
        try {
            Integer year = (Integer) dateMap.get("year");
            Integer month = (Integer) dateMap.get("month");
            Integer day = (Integer) dateMap.get("day");

            if (year != null && month != null && day != null) {
                LocalDateTime dueDate = LocalDateTime.of(year, month, day, 23, 59, 59);
                return dueDate.format(DateTimeFormatter.ISO_LOCAL_DATE_TIME);
            }
        } catch (Exception e) {
            System.out.println("Error parsing Google date: " + e.getMessage());
        }
        return null;
    }
