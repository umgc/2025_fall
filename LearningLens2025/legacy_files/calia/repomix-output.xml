     */
    private String createOrUpdateChatFile(String accessToken, String courseId, String studentId, 
                                    String content, String prompt, String response) {
    try {
        System.out.println("🔧 Creating or updating chat file for student: " + studentId);
        
        // First, try to find an existing file
        String existingFileId = findExistingChatFileSimple(accessToken, courseId, studentId);
        
        if (existingFileId != null) {
            System.out.println("🔧 Found potential existing file: " + existingFileId);
            
            // Verify the file actually exists and is accessible
            if (verifyFileExists(accessToken, existingFileId)) {
                System.out.println("🔧 File verified, attempting to append content");
                
                // Try to append to the existing file
                String updatedFileId = appendToChatFile(accessToken, existingFileId, prompt, response);
                
                if (updatedFileId != null) {
                    System.out.println("✅ Successfully updated existing file: " + updatedFileId);
