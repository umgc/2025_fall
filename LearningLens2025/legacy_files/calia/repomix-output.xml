package com.focusedai.caila_service.controller;

import com.focusedai.caila_service.service.GoogleFormsService;
import com.focusedai.caila_service.service.AuthService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.util.*;

@RestController
@RequestMapping("/api/google-forms")
@CrossOrigin(origins = "*")
public class GoogleFormsController {
    
    private static final Logger logger = LoggerFactory.getLogger(GoogleFormsController.class);

    @Autowired
    private GoogleFormsService googleFormsService;

    @Autowired
    private AuthService authService;

    @PostMapping("/create-form")
    public ResponseEntity<Map<String, Object>> createForm(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> formData) {
        
        try {
            logger.info("Creating Google Form with data: {}", formData);
            
            String token = authHeader.replace("Bearer ", "");
            
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"google".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid Google authentication token"
                ));
            }
            
            // Validate required fields
            if (!formData.containsKey("title") || formData.get("title") == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Form title is required"
                ));
            }

            Map<String, Object> result = googleFormsService.createGoogleForm(token, formData);
            
            if ((Boolean) result.get("success")) {
                return ResponseEntity.ok(result);
            } else {
                return ResponseEntity.badRequest().body(result);
            }

        } catch (Exception e) {
            logger.error("Error creating Google Form", e);
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    @PostMapping("/create-interactive-quiz")
    public ResponseEntity<Map<String, Object>> createInteractiveQuiz(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            logger.info("Creating interactive quiz with request: {}", request);
            
            // Extract token from Authorization header
            String token = authHeader.replace("Bearer ", "");
            
            // Validate token
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"google".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid or missing Google authentication token"
                ));
            }

            // Extract request data
            String courseId = (String) request.get("courseId");
            @SuppressWarnings("unchecked")
            Map<String, Object> quizData = (Map<String, Object>) request.get("quizData");

            if (courseId == null || quizData == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Missing courseId or quizData"
                ));
            }
            
            // Validate quiz data has title
            if (!quizData.containsKey("title") || quizData.get("title") == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Quiz title is required"
                ));
            }

            // Create interactive quiz
            Map<String, Object> result = googleFormsService.createInteractiveQuiz(token, courseId, quizData);
            
            if ((Boolean) result.get("success")) {
                return ResponseEntity.ok(result);
            } else {
                return ResponseEntity.badRequest().body(result);
            }

        } catch (Exception e) {
            logger.error("Error creating interactive quiz", e);
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    @PostMapping("/create-classroom-assignment")
    public ResponseEntity<Map<String, Object>> createClassroomAssignment(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            logger.info("Creating classroom assignment with request: {}", request);
            
            String token = authHeader.replace("Bearer ", "");
            
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"google".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid Google authentication token"
                ));
            }

            String courseId = (String) request.get("courseId");
            @SuppressWarnings("unchecked")
            Map<String, Object> assignmentData = (Map<String, Object>) request.get("assignmentData");

            if (courseId == null || assignmentData == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Missing courseId or assignmentData"
                ));
            }
            
            // Validate assignment data has title
            if (!assignmentData.containsKey("title") || assignmentData.get("title") == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Assignment title is required"
                ));
            }

            // Note: We need to pass the actual access token to the service method
            // The service will extract it using the AuthService internally
            Map<String, Object> result = googleFormsService.createClassroomAssignment(token, courseId, assignmentData);
            
            if ((Boolean) result.get("success")) {
                return ResponseEntity.ok(result);
            } else {
                return ResponseEntity.badRequest().body(result);
            }

        } catch (Exception e) {
            logger.error("Error creating classroom assignment", e);
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    // Health check endpoint
    @GetMapping("/health")
    public ResponseEntity<Map<String, Object>> health() {
        return ResponseEntity.ok(Map.of(
            "status", "healthy",
            "service", "GoogleFormsService",
            "timestamp", new Date()
        ));
    }
}
