@GetMapping("/{courseId}/assignments/debug-full")
public ResponseEntity<Map<String, Object>> debugFullCourseContent(
        @RequestHeader("Authorization") String authHeader,
        @PathVariable String courseId) {
    
    try {
        String token = authHeader.replace("Bearer ", "");
        
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        if (tokenInfo == null) {
            return ResponseEntity.badRequest().body(Map.of(
                "success", false,
                "error", "Invalid authentication token"
            ));
        }

        if (!"moodle".equals(tokenInfo.get("platform"))) {
            return ResponseEntity.badRequest().body(Map.of(
                "success", false,
                "error", "This debug endpoint only works with Moodle"
            ));
        }

        RestTemplate restTemplate = new RestTemplate();
        String moodleBaseUrl = "http://18.188.18.80/moodle";
        Map<String, Object> debugResults = new HashMap<>();

        // 1. Test mod_assign_get_assignments (what we're currently using)
        try {
            String assignUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=mod_assign_get_assignments"
                    + "&courseids[0]=" + courseId
                    + "&moodlewsrestformat=json";
            
            Map<String, Object> assignResponse = restTemplate.getForObject(assignUrl, Map.class);
            debugResults.put("mod_assign_get_assignments", Map.of(
                "url", assignUrl,
                "response", assignResponse
            ));
        } catch (Exception e) {
            debugResults.put("mod_assign_get_assignments", Map.of("error", e.getMessage()));
        }

        // 2. Test core_course_get_contents (alternative approach)
        try {
            String contentsUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_course_get_contents"
                    + "&courseid=" + courseId
                    + "&moodlewsrestformat=json";
            
            List<Map<String, Object>> contentsResponse = restTemplate.getForObject(contentsUrl, List.class);
            
            // Extract all activities from all sections
            List<Map<String, Object>> allActivities = new ArrayList<>();
            if (contentsResponse != null) {
                for (Map<String, Object> section : contentsResponse) {
                    if (section.containsKey("modules")) {
                        @SuppressWarnings("unchecked")
                        List<Map<String, Object>> modules = (List<Map<String, Object>>) section.get("modules");
                        for (Map<String, Object> module : modules) {
                            Map<String, Object> activityInfo = new HashMap<>();
                            activityInfo.put("id", module.get("id"));
                            activityInfo.put("instance", module.get("instance"));
                            activityInfo.put("name", module.get("name"));
                            activityInfo.put("modname", module.get("modname"));
                            activityInfo.put("visible", module.get("visible"));
                            activityInfo.put("availability", module.get("availability"));
                            activityInfo.put("section", section.get("name"));
                            allActivities.add(activityInfo);
                        }
                    }
                }
            }
            
            debugResults.put("core_course_get_contents", Map.of(
                "url", contentsUrl,
                "totalSections", contentsResponse != null ? contentsResponse.size() : 0,
                "allActivities", allActivities,
                "assignmentActivities", allActivities.stream()
                    .filter(act -> "assign".equals(act.get("modname")))
                    .collect(java.util.stream.Collectors.toList())
            ));
        } catch (Exception e) {
            debugResults.put("core_course_get_contents", Map.of("error", e.getMessage()));
        }

        // 3. Test user enrollment status
        try {
            String enrollUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_enrol_get_users_courses"
                    + "&userid=" + ((Map<String, Object>) tokenInfo.get("userInfo")).get("userId")
                    + "&moodlewsrestformat=json";
            
            List<Map<String, Object>> enrollResponse = restTemplate.getForObject(enrollUrl, List.class);
            
            // Find this specific course
            Map<String, Object> thisCourse = null;
            if (enrollResponse != null) {
                for (Map<String, Object> course : enrollResponse) {
                    if (courseId.equals(String.valueOf(course.get("id")))) {
                        thisCourse = course;
                        break;
                    }
                }
            }
            
            debugResults.put("user_enrollment", Map.of(
                "url", enrollUrl,
                "allEnrolledCourses", enrollResponse != null ? enrollResponse.size() : 0,
                "thisSpecificCourse", thisCourse,
                "isEnrolledInThisCourse", thisCourse != null
            ));
        } catch (Exception e) {
            debugResults.put("user_enrollment", Map.of("error", e.getMessage()));
        }

        // 4. Test getting all assignments without course filter
        try {
            String allAssignUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=mod_assign_get_assignments"
                    + "&moodlewsrestformat=json";
            
            Map<String, Object> allAssignResponse = restTemplate.getForObject(allAssignUrl, Map.class);
            debugResults.put("mod_assign_get_assignments_all", Map.of(
                "url", allAssignUrl,
                "response", allAssignResponse
            ));
        } catch (Exception e) {
            debugResults.put("mod_assign_get_assignments_all", Map.of("error", e.getMessage()));
        }

        return ResponseEntity.ok(Map.of(
            "success", true,
            "courseId", courseId,
            "userId", ((Map<String, Object>) tokenInfo.get("userInfo")).get("userId"),
            "debugResults", debugResults,
            "recommendation", "Check the 'assignmentActivities' in core_course_get_contents to see all assignment modules, and compare with mod_assign_get_assignments results"
        ));

    } catch (Exception e) {
        return ResponseEntity.internalServerError().body(Map.of(
            "success", false,
            "error", "Debug error: " + e.getMessage()
        ));
    }
}

