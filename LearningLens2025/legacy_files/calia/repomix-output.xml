    /**
     * Store teacher chat log in Google Drive
     */
    public Map<String, Object> storeTeacherChatLog(String teacherToken, String teacherId, String courseId,
                                                  String materialType, String prompt, String response) {
        try {
            System.out.println("🔧 Storing teacher chat log for teacher: " + teacherId);
            
            // Create session ID and filename
            String sessionId = "teacher_" + System.currentTimeMillis();
            String today = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd"));
            
            String sanitizedTeacherId = sanitizeEmailForDrive(teacherId);
            String sanitizedCourseId = sanitizeForDrive(courseId);
            String sanitizedMaterialType = sanitizeForDrive(materialType);
            
            String fileName = String.format("CAILA_Teacher_%s_%s_%s_%s_%s.txt", 
                           sanitizedTeacherId, sanitizedCourseId, sanitizedMaterialType, today, sessionId);
            
            // Build complete content including header AND first chat entry
            String completeContent = buildTeacherChatHeader(teacherId, courseId, materialType, sessionId);
            completeContent += formatTeacherChatEntry(prompt, response);
            
            // Create file with complete content
            String fileId = createTeacherChatFile(teacherToken, fileName, completeContent);
            
            if (fileId != null) {
                System.out.println("✅ Created teacher chat file with ID: " + fileId);
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("sessionId", sessionId);
                result.put("fileId", fileId);
                result.put("message", "Teacher chat log stored successfully");
                return result;
            } else {
                return createErrorResponse("Failed to create chat session");
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error storing teacher chat log: " + e.getMessage());
            e.printStackTrace();
            return createErrorResponse("Failed to store teacher chat log: " + e.getMessage());
        }
    }

    /**
     * Get teacher's chat history
     */
    public Map<String, Object> getTeacherChatHistory(String teacherToken, String teacherId) {
        try {
            System.out.println("🔧 Getting teacher chat history for: " + teacherId);
            
            List<Map<String, Object>> teacherChatFiles = findTeacherChatFiles(teacherToken, teacherId);
            List<Map<String, Object>> chatSessions = new ArrayList<>();
            
            for (Map<String, Object> file : teacherChatFiles) {
                try {
                    Map<String, Object> sessionSummary = buildTeacherSessionSummary(teacherToken, file);
                    if (sessionSummary != null) {
                        chatSessions.add(sessionSummary);
                    }
                } catch (Exception fileError) {
                    System.out.println("⚠️ Error processing teacher chat file: " + fileError.getMessage());
                }
            }
            
            chatSessions.sort((a, b) -> {
                String timeA = (String) a.get("createdTime");
                String timeB = (String) b.get("createdTime");
                if (timeA == null || timeB == null) return 0;
                return timeB.compareTo(timeA);
            });
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", Map.of(
                "teacherId", teacherId,
                "sessions", chatSessions,
                "totalSessions", chatSessions.size(),
                "platform", "google"
            ));
            
            return result;
            
        } catch (Exception e) {
            System.out.println("❌ Error getting teacher chat history: " + e.getMessage());
            e.printStackTrace();
            return createErrorResponse("Failed to get teacher chat history: " + e.getMessage());
        }
    }

    /**
     * Get specific teacher chat session
     */
    public Map<String, Object> getTeacherChatSession(String teacherToken, String teacherId, String sessionId) {
        try {
            System.out.println("🔧 Getting teacher chat session: " + sessionId);
            
            String fileId = findTeacherChatFileBySessionId(teacherToken, teacherId, sessionId);
            if (fileId == null) {
                return createErrorResponse("Chat session not found");
            }
            
            String content = getFileContent(teacherToken, fileId);
            if (content == null || content.trim().isEmpty()) {
                return createErrorResponse("Session content not available");
            }
            
            Map<String, Object> sessionData = parseTeacherChatSession(content, sessionId);
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", sessionData);
            
            return result;
            
        } catch (Exception e) {
            System.out.println("❌ Error getting teacher chat session: " + e.getMessage());
            e.printStackTrace();
            return createErrorResponse("Failed to get chat session: " + e.getMessage());
        }
    }

    /**
     * Update teacher chat session with new message
     */
    public Map<String, Object> updateTeacherChatSession(String teacherToken, String teacherId, 
                                                       String sessionId, String prompt, String response) {
        try {
            System.out.println("🔧 Updating teacher chat session: " + sessionId);
            
            String fileId = findTeacherChatFileBySessionId(teacherToken, teacherId, sessionId);
            if (fileId == null) {
                return createErrorResponse("Chat session not found");
            }
            
            String existingContent = getFileContent(teacherToken, fileId);
            if (existingContent == null) {
                return createErrorResponse("Could not read existing session content");
            }
            
            String chatEntry = formatTeacherChatEntry(prompt, response);
            String updatedContent = existingContent + chatEntry;
            
            boolean success = updateFileContent(teacherToken, fileId, updatedContent);
            
            if (success) {
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("sessionId", sessionId);
                result.put("message", "Session updated successfully");
                return result;
            } else {
                return createErrorResponse("Failed to update session");
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error updating teacher chat session: " + e.getMessage());
            e.printStackTrace();
            return createErrorResponse("Failed to update session: " + e.getMessage());
        }
    }

    /**
     * Delete teacher chat session
     */
    public Map<String, Object> deleteTeacherChatSession(String teacherToken, String teacherId, String sessionId) {
        try {
            System.out.println("🔧 Deleting teacher chat session: " + sessionId);
            
            String fileId = findTeacherChatFileBySessionId(teacherToken, teacherId, sessionId);
            if (fileId == null) {
                return createErrorResponse("Chat session not found");
            }
            
            boolean deleted = deleteGoogleDriveFile(teacherToken, fileId);
            
            if (deleted) {
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("message", "Session deleted successfully");
                return result;
            } else {
                return createErrorResponse("Failed to delete session");
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error deleting teacher chat session: " + e.getMessage());
            e.printStackTrace();
            return createErrorResponse("Failed to delete session: " + e.getMessage());
        }
    }

