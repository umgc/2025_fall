    private ConversationIntent analyzeConversationIntent(String prompt, String materialType) {
        prompt = prompt.toLowerCase();
        
        Matcher generationMatcher = GENERATION_PATTERNS.matcher(prompt);
        Matcher completionMatcher = COMPLETION_PATTERNS.matcher(prompt);
        
        boolean wantsToGenerate = generationMatcher.find();
        boolean isComplete = completionMatcher.find();
        boolean wantsToModify = prompt.contains("change") || prompt.contains("modify") || 
                              prompt.contains("update") || prompt.contains("revise") ||
                              prompt.contains("edit") || prompt.contains("improve");
        boolean askingQuestion = prompt.contains("?") || prompt.startsWith("what") || 
                               prompt.startsWith("how") || prompt.startsWith("why") ||
                               prompt.startsWith("when") || prompt.startsWith("where");
        
        String intentType;
        if (wantsToGenerate) intentType = "generate";
        else if (wantsToModify) intentType = "modify";
        else if (isComplete) intentType = "complete";
        else if (askingQuestion) intentType = "question";
        else intentType = "discuss";
        
        return new ConversationIntent(wantsToGenerate, wantsToModify, isComplete, askingQuestion, intentType);
    }

    private String buildConversationalPrompt(String prompt, String materialType, ConversationIntent intent) {
        StringBuilder enhancedPrompt = new StringBuilder();
        
        enhancedPrompt.append("You are CAILA, an AI assistant specializing in helping teachers create educational materials through conversation. ");
        enhancedPrompt.append("You are currently helping create a ").append(materialType).append(". ");
        
        // Check if the prompt is specific enough to generate directly
        boolean isSpecificRequest = isSpecificGenerationRequest(prompt, materialType);
        
        if (isSpecificRequest || intent.wantsToGenerate) {
            enhancedPrompt.append("The teacher has given you specific requirements. Generate a complete, ready-to-use ")
                         .append(materialType.toLowerCase()).append(" immediately based on their specifications. ");
            enhancedPrompt.append("Do not ask clarifying questions - create the content directly. ");
            enhancedPrompt.append("Make it professional, educational, and appropriate for the specified grade level or audience. ");
        } else {
            switch (intent.intentType) {
                case "modify":
                    enhancedPrompt.append("The teacher wants to modify existing content. Ask clarifying questions and provide specific suggestions. ");
                    break;
                case "complete":
                    enhancedPrompt.append("The teacher seems satisfied with the current content. Confirm completion and offer final refinements or export options. ");
                    break;
                case "question":
                    enhancedPrompt.append("The teacher has a question. Provide helpful, educational guidance related to creating a ")
                                 .append(materialType.toLowerCase()).append(". ");
                    break;
                default:
                    enhancedPrompt.append("Engage in helpful conversation about creating the ")
                                 .append(materialType.toLowerCase()).append(". ");
            }
        }
        
        enhancedPrompt.append("\n\nTeacher's request: ").append(prompt);
        
        if (isSpecificRequest || intent.wantsToGenerate) {
            enhancedPrompt.append("\n\nGenerate the complete ").append(materialType.toLowerCase())
                         .append(" now. Format it clearly and professionally:");
        } else {
            enhancedPrompt.append("\n\nRespond conversationally and helpfully. If generating content, make it complete and professional. ");
            enhancedPrompt.append("If the content is substantial (like a full lesson plan or assignment), clearly mark it as the generated material.");
        }
        
        return enhancedPrompt.toString();
    }

    /**
     * Check if the prompt contains specific enough details to generate content directly
     */
    private boolean isSpecificGenerationRequest(String prompt, String materialType) {
        String lowerPrompt = prompt.toLowerCase();
        String lowerMaterialType = materialType.toLowerCase();
        
        // Check for specific patterns that indicate direct generation
        boolean hasActionWord = lowerPrompt.contains("create") || lowerPrompt.contains("make") || 
                               lowerPrompt.contains("generate") || lowerPrompt.contains("write") ||
                               lowerPrompt.contains("design") || lowerPrompt.contains("build");
        
        boolean hasMaterialType = lowerPrompt.contains(lowerMaterialType) || 
                                 lowerPrompt.contains("quiz") || lowerPrompt.contains("test") ||
                                 lowerPrompt.contains("assignment") || lowerPrompt.contains("lesson") ||
                                 lowerPrompt.contains("worksheet") || lowerPrompt.contains("rubric");
        
        boolean hasSpecifics = lowerPrompt.contains("question") || lowerPrompt.contains("problem") ||
                              lowerPrompt.contains("grade") || lowerPrompt.contains("topic") ||
                              lowerPrompt.matches(".*\\d+.*") || // Contains numbers (like "5 questions")
                              lowerPrompt.contains("about") || lowerPrompt.contains("on");
        
        // Additional specific patterns
        boolean hasQuantity = lowerPrompt.matches(".*(\\d+)\\s*(question|problem|item|page|minute).*");
        boolean hasGradeLevel = lowerPrompt.matches(".*(\\d+)(st|nd|rd|th)\\s*grade.*") ||
                               lowerPrompt.contains("elementary") || lowerPrompt.contains("middle") ||
                               lowerPrompt.contains("high school") || lowerPrompt.contains("kindergarten");
        boolean hasSubject = lowerPrompt.contains("math") || lowerPrompt.contains("science") ||
                            lowerPrompt.contains("english") || lowerPrompt.contains("history") ||
                            lowerPrompt.contains("reading") || lowerPrompt.contains("writing");
        
        // If it has action + material type + any specifics, generate directly
        return (hasActionWord && hasMaterialType && (hasSpecifics || hasQuantity || hasGradeLevel || hasSubject));
    }

    private MaterialContent detectMaterialContent(String response, String materialType) {
        // Simple heuristic to detect if response contains substantial material content
        int wordCount = response.split("\\s+").length;
        boolean hasStructure = response.contains("**") || response.contains("##") || 
                              response.contains("1.") || response.contains("•");
        boolean hasMaterialKeywords = response.toLowerCase().contains(materialType.toLowerCase()) ||
                                     response.toLowerCase().contains("assignment") ||
                                     response.toLowerCase().contains("lesson") ||
                                     response.toLowerCase().contains("quiz");
        
        double confidence = 0.0;
        if (wordCount > 100) confidence += 0.3;
        if (hasStructure) confidence += 0.3;
        if (hasMaterialKeywords) confidence += 0.2;
        if (wordCount > 300) confidence += 0.2;
        
        boolean containsMaterial = confidence > 0.5;
        
        return new MaterialContent(containsMaterial, response, materialType, confidence);
    }

