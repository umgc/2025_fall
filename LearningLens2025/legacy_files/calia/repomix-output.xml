    /**
     * Parse teacher chat session content
     */
    private Map<String, Object> parseTeacherChatSession(String content, String sessionId) {
        List<Map<String, Object>> messages = new ArrayList<>();
        String[] lines = content.split("\n");
        
        String currentRole = null;
        StringBuilder currentMessage = new StringBuilder();
        String currentTimestamp = null;
        
        for (String line : lines) {
            line = line.trim();
            
            if (line.startsWith("[") && line.endsWith("]")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                currentTimestamp = line.substring(1, line.length() - 1);
                currentRole = null;
                currentMessage = new StringBuilder();
                
            } else if (line.startsWith("TEACHER:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                currentRole = "teacher";
                currentMessage = new StringBuilder(line.substring(8).trim());
                
            } else if (line.startsWith("CAILA:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                currentRole = "caila";
                currentMessage = new StringBuilder(line.substring(6).trim());
                
            } else if (!line.equals("--------------------------------------------------") && 
                      !line.equals("==================================================") &&
                      !line.isEmpty() && currentRole != null) {
                if (currentMessage.length() > 0) currentMessage.append(" ");
                currentMessage.append(line);
            }
        }
        
        if (currentRole != null && currentMessage.length() > 0) {
            Map<String, Object> message = new HashMap<>();
            message.put("role", currentRole);
            message.put("content", currentMessage.toString().trim());
            message.put("timestamp", currentTimestamp);
            messages.add(message);
        }
        
        String materialType = extractMaterialTypeFromContent(content);
        String courseId = extractCourseIdFromContent(content);
        String teacherId = extractTeacherIdFromContent(content);
        String createdAt = extractCreatedAtFromContent(content);
        
        Map<String, Object> sessionData = new HashMap<>();
        sessionData.put("sessionId", sessionId);
        sessionData.put("teacherId", teacherId);
        sessionData.put("courseId", courseId);
        sessionData.put("materialType", materialType);
        sessionData.put("createdAt", createdAt);
        sessionData.put("messages", messages);
        sessionData.put("messageCount", messages.size());
        sessionData.put("platform", "google");
        
        return sessionData;
    }

    /**
     * Parse student chat log content
     */
    private List<Map<String, Object>> parseChatLogContent(String content) {
        List<Map<String, Object>> entries = new ArrayList<>();
        if (content == null || content.trim().isEmpty()) {
            return entries;
        }
        
        String[] lines = content.split("\n");
        Map<String, Object> currentEntry = null;
        String currentRole = null;
        StringBuilder currentMessage = new StringBuilder();
        
        for (String line : lines) {
            String trimmedLine = line.trim();
            
            if (trimmedLine.isEmpty() || trimmedLine.startsWith("=") || trimmedLine.startsWith("-")) {
                continue;
            }
            
            if (trimmedLine.startsWith("[") && trimmedLine.endsWith("]")) {
                if (currentEntry != null && currentRole != null && currentMessage.length() > 0) {
                    currentEntry.put(currentRole.toLowerCase(), currentMessage.toString().trim());
                }
                if (currentEntry != null && 
                    (currentEntry.containsKey("student") || currentEntry.containsKey("caila"))) {
                    entries.add(currentEntry);
                }
                
                String timestamp = trimmedLine.substring(1, trimmedLine.length() - 1);
                currentEntry = new HashMap<>();
                currentEntry.put("timestamp", timestamp);
                currentRole = null;
                currentMessage = new StringBuilder();
                continue;
            }
            
            if (trimmedLine.startsWith("STUDENT:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    currentEntry.put(currentRole.toLowerCase(), currentMessage.toString().trim());
                }
                currentRole = "STUDENT";
                currentMessage = new StringBuilder();
                String studentText = trimmedLine.substring(8).trim();
                if (!studentText.isEmpty()) {
                    currentMessage.append(studentText);
                }
                continue;
            }
            
            if (trimmedLine.startsWith("CAILA:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    currentEntry.put(currentRole.toLowerCase(), currentMessage.toString().trim());
                }
                currentRole = "CAILA";
                currentMessage = new StringBuilder();
                String cailaText = trimmedLine.substring(6).trim();
                if (!cailaText.isEmpty()) {
                    currentMessage.append(cailaText);
                }
                continue;
            }
            
            if (currentRole != null && !trimmedLine.isEmpty() &&
                !trimmedLine.contains("CAILA AI Assistant") && 
                !trimmedLine.contains("Student:") && 
                !trimmedLine.contains("Course ID:") &&
                !trimmedLine.contains("Created:")) {
                
                if (currentMessage.length() > 0) {
                    currentMessage.append("\n");
                }
                currentMessage.append(trimmedLine);
            }
        }
        
        if (currentEntry != null && currentRole != null && currentMessage.length() > 0) {
            currentEntry.put(currentRole.toLowerCase(), currentMessage.toString().trim());
        }
        if (currentEntry != null && 
            (currentEntry.containsKey("student") || currentEntry.containsKey("caila"))) {
            entries.add(currentEntry);
        }
        
        return entries;
    }

