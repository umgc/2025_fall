    /**
     * Generic method to create Moodle resources (pages, files, URLs)
     */
    private Map<String, Object> createMoodleResource(String token, String courseId, 
                                                    String resourceType, Map<String, Object> resourceData) {
        try {
            logger.info("🔧 Creating Moodle resource of type: {}", resourceType);
            
            // Build the API URL for creating resources
            String url = moodleBaseUrl + "/webservice/rest/server.php";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            StringBuilder requestBody = new StringBuilder();
            requestBody.append("wstoken=").append(token);
            requestBody.append("&wsfunction=core_course_create_modules");
            requestBody.append("&moodlewsrestformat=json");
            
            // Course module data
            requestBody.append("&modules[0][modulename]=").append(resourceType);
            requestBody.append("&modules[0][section]=0"); // Add to first section
            requestBody.append("&modules[0][visible]=1");
            requestBody.append("&modules[0][course]=").append(courseId);
            
            // Add resource-specific data
            for (Map.Entry<String, Object> entry : resourceData.entrySet()) {
                String key = entry.getKey();
                Object value = entry.getValue();
                if (value != null) {
                    requestBody.append("&modules[0][").append(key).append("]=")
                              .append(URLEncoder.encode(value.toString(), StandardCharsets.UTF_8));
                }
            }
            
            logger.info("🔧 Resource creation request: {}", requestBody.toString().substring(0, Math.min(200, requestBody.length())) + "...");
            
            HttpEntity<String> request = new HttpEntity<>(requestBody.toString(), headers);
            
            ResponseEntity<String> response = restTemplate.postForEntity(url, request, String.class);
            
            logger.info("🔧 Resource creation response status: {}", response.getStatusCode());
            logger.info("🔧 Resource creation response: {}", response.getBody());
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (jsonResponse.has("exception")) {
                    String error = jsonResponse.path("message").asText();
                    logger.error("❌ Moodle API error: {}", error);
                    return createErrorResponse("Moodle API error: " + error);
                }
                
                // Parse successful response
                JsonNode modules = jsonResponse.path("modules");
                if (modules.isArray() && modules.size() > 0) {
                    JsonNode module = modules.get(0);
                    String moduleId = module.path("id").asText();
                    String cmId = module.path("cmid").asText();
                    
                    Map<String, Object> moduleInfo = new HashMap<>();
                    moduleInfo.put("moduleId", moduleId);
                    moduleInfo.put("cmId", cmId);
                    moduleInfo.put("resourceType", resourceType);
                    moduleInfo.put("courseId", courseId);
                    moduleInfo.put("url", getMoodleActivityUrl(courseId, cmId, resourceType));
                    
                    return createSuccessResponse("Resource created successfully", moduleInfo);
                } else {
                    logger.warn("🔧 Unexpected response format from Moodle");
                    return createErrorResponse("Unexpected response format from Moodle");
                }
            } else {
                return createErrorResponse("HTTP error: " + response.getStatusCode());
            }
            
        } catch (Exception e) {
            logger.error("❌ Error creating Moodle resource: {}", e.getMessage(), e);
            return createErrorResponse("Failed to create resource: " + e.getMessage());
        }
    }

    /**
     * Generic method to create Moodle activities using core_course_create_modules
     */
    private Map<String, Object> createMoodleActivity(String token, String courseId, 
                                                    String activityType, Map<String, Object> activityData) {
        try {
            logger.info("🔧 Creating Moodle activity using core module creation API");
            
            String url = moodleBaseUrl + "/webservice/rest/server.php";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            StringBuilder requestBody = new StringBuilder();
            requestBody.append("wstoken=").append(token);
            requestBody.append("&wsfunction=core_course_create_modules");
            requestBody.append("&moodlewsrestformat=json");
            
            // Module configuration
            requestBody.append("&modules[0][modulename]=").append(activityType);
            requestBody.append("&modules[0][section]=0"); // Add to first section
            requestBody.append("&modules[0][visible]=1");
            requestBody.append("&modules[0][course]=").append(courseId);
            
            // Add activity-specific data with proper module prefix
            for (Map.Entry<String, Object> entry : activityData.entrySet()) {
                String key = entry.getKey();
                Object value = entry.getValue();
                if (value != null) {
                    requestBody.append("&modules[0][").append(key).append("]=")
                              .append(URLEncoder.encode(value.toString(), StandardCharsets.UTF_8));
                }
            }
            
            logger.info("🔧 Moodle request body: {}", requestBody.toString().substring(0, Math.min(200, requestBody.length())) + "...");
            
            HttpEntity<String> request = new HttpEntity<>(requestBody.toString(), headers);
            
            ResponseEntity<String> response = restTemplate.postForEntity(url, request, String.class);
            
            logger.info("🔧 Moodle response status: {}", response.getStatusCode());
            logger.info("🔧 Moodle response body: {}", response.getBody());
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (jsonResponse.has("exception")) {
                    String error = jsonResponse.path("message").asText();
                    logger.error("❌ Moodle API error: {}", error);
                    
                    // Fallback to creating as a page resource
                    logger.info("🔧 Falling back to page resource creation");
                    return createMoodlePage(token, courseId, convertActivityDataToPageData(activityData, activityType));
                }
                
                // Parse successful response
                JsonNode modules = jsonResponse.path("modules");
                if (modules.isArray() && modules.size() > 0) {
                    JsonNode module = modules.get(0);
                    String moduleId = module.path("id").asText();
                    String cmId = module.path("cmid").asText();
                    
                    Map<String, Object> activityInfo = new HashMap<>();
                    activityInfo.put("moduleId", moduleId);
                    activityInfo.put("cmId", cmId);
                    activityInfo.put("activityType", activityType);
                    activityInfo.put("courseId", courseId);
                    activityInfo.put("url", getMoodleActivityUrl(courseId, cmId, activityType));
                    
                    return createSuccessResponse("Activity created successfully", activityInfo);
                } else {
                    logger.warn("🔧 Unexpected response format, falling back to page");
                    return createMoodlePage(token, courseId, convertActivityDataToPageData(activityData, activityType));
                }
            } else {
                logger.error("❌ HTTP error: {}", response.getStatusCode());
                return createMoodlePage(token, courseId, convertActivityDataToPageData(activityData, activityType));
            }
            
        } catch (Exception e) {
            logger.error("❌ Error creating Moodle activity: {}", e.getMessage(), e);
            // Always fallback to creating as a page resource
            logger.info("🔧 Exception occurred, falling back to page resource creation");
            return createMoodlePage(token, courseId, convertActivityDataToPageData(activityData, activityType));
        }
    }

    /**
     * Helper method to get the correct Moodle function for activity creation
     */
    private String getActivityCreationFunction(String activityType) {
        switch (activityType) {
            case "assign":
                return "mod_assign_create_assignment";
            case "quiz":
                return "mod_quiz_create_quiz";
            case "forum":
                return "mod_forum_create_forum";
            case "lesson":
                return "mod_lesson_create_lesson";
            default:
                return "core_course_create_modules";
        }
    }

    /**
     * Convert activity data to page data as fallback
     */
    private Map<String, Object> convertActivityDataToPageData(Map<String, Object> activityData, String activityType) {
        Map<String, Object> pageData = new HashMap<>();
        
        String title = (String) activityData.get("name");
        String intro = (String) activityData.get("intro");
        
