    /**
     * Find chat files for teacher access
     */
    private List<Map<String, Object>> findChatFilesSimplified(String teacherAccessToken, String courseId) {
        List<Map<String, Object>> chatFiles = new ArrayList<>();
        
        try {
            List<Map<String, Object>> allFiles = getAllAccessibleFiles(teacherAccessToken);
            String courseIdSanitized = sanitizeForDrive(courseId);
            
            for (Map<String, Object> file : allFiles) {
                String fileName = (String) file.get("name");
                String fileId = (String) file.get("id");
                
                if (fileName != null && fileId != null &&
                    fileName.startsWith("CAILA_Chat_") && fileName.contains(courseIdSanitized)) {
                    String studentId = extractStudentIdFromFileName(fileName);
                    
                    if (studentId != null && verifyTeacherAccess(teacherAccessToken, fileId)) {
                        Map<String, Object> summary = new HashMap<>();
                        summary.put("studentId", studentId);
                        summary.put("fileId", fileId);
                        summary.put("fileName", fileName);
                        summary.put("lastUpdated", file.get("modifiedTime"));
                        summary.put("createdTime", file.get("createdTime"));
                        summary.put("accessMethod", "simplified_filter");
                        summary.put("commentCount", getMessageCountFromFileSafe(teacherAccessToken, fileId));
                        
                        chatFiles.add(summary);
                    }
                }
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error in simplified search: " + e.getMessage());
            e.printStackTrace();
        }
        
        return chatFiles;
    }

