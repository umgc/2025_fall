    /**
     * Attempt direct creation using core functions
     */
    private Map<String, Object> attemptDirectCreation(String token, String courseId, 
                                                     Map<String, Object> materialData, String exportType) {
        try {
            logger.info("🔧 Attempting direct creation with core_course_create_modules");
            
            // Try to use the core module creation function
            String moduleName = getModuleNameForExportType(exportType);
            Map<String, Object> moduleData = prepareModuleData(materialData, exportType);
            
            String url = moodleBaseUrl + "/webservice/rest/server.php";
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            StringBuilder requestBody = new StringBuilder();
            requestBody.append("wstoken=").append(token);
            requestBody.append("&wsfunction=core_course_create_modules");
            requestBody.append("&moodlewsrestformat=json");
            
            // Module configuration
            requestBody.append("&modules[0][modulename]=").append(moduleName);
            requestBody.append("&modules[0][section]=0");
            requestBody.append("&modules[0][visible]=1");
            requestBody.append("&modules[0][course]=").append(courseId);
            
            // Add module-specific data
            for (Map.Entry<String, Object> entry : moduleData.entrySet()) {
                String key = entry.getKey();
                Object value = entry.getValue();
                if (value != null) {
                    requestBody.append("&modules[0][").append(key).append("]=")
                              .append(URLEncoder.encode(value.toString(), StandardCharsets.UTF_8));
                }
            }
            
            HttpEntity<String> request = new HttpEntity<>(requestBody.toString(), headers);
            ResponseEntity<String> response = restTemplate.postForEntity(url, request, String.class);
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (!jsonResponse.has("exception")) {
                    // Success!
                    JsonNode modules = jsonResponse.path("modules");
                    if (modules.isArray() && modules.size() > 0) {
                        JsonNode module = modules.get(0);
                        String cmId = module.path("cmid").asText();
                        
                        Map<String, Object> successData = new HashMap<>();
                        successData.put("moduleId", module.path("id").asText());
                        successData.put("cmId", cmId);
                        successData.put("exportType", exportType);
                        successData.put("url", getMoodleActivityUrl(courseId, cmId, moduleName));
                        
                        logger.info("✅ Direct creation successful: {} created", exportType);
                        return createSuccessResponse("Assignment created successfully in Moodle", successData);
                    }
                }
            }
            
            logger.info("🔧 Direct creation failed, will try alternative");
            return createErrorResponse("Direct creation not available");
            
        } catch (Exception e) {
            logger.info("🔧 Direct creation exception: {}, will try alternative", e.getMessage());
            return createErrorResponse("Direct creation failed: " + e.getMessage());
        }
    }

    /**
     * Alternative creation methods when direct API doesn't work
     */
    private Map<String, Object> attemptAlternativeCreation(String token, String courseId, 
                                                          Map<String, Object> materialData, String exportType) {
        try {
            logger.info("🔧 Attempting alternative creation methods");
            
            // Method 1: Try using course editing simulation
            Map<String, Object> simulationResult = createViaSimulation(token, courseId, materialData, exportType);
            if ((Boolean) simulationResult.get("success")) {
                return simulationResult;
            }
            
            // Method 2: Enhanced course note with assignment-like structure
            return createEnhancedAssignmentNote(token, courseId, materialData, exportType);
            
        } catch (Exception e) {
            logger.error("❌ Alternative creation failed", e);
            return createManualInstructionsResponse(materialData, courseId);
        }
    }

    /**
     * Create via course structure simulation
     */
    private Map<String, Object> createViaSimulation(String token, String courseId, 
                                                   Map<String, Object> materialData, String exportType) {
        try {
            logger.info("🔧 Attempting course structure simulation");
            
            // First, get course structure to understand sections
            String sectionsUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_course_get_contents"
                    + "&courseid=" + courseId
                    + "&moodlewsrestformat=json";
            
            ResponseEntity<String> sectionsResponse = restTemplate.getForEntity(sectionsUrl, String.class);
            
            if (sectionsResponse.getStatusCode() == HttpStatus.OK) {
                JsonNode sectionsJson = objectMapper.readTree(sectionsResponse.getBody());
                
                if (!sectionsJson.has("exception") && sectionsJson.isArray() && sectionsJson.size() > 0) {
                    // We have access to course structure, but still can't create modules directly
                    // Fall through to enhanced note method
                    logger.info("🔧 Course structure accessible but module creation unavailable");
                }
            }
            
            return createErrorResponse("Simulation method not available");
            
        } catch (Exception e) {
            logger.info("🔧 Simulation method failed: {}", e.getMessage());
            return createErrorResponse("Simulation failed: " + e.getMessage());
        }
    }

    /**
     * Create an enhanced assignment-like note
     */
    private Map<String, Object> createEnhancedAssignmentNote(String token, String courseId, 
                                                           Map<String, Object> materialData, String exportType) {
        try {
            logger.info("🔧 Creating enhanced assignment note");
            
            String title = (String) materialData.get("title");
            String content = (String) materialData.get("content");
            
            // Get user info
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            Map<String, Object> userInfo = (Map<String, Object>) tokenInfo.get("userInfo");
            Integer userId = (Integer) userInfo.get("userId");
            
            // Create a specially formatted note that looks like an assignment
            String enhancedContent = buildEnhancedAssignmentContent(title, content, exportType, courseId);
            
            // Create as a course note with special formatting
            String url = moodleBaseUrl + "/webservice/rest/server.php";
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            StringBuilder requestBody = new StringBuilder();
            requestBody.append("wstoken=").append(token);
            requestBody.append("&wsfunction=core_notes_create_notes");
            requestBody.append("&moodlewsrestformat=json");
            requestBody.append("&notes[0][userid]=").append(userId);
            requestBody.append("&notes[0][publishstate]=course");
            requestBody.append("&notes[0][courseid]=").append(courseId);
            requestBody.append("&notes[0][text]=").append(URLEncoder.encode(enhancedContent, StandardCharsets.UTF_8));
            requestBody.append("&notes[0][format]=1");
            
            HttpEntity<String> request = new HttpEntity<>(requestBody.toString(), headers);
            ResponseEntity<String> response = restTemplate.postForEntity(url, request, String.class);
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (!jsonResponse.has("exception")) {
                    Map<String, Object> noteData = new HashMap<>();
                    noteData.put("noteId", jsonResponse.isArray() && jsonResponse.size() > 0 ? 
                               jsonResponse.get(0).path("id").asText() : "created");
                    noteData.put("exportType", "enhanced_assignment_note");
                    noteData.put("url", moodleBaseUrl + "/notes/index.php?course=" + courseId);
                    noteData.put("conversionInstructions", getConversionInstructions(exportType));
                    
                    return createSuccessResponse(
                        "Assignment content prepared in Moodle notes. Follow the conversion instructions to create the actual assignment.", 
                        noteData
                    );
                }
            }
            
            return createManualInstructionsResponse(materialData, courseId);
            
        } catch (Exception e) {
            logger.error("❌ Enhanced note creation failed", e);
            return createManualInstructionsResponse(materialData, courseId);
        }
    }

    /**
     * Get module name for export type
     */
    private String getModuleNameForExportType(String exportType) {
        switch (exportType != null ? exportType : "page") {
            case "assignment":
                return "assign";
            case "quiz":
                return "quiz";
            case "forum":
                return "forum";
            case "lesson":
                return "lesson";
            default:
                return "page";
        }
    }

    /**
     * Prepare module data based on export type
     */
    private Map<String, Object> prepareModuleData(Map<String, Object> materialData, String exportType) {
        Map<String, Object> moduleData = new HashMap<>();
        
        String title = (String) materialData.get("title");
        String content = (String) materialData.get("content");
        
        moduleData.put("name", title);
        
        switch (exportType != null ? exportType : "page") {
            case "assignment":
                moduleData.put("intro", formatContentForMoodle(content, "assignment"));
                moduleData.put("introformat", 1);
                moduleData.put("grade", 100);
                moduleData.put("duedate", (System.currentTimeMillis() / 1000) + (7 * 24 * 60 * 60)); // 7 days
                moduleData.put("allowsubmissionsfromdate", System.currentTimeMillis() / 1000);
                moduleData.put("submissiondrafts", 0);
                moduleData.put("sendnotifications", 1);
                break;
                
            case "quiz":
                moduleData.put("intro", formatContentForMoodle(content, "quiz"));
                moduleData.put("introformat", 1);
                moduleData.put("timeopen", System.currentTimeMillis() / 1000);
                moduleData.put("timeclose", (System.currentTimeMillis() / 1000) + (30 * 24 * 60 * 60));
                moduleData.put("attempts", 0);
                break;
                
            default:
                moduleData.put("content", formatContentForMoodle(content, "page"));
                moduleData.put("contentformat", 1);
                moduleData.put("display", 5);
                break;
        }
        
        return moduleData;
    }

