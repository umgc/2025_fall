    private String extractMaterialFromConversation(List<Map<String, Object>> messages, String materialType) {
        String bestMaterial = null;
        double bestConfidence = 0.0;
        
        if (messages != null) {
            for (Map<String, Object> message : messages) {
                String role = (String) message.get("role");
                String content = (String) message.get("content");
                
                if ("caila".equals(role) && content != null) {
                    MaterialContent detected = detectMaterialContent(content, materialType);
                    if (detected.containsMaterial && detected.confidence > bestConfidence) {
                        bestMaterial = content;
                        bestConfidence = detected.confidence;
                    }
                }
            }
        }
        
        return bestMaterial;
    }

