@CrossOrigin(origins = "*")
public class ChatLogController {

    @Autowired
    private GoogleDriveChatService googleDriveChatService;

    @Autowired
    private AuthService authService;

    @Autowired
    private CailaService cailaService;

    @Autowired
    private RestTemplate restTemplate;

    @Autowired
    private MoodleChatService moodleChatService;

    private static final Logger logger = LoggerFactory.getLogger(ChatLogController.class);

    /**
     * Enhanced chat with context that saves to student's Drive and shares with teacher
     */
    @PostMapping("/chat-with-context")
    public ResponseEntity<Map<String, Object>> chatWithContext(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                Map<String, Object> errorResponse = new HashMap<>();
                errorResponse.put("success", false);
                errorResponse.put("error", "Invalid authentication token");
                return ResponseEntity.badRequest().body(errorResponse);
            }

            String courseId = (String) request.get("courseId");
            String studentId = (String) request.get("studentId");
            String prompt = (String) request.get("prompt");

            if (courseId == null || studentId == null || prompt == null) {
                Map<String, Object> errorResponse = new HashMap<>();
                errorResponse.put("success", false);
                errorResponse.put("error", "Missing required fields: courseId, studentId, prompt");
                return ResponseEntity.badRequest().body(errorResponse);
            }

            System.out.println("🔧 ChatLogController: Processing enhanced chat request");
            System.out.println("🔧 Course ID: " + courseId);
            System.out.println("🔧 Student ID: " + studentId);
            System.out.println("🔧 Platform: " + tokenInfo.get("platform"));

            // Get AI response first
            String aiResponse = cailaService.chatWithCaila(prompt);
            System.out.println("🔧 AI Response generated successfully");

            // Store chat log with sharing based on platform
            Map<String, Object> logResult;
            String platform = (String) tokenInfo.get("platform");
            
            try {
                System.out.println("🔧 Attempting to store chat log for platform: " + platform);
                
                if ("google".equals(platform)) {
                    // Use enhanced sharing method for Google
                    logResult = googleDriveChatService.storeChatLogWithSharing(
                        token, courseId, studentId, prompt, aiResponse
                    );
                } else if ("moodle".equals(platform)) {
                    // Use Moodle chat service
                    logResult = moodleChatService.storeChatLog(
                        token, courseId, studentId, prompt, aiResponse
                    );
                } else {
                    // For unknown platforms - use HashMap instead of Map.of()
                    logResult = new HashMap<>();
                    logResult.put("success", true);
                    logResult.put("message", "Chat completed successfully (platform: " + (platform != null ? platform : "unknown") + ")");
                    logResult.put("location", "Local only");
                    logResult.put("logged", false);
                    logResult.put("platform", platform != null ? platform : "unknown");
                }
                
                System.out.println("🔧 Chat log storage result: " + logResult);
            } catch (Exception logException) {
                System.out.println("🔧 Chat log storage failed: " + logException.getMessage());
                logResult = new HashMap<>();
                logResult.put("success", false);
                logResult.put("error", "Storage failed: " + logException.getMessage());
                logResult.put("logged", false);
            }

            // Return response with detailed logging info - use HashMap instead of Map.of()
            Map<String, Object> responseData = new HashMap<>();
            responseData.put("response", aiResponse);
            responseData.put("logged", logResult.get("logged"));
            responseData.put("logDetails", logResult);
            responseData.put("platform", platform);
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", responseData);

            return ResponseEntity.ok(result);

        } catch (Exception e) {
            System.out.println("🔧 ChatLogController: Exception in chatWithContext: " + e.getMessage());
            e.printStackTrace();
            Map<String, Object> errorResponse = new HashMap<>();
            errorResponse.put("success", false);
            errorResponse.put("error", "Server error: " + e.getMessage());
            return ResponseEntity.internalServerError().body(errorResponse);
        }
    }

