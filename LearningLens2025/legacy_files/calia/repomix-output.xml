// File: src/main/java/com/focusedai/caila_service/service/StudentAssignmentService.java
// ENHANCED VERSION - Fixed quiz content loading and improved error handling

package com.focusedai.caila_service.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.http.*;

import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.*;

@Service
public class StudentAssignmentService {
    
    @Autowired
    private AuthService authService;
    
    private final RestTemplate restTemplate = new RestTemplate();
    
    @Value("${lms.moodle.base-url:http://18.188.18.80/moodle}")
    private String moodleBaseUrl;

    public Map<String, Object> getCourseAssignments(String token, String courseId) {
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        if (tokenInfo == null) {
            return Map.of("success", false, "error", "Invalid token");
        }

        String platform = (String) tokenInfo.get("platform");

        if ("google".equals(platform)) {
            return getGoogleClassroomAssignments(token, courseId);
        } else if ("moodle".equals(platform)) {
            return getMoodleAssignments(token, courseId);
        }

        return Map.of("success", false, "error", "Unsupported platform");
    }

    // Google Classroom assignments (unchanged)
    private Map<String, Object> getGoogleClassroomAssignments(String token, String courseId) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + token);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            ResponseEntity<Map> response = restTemplate.exchange(
                "https://classroom.googleapis.com/v1/courses/" + courseId + "/courseWork",
                HttpMethod.GET, entity, Map.class
            );

            if (response.getStatusCode() == HttpStatus.OK) {
                Map<String, Object> responseBody = response.getBody();
                List<Map<String, Object>> assignments = new ArrayList<>();

                if (responseBody != null && responseBody.containsKey("courseWork")) {
                    @SuppressWarnings("unchecked")
                    List<Map<String, Object>> courseWork = (List<Map<String, Object>>) responseBody.get("courseWork");

                    for (Map<String, Object> work : courseWork) {
                        Map<String, Object> assignment = new HashMap<>();
                        assignment.put("id", work.get("id"));
                        assignment.put("name", work.get("title"));
                        assignment.put("description", work.get("description"));
                        assignment.put("maxScore", work.get("maxPoints"));
                        assignment.put("platform", "google");
                        assignment.put("courseId", courseId);
                        assignment.put("status", "assigned");
                        
                        // Handle due date
                        if (work.containsKey("dueDate")) {
                            @SuppressWarnings("unchecked")
                            Map<String, Object> dueDate = (Map<String, Object>) work.get("dueDate");
                            if (dueDate != null) {
                                String dueDateStr = formatGoogleDate(dueDate);
                                assignment.put("dueDate", dueDateStr);
                            }
                        }

                        assignments.add(assignment);
                    }
                }

                return Map.of(
                    "success", true,
                    "data", assignments,
                    "count", assignments.size(),
                    "platform", "google"
                );
            }

            return Map.of("success", false, "error", "Failed to fetch assignments from Google Classroom");

        } catch (Exception e) {
            return Map.of("success", false, "error", "Google Classroom error: " + e.getMessage());
        }
    }

    // ENHANCED: Moodle assignments with improved content loading
    private Map<String, Object> getMoodleAssignments(String token, String courseId) {
        try {
            System.out.println("🔧 Fetching Moodle activities with content for course: " + courseId);
            
            // Get all course activities using core_course_get_contents
            String url = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_course_get_contents"
                    + "&courseid=" + courseId
                    + "&moodlewsrestformat=json";

            System.out.println("🔧 Moodle course contents URL: " + url);

            @SuppressWarnings("unchecked")
            List<Map<String, Object>> sections = restTemplate.getForObject(url, List.class);
            
            System.out.println("🔧 Moodle API response sections: " + (sections != null ? sections.size() : 0));

            List<Map<String, Object>> assignments = new ArrayList<>();

            if (sections != null) {
                for (Map<String, Object> section : sections) {
                    System.out.println("🔧 Processing section: " + section.get("name"));
                    
                    if (section.containsKey("modules")) {
                        @SuppressWarnings("unchecked")
                        List<Map<String, Object>> modules = (List<Map<String, Object>>) section.get("modules");
                        
                        System.out.println("🔧 Number of modules in section: " + modules.size());

                        for (Map<String, Object> module : modules) {
