            Object visible = module.get("visible");
            assignment.put("visible", visible);
            
            // Handle dates if available
            handleActivityDates(assignment, module);
            
            // Set default max score based on activity type
            assignment.put("maxScore", getDefaultMaxScore(modname));
            
            // ENHANCED: Load specific content based on activity type with better error handling
            String description = loadActivityDescriptionRobust(token, modname, instanceId, courseId, module);
            assignment.put("description", description);
            
            // Load additional activity-specific data
