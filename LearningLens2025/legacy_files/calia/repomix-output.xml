    private ConversationSummary generateConversationSummary(List<Map<String, Object>> messages, String materialType) {
        int totalMessages = messages != null ? messages.size() : 0;
        int materialIterations = 0;
        String finalMaterial = null;
        List<String> keyTopics = new ArrayList<>();
        
        if (messages != null) {
            for (Map<String, Object> message : messages) {
                String content = (String) message.get("content");
                if (content != null) {
                    MaterialContent detected = detectMaterialContent(content, materialType);
                    if (detected.containsMaterial) {
                        materialIterations++;
                        finalMaterial = content;
                    }
                }
            }
        }
        
        String conversationFlow = totalMessages < 3 ? "Brief discussion" :
                                totalMessages < 8 ? "Detailed planning" : "Comprehensive development";
        
        String currentStatus = finalMaterial != null ? "Material generated" : "In progress";
        
        return new ConversationSummary(totalMessages, materialIterations, finalMaterial, 
                                     conversationFlow, keyTopics, currentStatus);
    }

