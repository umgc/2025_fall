    /**
     * Create a personal note in Moodle (fallback approach)
     */
    private Map<String, Object> createMoodlePersonalNote(String token, String courseId, 
                                                        Map<String, Object> materialData) {
        try {
            logger.info("🔧 Creating Moodle personal note as fallback");
            
            String title = (String) materialData.get("title");
            String content = (String) materialData.get("content");
            String materialType = (String) materialData.get("type");
            String exportType = (String) materialData.get("exportType");
            
            // Get user info to create note for self
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            Map<String, Object> userInfo = (Map<String, Object>) tokenInfo.get("userInfo");
            Integer userId = (Integer) userInfo.get("userId");
            
            // Format the content as a comprehensive note
            String noteContent = buildMoodleNoteContent(title, content, materialType, exportType, courseId);
            
            // Create the note using core_notes_create_notes
            String url = moodleBaseUrl + "/webservice/rest/server.php";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            StringBuilder requestBody = new StringBuilder();
            requestBody.append("wstoken=").append(token);
            requestBody.append("&wsfunction=core_notes_create_notes");
            requestBody.append("&moodlewsrestformat=json");
            requestBody.append("&notes[0][userid]=").append(userId);
            requestBody.append("&notes[0][publishstate]=course"); // Make it course-level so other teachers can see
            requestBody.append("&notes[0][courseid]=").append(courseId);
            requestBody.append("&notes[0][text]=").append(URLEncoder.encode(noteContent, StandardCharsets.UTF_8));
            requestBody.append("&notes[0][format]=1"); // HTML format
            
            logger.info("🔧 Creating note with request body length: {}", requestBody.length());
            
            HttpEntity<String> request = new HttpEntity<>(requestBody.toString(), headers);
            
            ResponseEntity<String> response = restTemplate.postForEntity(url, request, String.class);
            
            logger.info("🔧 Note creation response status: {}", response.getStatusCode());
            logger.info("🔧 Note creation response: {}", response.getBody());
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (jsonResponse.has("exception")) {
                    String error = jsonResponse.path("message").asText();
                    logger.error("❌ Moodle notes API error: {}", error);
                    
                    // Final fallback: provide instructions for manual creation
                    return createManualInstructionsResponse(materialData, courseId);
                }
                
                // Success - note created
                Map<String, Object> noteInfo = new HashMap<>();
                noteInfo.put("noteId", jsonResponse.isArray() && jsonResponse.size() > 0 ? 
                           jsonResponse.get(0).path("id").asText() : "created");
                noteInfo.put("exportType", "course_note");
                noteInfo.put("courseId", courseId);
                noteInfo.put("url", moodleBaseUrl + "/notes/index.php?course=" + courseId);
                noteInfo.put("title", title);
                noteInfo.put("accessInstructions", "Access via Course > Participants > Notes or Navigation block");
                
                return createSuccessResponse(
                    "Material exported as course note in Moodle. Access via Course Notes section.", 
                    noteInfo
                );
            } else {
                logger.error("❌ HTTP error creating note: {}", response.getStatusCode());
                return createManualInstructionsResponse(materialData, courseId);
            }
            
        } catch (Exception e) {
            logger.error("❌ Error creating Moodle note: {}", e.getMessage(), e);
            return createManualInstructionsResponse(materialData, courseId);
        }
    }

