     */
    @DeleteMapping("/session/{sessionId}")
    public ResponseEntity<Map<String, Object>> deleteChatSession(
            @RequestHeader("Authorization") String authHeader,
            @PathVariable String sessionId) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                return ResponseEntity.badRequest().body(createErrorResponse("Invalid authentication token"));
            }

            logger.info("🔧 Deleting teacher chat session: {}", sessionId);

            Map<String, Object> result = cailaService.deleteTeacherChatSession(token, sessionId);
            
            if ((Boolean) result.get("success")) {
                return ResponseEntity.ok(result);
            } else {
                return ResponseEntity.badRequest().body(result);
            }

        } catch (Exception e) {
            logger.error("❌ Delete chat session failed", e);
            return ResponseEntity.internalServerError().body(createErrorResponse("Failed to delete session: " + e.getMessage()));
        }
    }

    // Helper methods
    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> response = new HashMap<>();
        response.put("success", false);
        response.put("error", error);
        return response;
    }
}
