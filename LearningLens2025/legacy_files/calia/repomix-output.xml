    /**
     * Share file with teacher
     */
    private Map<String, Object> shareFileWithTeacher(String accessToken, String fileId, String teacherEmail) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);

            Map<String, Object> permission = Map.of(
                "type", "user",
                "role", "reader",
                "emailAddress", teacherEmail,
                "sendNotificationEmail", false
            );

            HttpEntity<Map<String, Object>> entity = new HttpEntity<>(permission, headers);

            ResponseEntity<Map> shareResponse = restTemplate.exchange(
                "https://www.googleapis.com/drive/v3/files/" + fileId + "/permissions",
                HttpMethod.POST, entity, Map.class
            );

            if (shareResponse.getStatusCode() == HttpStatus.OK) {
                Map<String, Object> responseBody = shareResponse.getBody();
                return Map.of(
                    "success", true,
                    "permissionId", responseBody != null ? responseBody.get("id") : "unknown",
                    "teacherEmail", teacherEmail,
                    "fileId", fileId
                );
            } else {
                return Map.of("success", false, "error", "Share API returned status: " + shareResponse.getStatusCode());
            }

        } catch (Exception e) {
            return Map.of("success", false, "error", e.getMessage());
        }
    }

