    /**
     * Generate Moodle activity URL
     */
    private String getMoodleActivityUrl(String courseId, String cmId, String activityType) {
        if (cmId != null && !cmId.trim().isEmpty() && !cmId.equals("0")) {
            // Use course module ID for direct access
            return moodleBaseUrl + "/mod/" + activityType + "/view.php?id=" + cmId;
        } else {
            // Fallback to course page
            return moodleBaseUrl + "/course/view.php?id=" + courseId;
        }
    }

    /**
     * Format content for Moodle HTML display
     */
    private String formatContentForMoodle(String content, String materialType) {
        if (content == null || content.trim().isEmpty()) {
            return "<p>Generated by CAILA AI Assistant</p>";
        }
        
        StringBuilder html = new StringBuilder();
        
        // Add header
        html.append("<div style='border: 2px solid #0066cc; padding: 15px; margin-bottom: 20px; background-color: #f0f8ff;'>");
        html.append("<h3 style='color: #0066cc; margin: 0;'>📚 ").append(materialType.toUpperCase()).append(" - Generated by CAILA AI</h3>");
        html.append("<p style='margin: 5px 0 0 0; font-style: italic;'>Generated on: ").append(LocalDateTime.now().format(DateTimeFormatter.ofPattern("MMM dd, yyyy 'at' HH:mm"))).append("</p>");
        html.append("</div>");
        
        // Convert plain text to HTML with basic formatting
        String[] lines = content.split("\n");
        boolean inList = false;
        
        for (String line : lines) {
            line = line.trim();
            
            if (line.isEmpty()) {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<br>");
                continue;
            }
            
            // Headers
            if (line.startsWith("# ")) {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<h2>").append(escapeHtml(line.substring(2))).append("</h2>");
            } else if (line.startsWith("## ")) {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<h3>").append(escapeHtml(line.substring(3))).append("</h3>");
            } else if (line.startsWith("### ")) {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<h4>").append(escapeHtml(line.substring(4))).append("</h4>");
            }
            // Bold text
            else if (line.startsWith("**") && line.endsWith("**") && line.length() > 4) {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<p><strong>").append(escapeHtml(line.substring(2, line.length() - 2))).append("</strong></p>");
            }
            // List items
            else if (line.startsWith("- ") || line.startsWith("• ") || line.matches("^\\d+\\.\\s.*")) {
                if (!inList) {
                    html.append("<ul>");
                    inList = true;
                }
                String listContent = line.replaceFirst("^[-•]\\s*|^\\d+\\.\\s*", "");
                html.append("<li>").append(escapeHtml(listContent)).append("</li>");
            }
            // Regular paragraphs
            else {
                if (inList) {
                    html.append("</ul>");
                    inList = false;
                }
                html.append("<p>").append(escapeHtml(line)).append("</p>");
            }
        }
        
        if (inList) {
            html.append("</ul>");
        }
        
        // Add footer
        html.append("<div style='border-top: 1px solid #ccc; padding-top: 15px; margin-top: 20px; font-size: 12px; color: #666;'>");
        html.append("<p><em>This content was generated by CAILA AI Assistant and exported to Moodle.</em></p>");
        html.append("</div>");
        
        return html.toString();
    }

    /**
     * Extract instructions from assignment content
     */
    private String extractInstructionsFromContent(String content) {
        if (content == null || content.trim().isEmpty()) {
            return "Complete this assignment as described.";
        }
        
        // Try to extract the first few meaningful lines as instructions
        String[] lines = content.split("\n");
        StringBuilder instructions = new StringBuilder();
        
        for (String line : lines) {
            line = line.trim();
            if (!line.isEmpty() && instructions.length() < 500) { // Limit length
                instructions.append(line).append("\n");
            }
            if (instructions.length() >= 300) { // Reasonable length for instructions
                break;
            }
        }
        
        return formatContentForMoodle(instructions.toString(), "assignment");
    }

    /**
     * Parse quiz content to extract questions (basic implementation)
     */
    private Map<String, Object> parseQuizContent(String content) {
        Map<String, Object> quizInfo = new HashMap<>();
        List<String> questions = new ArrayList<>();
        
        if (content != null) {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.trim().matches("^\\d+\\..*|^Question \\d+:.*|^\\*\\*Question.*")) {
                    questions.add(line.trim());
                }
            }
        }
        
        quizInfo.put("questions", questions);
        quizInfo.put("questionCount", questions.size());
        
        return quizInfo;
    }

    /**
     * Escape HTML special characters
     */
    private String escapeHtml(String text) {
        if (text == null) return "";
        return text.replace("&", "&amp;")
                  .replace("<", "&lt;")
                  .replace(">", "&gt;")
                  .replace("\"", "&quot;")
                  .replace("'", "&#39;");
    }

    /**
     * Helper method to create success response
     */
    private Map<String, Object> createSuccessResponse(String message, Object data) {
        Map<String, Object> response = new HashMap<>();
        response.put("success", true);
        response.put("message", message);
        response.put("data", data);
        response.put("platform", "moodle");
        return response;
    }

    /**
     * Helper method to create error response
     */
    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> response = new HashMap<>();
        response.put("success", false);
        response.put("error", error);
        response.put("platform", "moodle");
        return response;
    }
}
