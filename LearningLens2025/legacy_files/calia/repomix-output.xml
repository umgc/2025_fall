            Map<String, Object> data = (Map<String, Object>) sessionData.get("data");
            List<Map<String, Object>> messages = (List<Map<String, Object>>) data.get("messages");
            
            // Extract material content from conversation
            String materialContent = extractMaterialFromConversation(messages, materialType);
            
            if (materialContent == null || materialContent.trim().isEmpty()) {
                // If no material found in conversation, generate from context
                String conversationSummary = summarizeConversation(messages, materialType);
