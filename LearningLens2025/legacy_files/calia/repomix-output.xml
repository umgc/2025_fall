package com.focusedai.caila_service.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders; // Make sure this is Spring's HttpHeaders
import org.springframework.http.HttpMethod;
import org.springframework.http.HttpStatus;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.util.LinkedMultiValueMap;
import org.springframework.util.MultiValueMap;
import org.springframework.web.client.RestTemplate;

import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.Map;
import java.util.HashMap;
import java.util.concurrent.ConcurrentHashMap;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;

import com.fasterxml.jackson.databind.ObjectMapper;
import java.util.HashMap;


@Service
public class AuthService {
    private final RestTemplate restTemplate = new RestTemplate();
    private final Map<String, Map<String, Object>> tokenStore = new ConcurrentHashMap<>();
    
    @Value("${lms.moodle.base-url:http://18.188.18.80/moodle}")
    private String moodleBaseUrl;
    
    @Value("${lms.moodle.service-name:fai_moodle}")
    private String moodleServiceName;
    
    @Value("${lms.google.client-id:}")
    private String googleClientId;
    
    @Value("${lms.google.client-secret:}")
    private String googleClientSecret;
    
    @Value("${lms.google.redirect-uri:http://localhost:8080/oauth-callback.html}")
    private String googleRedirectUri;

    @Autowired
    private CourseTeacherMappingService courseTeacherMappingService;

    // Google OAuth Scopes needed for Classroom, Drive, and Forms
    private static final String GOOGLE_SCOPES = String.join(" ", 
    "https://www.googleapis.com/auth/classroom.courses.readonly",
    "https://www.googleapis.com/auth/classroom.coursework.students",
    "https://www.googleapis.com/auth/classroom.rosters.readonly",
    "https://www.googleapis.com/auth/classroom.student-submissions.students.readonly",
    "https://www.googleapis.com/auth/classroom.courseworkmaterials",
    "https://www.googleapis.com/auth/classroom.coursework.me",
    "https://www.googleapis.com/auth/classroom.rosters", // This is key for teacher emails
    "https://www.googleapis.com/auth/classroom.profile.emails", // This is critical
    "https://www.googleapis.com/auth/drive.file",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/forms.body",
    "https://www.googleapis.com/auth/forms.responses.readonly",
    "https://www.googleapis.com/auth/userinfo.email",
    "https://www.googleapis.com/auth/userinfo.profile"
);

    // Moodle Authentication
    public Map<String, Object> authenticateMoodle(String username, String password) {
    try {
        System.out.println("🔧 Moodle auth attempt - Username: " + username);
        System.out.println("🔧 Moodle URL: " + moodleBaseUrl);
        System.out.println("🔧 Service name: " + moodleServiceName);
        
        String url = String.format("%s/login/token.php?username=%s&password=%s&service=%s",
                moodleBaseUrl, username, password, moodleServiceName);
        
        System.out.println("🔧 Full Moodle URL: " + url);

        // Use ResponseEntity to get proper type handling
        ResponseEntity<String> responseEntity = restTemplate.getForEntity(url, String.class);
        
        if (responseEntity.getStatusCode() == HttpStatus.OK) {
            String responseBody = responseEntity.getBody();
            System.out.println("🔧 Moodle response body: " + responseBody);
            
            // Parse JSON manually using ObjectMapper for better type control
            try {
                ObjectMapper objectMapper = new ObjectMapper();
                @SuppressWarnings("unchecked")
                Map<String, Object> response = objectMapper.readValue(responseBody, Map.class);
                
                System.out.println("🔧 Parsed response: " + response);
                
                if (response != null && response.containsKey("token")) {
                    String token = (String) response.get("token");
                    System.out.println("🔧 Token received: " + token.substring(0, Math.min(10, token.length())) + "...");
                    
                    Map<String, Object> validationResult = validateMoodleToken(token);
                    System.out.println("🔧 Validation result: " + validationResult);
                    
                    if ((Boolean) validationResult.get("valid")) {
                        Map<String, Object> tokenInfo = new HashMap<>();
                        tokenInfo.put("token", token);
                        tokenInfo.put("platform", "moodle");
                        tokenInfo.put("username", username);
                        tokenInfo.put("timestamp", System.currentTimeMillis());
                        tokenInfo.put("userInfo", validationResult.get("userInfo"));
                        
                        tokenStore.put(token, tokenInfo);
                        
                        Map<String, Object> successResponse = new HashMap<>();
                        successResponse.put("success", true);
                        successResponse.put("token", token);
                        successResponse.put("platform", "moodle");
                        successResponse.put("userInfo", validationResult.get("userInfo"));
                        
                        System.out.println("🔧 Sending success response: " + successResponse);
                        return successResponse;
                    } else {
                        System.out.println("🔧 Token validation failed");
                        Map<String, Object> errorResponse = new HashMap<>();
                        errorResponse.put("success", false);
                        errorResponse.put("error", "Token validation failed: " + validationResult.get("error"));
                        return errorResponse;
                    }
                } else if (response != null && response.containsKey("error")) {
                    // Handle Moodle error response
                    String errorMessage = (String) response.get("error");
                    System.out.println("🔧 Moodle returned error: " + errorMessage);
                    Map<String, Object> errorResponse = new HashMap<>();
                    errorResponse.put("success", false);
                    errorResponse.put("error", "Moodle error: " + errorMessage);
                    return errorResponse;
                } else {
                    System.out.println("🔧 Unexpected response format: " + response);
                    Map<String, Object> errorResponse = new HashMap<>();
                    errorResponse.put("success", false);
                    errorResponse.put("error", "Unexpected response format from Moodle");
                    return errorResponse;
                }
            } catch (Exception jsonEx) {
                System.out.println("🔧 JSON parsing failed, response body: " + responseBody);
                System.out.println("🔧 JSON parsing exception: " + jsonEx.getMessage());
                jsonEx.printStackTrace();
                Map<String, Object> errorResponse = new HashMap<>();
                errorResponse.put("success", false);
                errorResponse.put("error", "Invalid response format from Moodle: " + jsonEx.getMessage());
                return errorResponse;
            }
        }
        
        // Handle non-200 HTTP status codes
        System.out.println("🔧 HTTP error: " + responseEntity.getStatusCode());
        Map<String, Object> errorResponse = new HashMap<>();
        errorResponse.put("success", false);
