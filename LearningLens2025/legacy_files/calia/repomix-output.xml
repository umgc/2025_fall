     * Find student chat files accessible to teacher
     */
    private List<Map<String, Object>> findStudentChatFilesForTeacher(String token, String courseId, String studentId) {
        List<Map<String, Object>> studentFiles = new ArrayList<>();
        
        try {
            List<Map<String, Object>> allFiles = getAllAccessibleFiles(token);
            String courseIdSanitized = sanitizeForDrive(courseId);
            String studentIdSanitized = sanitizeEmailForDrive(studentId);
            
            for (Map<String, Object> file : allFiles) {
                String fileName = (String) file.get("name");
                String fileId = (String) file.get("id");
                
                if (fileName != null && fileId != null &&
                    fileName.startsWith("CAILA_Chat_") && 
                    fileName.contains(courseIdSanitized) && 
                    fileName.contains(studentIdSanitized)) {
                    
                    if (verifyTeacherAccess(token, fileId)) {
                        studentFiles.add(file);
                    }
                }
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error finding student chat files: " + e.getMessage());
            e.printStackTrace();
        }
        
        return studentFiles;
    }

