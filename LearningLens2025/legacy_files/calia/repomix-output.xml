    // Get user ID directly from token instead of searching
    private Integer getUserIdFromToken(String token) {
        try {
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo != null) {
                Map<String, Object> userInfo = (Map<String, Object>) tokenInfo.get("userInfo");
                if (userInfo != null) {
                    Object userId = userInfo.get("userId");
                    if (userId != null) {
                        if (userId instanceof Integer) {
                            return (Integer) userId;
                        } else if (userId instanceof String) {
                            try {
                                return Integer.parseInt((String) userId);
                            } catch (NumberFormatException e) {
                                logger.warn("🔧 Moodle: Could not parse userId as integer: {}", userId);
                            }
                        }
                    }
                }
            }
            return null;
        } catch (Exception e) {
            logger.error("❌ Moodle: Error getting user ID from token", e);
            return null;
        }
    }

