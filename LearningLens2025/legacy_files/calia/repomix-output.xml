    private String findOrCreateTeacherChatSession(String teacherToken, Integer teacherUserId, 
                                                String courseId, String materialType) {
        try {
            // Look for existing session for this material type today
            String today = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd"));
            String sessionPrefix = "CAILA_Teacher_" + materialType + "_" + today;
            
            List<Map<String, Object>> existingNotes = getTeacherChatNotes(teacherToken, teacherUserId);
            
            for (Map<String, Object> note : existingNotes) {
                String content = (String) note.get("content");
                if (content != null && content.contains(sessionPrefix)) {
                    return extractSessionIdFromContent(content);
                }
            }
            
            // Create new session
            String sessionId = "teacher_" + System.currentTimeMillis();
            String sessionContent = buildTeacherChatHeader(teacherUserId.toString(), courseId, materialType, sessionId);
            
            boolean created = createTeacherChatNote(teacherToken, teacherUserId, Integer.parseInt(courseId), sessionContent);
            if (created) {
                return sessionId;
            }
            
            return null;
            
        } catch (Exception e) {
            logger.error("❌ Error finding/creating teacher chat session", e);
            return null;
        }
    }

    private String buildTeacherChatHeader(String teacherId, String courseId, String materialType, String sessionId) {
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
        StringBuilder header = new StringBuilder();
        
        header.append("CAILA Teacher Chat Session\n");
        header.append("=".repeat(50)).append("\n");
        header.append("Teacher ID: ").append(teacherId).append("\n");
        header.append("Course ID: ").append(courseId).append("\n");
        header.append("Material Type: ").append(materialType).append("\n");
        header.append("Session ID: ").append(sessionId).append("\n");
        header.append("Created: ").append(timestamp).append("\n");
        header.append("=".repeat(50)).append("\n\n");
        
        return header.toString();
    }

    private String formatTeacherChatEntry(String prompt, String response) {
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
        StringBuilder entry = new StringBuilder();
        
        entry.append("[").append(timestamp).append("]\n");
        entry.append("TEACHER: ").append(prompt).append("\n\n");
        entry.append("CAILA: ").append(response).append("\n\n");
        entry.append("-".repeat(50)).append("\n\n");
        
        return entry.toString();
    }

    private List<Map<String, Object>> getTeacherChatNotes(String teacherToken, Integer teacherUserId) {
        try {
            logger.info("🔧 Moodle: Getting teacher chat notes for user ID: {}", teacherUserId);
            
            String url = String.format("%s/webservice/rest/server.php?wstoken=%s&wsfunction=core_notes_get_course_notes&courseid=1&userid=%d&moodlewsrestformat=json",
                moodleBaseUrl, teacherToken, teacherUserId);
            
            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (jsonResponse.has("exception")) {
                    logger.error("❌ Moodle: Notes API error: {}", jsonResponse.path("message").asText());
                    return Collections.emptyList();
                }
                
                List<Map<String, Object>> teacherChatNotes = new ArrayList<>();
                
                // Check all note types for teacher chat sessions
                JsonNode[] noteArrays = {jsonResponse.path("personalnotes"), jsonResponse.path("coursenotes"), jsonResponse.path("sitenotes")};
                String[] noteTypes = {"personal", "course", "site"};
                
                for (int i = 0; i < noteArrays.length; i++) {
                    JsonNode noteArray = noteArrays[i];
                    String noteType = noteTypes[i];
                    
                    if (noteArray.isArray()) {
                        for (JsonNode note : noteArray) {
                            String content = note.path("content").asText();
                            
                            if (content.contains("CAILA Teacher Chat Session")) {
                                Map<String, Object> noteMap = new HashMap<>();
                                noteMap.put("id", note.path("id").asInt());
                                noteMap.put("content", content);
                                noteMap.put("userid", note.path("userid").asInt());
                                noteMap.put("lastmodified", note.path("lastmodified").asLong());
                                noteMap.put("noteType", noteType);
                                teacherChatNotes.add(noteMap);
                                
                                logger.info("✅ Found teacher chat note - ID: {}, Type: {}", 
                                           note.path("id").asInt(), noteType);
                            }
                        }
                    }
                }
                
                logger.info("🔧 Moodle: Total teacher chat notes found: {}", teacherChatNotes.size());
                return teacherChatNotes;
            }
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to get teacher chat notes", e);
        }
        
        return Collections.emptyList();
    }

    private boolean createTeacherChatNote(String teacherToken, Integer teacherUserId, Integer courseId, String content) {
        try {
            logger.info("🔧 Moodle: Creating teacher chat note for user: {} in course: {}", teacherUserId, courseId);
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            // Create as personal note (teachers can see their own notes)
            String requestBody = String.format(
                "wstoken=%s&wsfunction=core_notes_create_notes&moodlewsrestformat=json&notes[0][userid]=%d&notes[0][publishstate]=personal&notes[0][courseid]=%d&notes[0][text]=%s&notes[0][format]=1",
                teacherToken, teacherUserId, courseId, URLEncoder.encode(content, StandardCharsets.UTF_8)
            );
            
            HttpEntity<String> request = new HttpEntity<>(requestBody, headers);
            ResponseEntity<String> response = restTemplate.postForEntity(
                moodleBaseUrl + "/webservice/rest/server.php", request, String.class
            );
            
            if (response.getStatusCode() == HttpStatus.OK) {
                try {
                    JsonNode responseJson = objectMapper.readTree(response.getBody());
                    if (responseJson.has("exception")) {
                        logger.error("❌ Moodle: Teacher note creation failed: {}", responseJson.path("message").asText());
                        return false;
                    }
                    
                    logger.info("✅ Moodle: Teacher chat note created successfully");
                    return true;
                } catch (Exception parseError) {
                    logger.warn("🔧 Could not parse response as JSON, assuming success");
                    return true;
                }
            }
            
            return false;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to create teacher chat note", e);
            return false;
        }
    }

    private boolean appendToTeacherChatSession(String teacherToken, Integer teacherUserId, Integer courseId, 
                                             String sessionId, String newContent) {
        try {
            // Find existing note for this session
            Map<String, Object> sessionNote = findTeacherChatNoteBySessionId(teacherToken, teacherUserId, sessionId);
            if (sessionNote != null) {
                String existingContent = (String) sessionNote.get("content");
                String updatedContent = existingContent + newContent;
                
                // Since Moodle doesn't allow note updating, create a new note with updated content
                Integer noteId = (Integer) sessionNote.get("id");
                deleteMoodleNote(teacherToken, noteId); // Delete old note
                
                return createTeacherChatNote(teacherToken, teacherUserId, courseId, updatedContent);
            }
            
            return false;
            
        } catch (Exception e) {
            logger.error("❌ Error appending to teacher chat session", e);
            return false;
        }
    }

