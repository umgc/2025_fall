    // Helper method to clean HTML descriptions
    private String cleanHtmlDescription(String htmlDescription) {
        if (htmlDescription == null) return "";
        
        return htmlDescription
                .replaceAll("<br\\s*/?>", "\n")
                .replaceAll("<p>", "\n")
                .replaceAll("</p>", "\n")
                .replaceAll("<[^>]+>", "")  // Remove all HTML tags
                .replaceAll("&nbsp;", " ")
                .replaceAll("&amp;", "&")
                .replaceAll("&lt;", "<")
                .replaceAll("&gt;", ">")
                .replaceAll("&quot;", "\"")
                .replaceAll("&#39;", "'")
                .trim()
                .replaceAll("\n\n+", "\n\n");  // Remove excessive newlines
    }

