    // Get all chat logs for a student (for teacher view)
    public Map<String, Object> getChatLogs(String token, String courseId, String studentId) {
        logger.info("🔧 Moodle: Teacher retrieving chat logs for student {} in course {}", studentId, courseId);
        
        try {
            // FIXED: Instead of searching for student, get user ID from enrollment data
            Integer studentUserId = getStudentUserIdFromEnrollment(token, courseId, studentId);
            
            if (studentUserId == null) {
                logger.warn("🔧 Moodle: Student not found with ID: {}", studentId);
                return createErrorResponse("Student not found: " + studentId);
            }
            
            logger.info("🔧 Moodle: Found student {} with user ID {}", studentId, studentUserId);
            
            // Get all chat log notes for this student in this course
            List<Map<String, Object>> chatLogNotes = getChatLogNotes(token, studentUserId, Integer.parseInt(courseId));
            
            if (chatLogNotes.isEmpty()) {
                logger.info("🔧 Moodle: No chat log notes found for student {}", studentId);
                
                Map<String, Object> emptyData = new HashMap<>();
                emptyData.put("studentId", studentId);
                emptyData.put("courseId", courseId);
                emptyData.put("entries", Collections.emptyList());
                emptyData.put("totalEntries", 0);
                emptyData.put("lastUpdated", null);
                emptyData.put("platform", "moodle");
                emptyData.put("fullContent", "");
                emptyData.put("noteCount", 0);
                
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("data", emptyData);
                return result;
            }
            
            logger.info("🔧 Moodle: Found {} chat log notes for student {}", chatLogNotes.size(), studentId);
            
            // Parse all chat entries from all notes with enhanced error handling
            List<Map<String, Object>> allEntries = new ArrayList<>();
            String lastUpdated = null;
            StringBuilder fullContent = new StringBuilder();
            
            for (int i = 0; i < chatLogNotes.size(); i++) {
                Map<String, Object> note = chatLogNotes.get(i);
                String content = (String) note.get("content");
                Object timeModified = note.get("lastmodified");
                String noteType = (String) note.get("noteType");
                Integer noteId = (Integer) note.get("id");
                
                logger.info("🔧 Moodle: Processing note {} of {} - ID: {}, Type: {}, Content length: {}", 
                           i + 1, chatLogNotes.size(), noteId, noteType, content != null ? content.length() : 0);
                
                if (content != null && (content.contains("CAILA Chat Log") || content.contains("CAILA Chat Entry"))) {
                    try {
                        List<Map<String, Object>> entries = parseChatLogContentSafely(content, noteId);
                        allEntries.addAll(entries);
                        logger.info("✅ Moodle: Successfully parsed {} entries from note {}", entries.size(), noteId);
                        
                        // Build full content for raw view
                        if (fullContent.length() > 0) {
                            fullContent.append("\n\n=== NOTE ").append(noteId).append(" (").append(noteType).append(") ===\n\n");
                        }
                        fullContent.append(content);
                        
                        // Track latest update
                        if (timeModified != null) {
                            String timeStr = timeModified.toString();
                            if (lastUpdated == null || timeStr.compareTo(lastUpdated) > 0) {
                                lastUpdated = timeStr;
                            }
                        }
                        
                    } catch (Exception parseError) {
                        logger.error("❌ Moodle: Failed to parse note {} content: {}", noteId, parseError.getMessage());
                        // Continue processing other notes instead of failing completely
                    }
                } else {
                    logger.warn("🔧 Moodle: Note {} does not appear to be a CAILA chat log", noteId);
                }
            }
            
            // Sort entries by timestamp (newest first) with null safety
            allEntries.sort((a, b) -> {
                String timeA = (String) a.get("timestamp");
                String timeB = (String) b.get("timestamp");
                if (timeA == null && timeB == null) return 0;
                if (timeA == null) return 1;
                if (timeB == null) return -1;
                return timeB.compareTo(timeA);
            });
            
            // Prepare response data
            Map<String, Object> data = new HashMap<>();
            data.put("studentId", studentId);
            data.put("courseId", courseId);
            data.put("entries", allEntries);
            data.put("totalEntries", allEntries.size());
            data.put("lastUpdated", lastUpdated);
            data.put("platform", "moodle");
            data.put("fullContent", fullContent.toString());
            data.put("noteCount", chatLogNotes.size());
            data.put("studentUserId", studentUserId); // For debugging
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", data);
            
            logger.info("✅ Moodle: Successfully returning {} chat entries for student {} from {} notes", 
                       allEntries.size(), studentId, chatLogNotes.size());
            return result;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to retrieve chat logs for student {}: {}", studentId, e.getMessage(), e);
            return createErrorResponse("Failed to retrieve chat logs: " + e.getMessage());
        }
    }

    // Get chat logs for all students in a course (for teacher dashboard)
    public Map<String, Object> getAllCourseChatLogs(String token, String courseId) {
        logger.info("🔧 Moodle: Retrieving all chat logs for course {}", courseId);
        
        try {
            // Get all students enrolled in the course first
            List<Map<String, Object>> enrolledStudents = getEnrolledStudents(token, courseId);
            logger.info("🔧 Moodle: Found {} enrolled students", enrolledStudents.size());
            
            List<Map<String, Object>> studentSummaries = new ArrayList<>();
            
            for (Map<String, Object> student : enrolledStudents) {
                Integer userId = (Integer) student.get("id");
                String username = (String) student.get("username");
                String fullname = (String) student.get("fullname");
                
                if (userId != null && username != null) {
                    // Get chat log notes for this student
                    List<Map<String, Object>> studentChatNotes = getChatLogNotes(token, userId, Integer.parseInt(courseId));
                    
                    if (!studentChatNotes.isEmpty()) {
                        // Count total chat interactions
                        int totalInteractions = 0;
                        String lastUpdated = null;
                        
                        for (Map<String, Object> note : studentChatNotes) {
                            String content = (String) note.get("content");
                            Object lastModified = note.get("lastmodified");
                            
                            if (content != null && (content.contains("CAILA Chat Log") || content.contains("CAILA Chat Entry"))) {
                                List<Map<String, Object>> entries = parseChatLogContent(content);
                                totalInteractions += entries.size();
                                
                                // Track latest update
                                if (lastModified != null) {
                                    String timeStr = lastModified.toString();
                                    if (lastUpdated == null || timeStr.compareTo(lastUpdated) > 0) {
                                        lastUpdated = timeStr;
                                    }
                                }
                            }
                        }
                        
                        // Create summary for this student
                        Map<String, Object> summary = new HashMap<>();
                        summary.put("studentId", username);
                        summary.put("studentName", fullname != null ? fullname : username);
                        summary.put("userId", userId);
                        summary.put("commentCount", totalInteractions);
                        summary.put("lastUpdated", lastUpdated);
                        summary.put("noteCount", studentChatNotes.size());
                        
                        studentSummaries.add(summary);
                        logger.info("✅ Moodle: Student {} has {} chat interactions in {} notes", 
                                   username, totalInteractions, studentChatNotes.size());
                    }
                }
            }
            
            // Sort by most recent activity
            studentSummaries.sort((a, b) -> {
                String timeA = (String) a.get("lastUpdated");
                String timeB = (String) b.get("lastUpdated");
                if (timeA == null) timeA = "";
                if (timeB == null) timeB = "";
                return timeB.compareTo(timeA);
            });
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", studentSummaries);
            result.put("totalStudents", studentSummaries.size());
            result.put("courseId", courseId);
            result.put("platform", "moodle");
            
            logger.info("✅ Moodle: Returning chat summaries for {} students with chat activity", studentSummaries.size());
            return result;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to retrieve course chat logs", e);
            return createErrorResponse("Failed to retrieve course chat logs: " + e.getMessage());
        }
    }

    // Get student's own chat logs (for student view)
    public Map<String, Object> getStudentOwnChatLogs(String token, String courseId, String studentId, String assignmentId) {
        logger.info("🔧 Moodle: Student {} requesting own chat logs for course {}", studentId, courseId);
        
        try {
            // For student's own logs, use their user ID from the token
            Integer studentUserId = getUserIdFromToken(token);
            if (studentUserId == null) {
                return createErrorResponse("Could not get user ID from authentication token");
            }
            
            logger.info("🔧 Moodle: Using student's own user ID from token: {}", studentUserId);
            
            // Get chat log notes
            List<Map<String, Object>> chatLogNotes = getChatLogNotes(token, studentUserId, Integer.parseInt(courseId));
            logger.info("🔧 Moodle: Retrieved {} chat log notes", chatLogNotes.size());
            
            // FIXED: Convert notes to chatFiles format that frontend expects
            List<Map<String, Object>> chatFiles = new ArrayList<>();
            
            if (!chatLogNotes.isEmpty()) {
                // Group all chat entries from all notes
                List<Map<String, Object>> allChatEntries = new ArrayList<>();
                String latestTimestamp = null;
                
                for (Map<String, Object> note : chatLogNotes) {
                    String content = (String) note.get("content");
                    Object lastModified = note.get("lastmodified");
                    
                    if (content != null && (content.contains("CAILA Chat Log") || content.contains("CAILA Chat Entry"))) {
                        List<Map<String, Object>> entries = parseChatLogContent(content);
                        allChatEntries.addAll(entries);
                        logger.info("🔧 Moodle: Parsed {} entries from note ID {}", entries.size(), note.get("id"));
                        
                        // Track latest timestamp
                        if (lastModified != null) {
                            String timeStr = lastModified.toString();
                            if (latestTimestamp == null || timeStr.compareTo(latestTimestamp) > 0) {
                                latestTimestamp = timeStr;
                            }
                        }
                    }
                }
                
                // Sort entries by timestamp (newest first)
                allChatEntries.sort((a, b) -> {
                    String timeA = (String) a.get("timestamp");
                    String timeB = (String) b.get("timestamp");
                    if (timeA == null) timeA = "";
                    if (timeB == null) timeB = "";
                    return timeB.compareTo(timeA);
                });
                
                // Filter by assignment if specified
                if (assignmentId != null && !assignmentId.isEmpty()) {
                    allChatEntries = allChatEntries.stream()
                        .filter(entry -> assignmentId.equals(entry.get("assignmentId")))
                        .collect(ArrayList::new, (list, entry) -> list.add(entry), ArrayList::addAll);
                }
                
                // Create chatFile entry - FIXED: This was missing!
                if (!allChatEntries.isEmpty()) {
                    Map<String, Object> chatFile = new HashMap<>();
                    chatFile.put("fileId", "moodle_" + courseId + "_" + studentId);
                    chatFile.put("fileName", "CAILA_Chat_Log_" + studentId + ".txt");
                    chatFile.put("assignmentContext", extractAssignmentContext(allChatEntries));
                    chatFile.put("chatCount", allChatEntries.size());
                    chatFile.put("lastModified", latestTimestamp);
                    chatFile.put("recentChats", allChatEntries); // Include all chats for now
                    
                    chatFiles.add(chatFile);
                    logger.info("✅ Moodle: Created chatFile with {} entries", allChatEntries.size());
                }
            }
            
            // Format response for student view
            Map<String, Object> studentDataMap = new HashMap<>();
            studentDataMap.put("studentId", studentId);
            studentDataMap.put("courseId", courseId);
            studentDataMap.put("assignmentId", assignmentId);
            studentDataMap.put("chatFiles", chatFiles);
            studentDataMap.put("totalFiles", chatFiles.size());
            studentDataMap.put("platform", "moodle");
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("data", studentDataMap);
            
            logger.info("✅ Moodle: Returning {} chat files to student", chatFiles.size());
            return result;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to retrieve student's own chat logs", e);
            return createErrorResponse("Failed to retrieve chat logs: " + e.getMessage());
        }
    }

