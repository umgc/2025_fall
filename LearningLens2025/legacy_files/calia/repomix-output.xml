        e.printStackTrace();
        return null;
    }
}


    private String findExistingChatFileSimple(String accessToken, String courseId, String studentId) {
    try {
        String baseFileName = generateChatFileBaseName(courseId, studentId);
        
        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + accessToken);
        HttpEntity<String> entity = new HttpEntity<>(headers);
        
        // Search with explicit filters to avoid trashed files and improve accuracy
        String searchQuery = URLEncoder.encode("name contains '" + baseFileName + "' and trashed=false", StandardCharsets.UTF_8);
        String url = "https://www.googleapis.com/drive/v3/files?" +
                    "q=" + searchQuery +
                    "&fields=files(id,name,createdTime,trashed)" +
                    "&pageSize=50" +
                    "&orderBy=createdTime desc";
        
        System.out.println("🔧 Searching for existing files with base name: " + baseFileName);
        
        ResponseEntity<Map> response = restTemplate.exchange(url, HttpMethod.GET, entity, Map.class);
        
        if (response.getStatusCode() == HttpStatus.OK && response.getBody() != null) {
            @SuppressWarnings("unchecked")
            List<Map<String, Object>> files = (List<Map<String, Object>>) response.getBody().get("files");
            
            if (files != null && !files.isEmpty()) {
                System.out.println("🔧 Found " + files.size() + " potential matching files");
                
                // Look for the most recent valid file
                for (Map<String, Object> file : files) {
                    String fileName = (String) file.get("name");
                    String fileId = (String) file.get("id");
                    Boolean isTrashed = (Boolean) file.get("trashed");
                    
                    if (fileName != null && fileId != null && 
                        fileName.startsWith(baseFileName) && 
                        (isTrashed == null || !isTrashed)) {
                        
                        System.out.println("🔧 Found matching file: " + fileName + " (ID: " + fileId + ")");
                        
                        // Double-check that we can actually access this file
                        if (verifyFileExists(accessToken, fileId)) {
                            System.out.println("✅ File verified and accessible: " + fileId);
                            return fileId;
                        } else {
                            System.out.println("⚠️ File found in search but not accessible: " + fileId);
                        }
                    }
                }
                
                System.out.println("❌ No accessible files found among search results");
            } else {
                System.out.println("🔧 No matching files found in search");
            }
        } else {
            System.out.println("❌ Search request failed with status: " + response.getStatusCode());
        }
        
        return null;
    } catch (Exception e) {
        System.out.println("❌ Error finding existing chat file: " + e.getMessage());
        e.printStackTrace();
        return null;
    }
}

    private String appendToChatFile(String accessToken, String fileId, String prompt, String response) {
    try {
        System.out.println("🔧 Attempting to append to file: " + fileId);
        
        // First, verify we can read the existing content
        String existingContent = getFileContent(accessToken, fileId);
        if (existingContent == null) {
            System.out.println("❌ Cannot read existing file content, file may not exist");
            return null;
        }
        
        // Build the new entry
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
        
        StringBuilder newEntry = new StringBuilder();
        newEntry.append("\n[").append(timestamp).append("]\n");
        newEntry.append("STUDENT: ").append(prompt).append("\n\n");
        newEntry.append("CAILA: ").append(response).append("\n\n");
        newEntry.append("-".repeat(50)).append("\n");
        
        String updatedContent = existingContent + newEntry.toString();
        
        // Try to update the file content
        boolean success = updateFileContent(accessToken, fileId, updatedContent);
        
        if (success) {
            System.out.println("✅ Successfully appended to file: " + fileId);
            return fileId;
        } else {
            System.out.println("❌ Failed to append to file: " + fileId);
            return null;
        }
        
    } catch (Exception e) {
        System.out.println("❌ Error appending to chat file: " + e.getMessage());
        e.printStackTrace();
        return null;
    }
}

