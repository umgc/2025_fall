                                System.out.println("⏭️ Skipped non-gradeable activity: " + module.get("name") + " (" + modname + ")");
                            }
                        }
                    }
                }
            }

            System.out.println("🔧 Total activities parsed with content: " + assignments.size());

            return Map.of(
                "success", true,
                "data", assignments,
                "count", assignments.size(),
                "platform", "moodle"
            );

        } catch (Exception e) {
