    private ConversationContext buildConversationContext(List<Map<String, Object>> messages, String materialType) {
        boolean hasPreviousMaterial = false;
        String lastMaterialContent = null;
        int messageCount = messages != null ? messages.size() : 0;
        List<String> discussedTopics = new ArrayList<>();
        
        if (messages != null) {
            for (Map<String, Object> message : messages) {
                String content = (String) message.get("content");
                if (content != null) {
                    MaterialContent detected = detectMaterialContent(content, materialType);
                    if (detected.containsMaterial && detected.confidence > 0.7) {
                        hasPreviousMaterial = true;
                        lastMaterialContent = content;
                    }
                }
            }
        }
        
        String conversationPhase = messageCount < 3 ? "initial" : 
                                  messageCount < 8 ? "development" : "refinement";
        
        return new ConversationContext(hasPreviousMaterial, lastMaterialContent, messageCount, conversationPhase, discussedTopics);
    }

