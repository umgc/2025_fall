import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.HashMap;
import java.util.Map;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

@RestController
@RequestMapping("/api/teacher-chat")
@CrossOrigin(origins = "*")
public class TeacherChatController {

    private static final Logger logger = LoggerFactory.getLogger(TeacherChatController.class);

    @Autowired
    private CailaService cailaService;

    @Autowired
    private AuthService authService;

    @Autowired
    private MaterialService materialService;

    /**
     * Enhanced conversational chat endpoint that can generate and manage materials
     */
    @PostMapping("/chat")
    public ResponseEntity<Map<String, Object>> conversationalChat(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                return ResponseEntity.badRequest().body(createErrorResponse("Invalid authentication token"));
            }

            // Extract request data
            String prompt = (String) request.get("prompt");
            String courseId = (String) request.get("courseId");
            String materialType = (String) request.get("materialType");
            String conversationMode = (String) request.getOrDefault("conversationMode", "chat");

            if (prompt == null || prompt.trim().isEmpty()) {
                return ResponseEntity.badRequest().body(createErrorResponse("Prompt is required"));
            }

            logger.info("🔧 Enhanced teacher chat request - Course: {}, Material: {}, Mode: {}", 
                       courseId, materialType, conversationMode);

            // Call enhanced conversational method that can handle both chat and generation
            var result = cailaService.conversationalChatWithMaterialGeneration(
                prompt, token, courseId, materialType, conversationMode);
            
            if (result.getStatus().equals("success")) {
                Map<String, Object> response = new HashMap<>();
                response.put("success", true);
                response.put("data", result.getData());
                return ResponseEntity.ok(response);
            } else {
                return ResponseEntity.badRequest().body(createErrorResponse(result.getMessage()));
            }

        } catch (Exception e) {
            logger.error("❌ Enhanced teacher chat failed", e);
            return ResponseEntity.internalServerError().body(createErrorResponse("Chat failed: " + e.getMessage()));
        }
    }

    /**
     * Resume chat session with enhanced material generation capabilities
     */
    @PostMapping("/resume")
    public ResponseEntity<Map<String, Object>> resumeConversationalSession(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                return ResponseEntity.badRequest().body(createErrorResponse("Invalid authentication token"));
            }

            // Extract request data
            String prompt = (String) request.get("prompt");
            String sessionId = (String) request.get("sessionId");
            String courseId = (String) request.get("courseId");
            String materialType = (String) request.get("materialType");

            if (prompt == null || prompt.trim().isEmpty()) {
                return ResponseEntity.badRequest().body(createErrorResponse("Prompt is required"));
            }

            if (sessionId == null || sessionId.trim().isEmpty()) {
                return ResponseEntity.badRequest().body(createErrorResponse("Session ID is required"));
            }

            logger.info("🔧 Resuming enhanced teacher chat session: {}", sessionId);

            // Resume enhanced chat with material generation context
            var result = cailaService.resumeConversationalChatSession(
                prompt, token, sessionId, courseId, materialType);
            
            if (result.getStatus().equals("success")) {
                Map<String, Object> response = new HashMap<>();
                response.put("success", true);
                response.put("data", result.getData());
                return ResponseEntity.ok(response);
            } else {
                return ResponseEntity.badRequest().body(createErrorResponse(result.getMessage()));
            }

        } catch (Exception e) {
            logger.error("❌ Resume enhanced chat session failed", e);
            return ResponseEntity.internalServerError().body(createErrorResponse("Resume failed: " + e.getMessage()));
        }
    }

    /**
     * Generate material from conversation context
     */
    @PostMapping("/generate-material")
    public ResponseEntity<Map<String, Object>> generateMaterialFromChat(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> request) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
