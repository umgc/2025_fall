    /**
     * Get file content
     */
    private String getFileContent(String token, String fileId) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + token);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            ResponseEntity<String> response = restTemplate.exchange(
                "https://www.googleapis.com/drive/v3/files/" + fileId + "?alt=media",
                HttpMethod.GET, entity, String.class
            );

            if (response.getStatusCode() == HttpStatus.OK) {
                return response.getBody() != null ? response.getBody() : "";
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error getting file content: " + e.getMessage());
        }
        
        return null;
    }

    /**
     * Update file content
     */
    private boolean updateFileContent(String token, String fileId, String content) {
    try {
        System.out.println("🔧 Updating file content for file: " + fileId);
        System.out.println("🔧 Content length: " + content.length() + " characters");
        
        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + token);
        headers.setContentType(MediaType.TEXT_PLAIN);
        headers.set("Content-Type", "text/plain; charset=UTF-8");
        
        HttpEntity<String> entity = new HttpEntity<>(content, headers);
        
        // Use PUT for media uploads as specified in Google Drive API
        String url = "https://www.googleapis.com/upload/drive/v3/files/" + fileId + "?uploadType=media";
        
        ResponseEntity<Map> response = restTemplate.exchange(
            url, HttpMethod.PUT, entity, Map.class
        );
        
        if (response.getStatusCode() == HttpStatus.OK) {
            System.out.println("✅ File content updated successfully");
            return true;
        } else {
            System.out.println("❌ Failed to update file, status: " + response.getStatusCode());
            if (response.getBody() != null) {
                System.out.println("❌ Response body: " + response.getBody());
            }
        }
        
        return false;
        
    } catch (Exception e) {
        System.out.println("❌ Error updating file content: " + e.getMessage());
        
        // Check if it's a 404 error specifically
        if (e.getMessage() != null && e.getMessage().contains("404")) {
            System.out.println("❌ File not found (404) - the file ID may be invalid or deleted");
        }
        
        e.printStackTrace();
        return false;
    }
}

    private boolean verifyFileExists(String accessToken, String fileId) {
    try {
        if (fileId == null || fileId.trim().isEmpty()) {
            return false;
        }
        
        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + accessToken);
        HttpEntity<String> entity = new HttpEntity<>(headers);

        ResponseEntity<Map> response = restTemplate.exchange(
            "https://www.googleapis.com/drive/v3/files/" + fileId + "?fields=id,name,trashed",
            HttpMethod.GET, entity, Map.class
        );

        if (response.getStatusCode() == HttpStatus.OK && response.getBody() != null) {
            Map<String, Object> fileInfo = response.getBody();
            Boolean isTrashed = (Boolean) fileInfo.get("trashed");
            // File exists and is not trashed
            return isTrashed == null || !isTrashed;
        }
        
        return false;
    } catch (Exception e) {
        System.out.println("❌ Error verifying file existence for ID " + fileId + ": " + e.getMessage());
        return false;
    }
}

