        @PathVariable String courseId,
        @PathVariable String studentId,
        @RequestHeader("Authorization") String authHeader) {
    
    try {
        String token = authHeader.replace("Bearer ", "");
        Map<String, Object> tokenInfo = authService.getTokenInfo(token);
        
        // FIXED: Add null safety for the "valid" field
        if (tokenInfo == null) {
            logger.warn("🔧 ChatLogController: Invalid token for teacher viewing student logs");
            return ResponseEntity.status(401).body(createErrorResponse("Invalid authentication token"));
        }
        
        // Check if token info has valid field, if not assume it's valid (since it exists in store)
        Boolean isValid = (Boolean) tokenInfo.get("valid");
        if (isValid != null && !isValid) {
            logger.warn("🔧 ChatLogController: Token marked as invalid");
            return ResponseEntity.status(401).body(createErrorResponse("Token is not valid"));
        }
        
        String platform = (String) tokenInfo.get("platform");
        Map<String, Object> userInfo = (Map<String, Object>) tokenInfo.get("userInfo");
        String teacherName = extractTeacherName(userInfo);
        
        logger.info("🔧 ChatLogController: Teacher {} requesting chat logs for student {} in course {} (platform: {})", 
                   teacherName, studentId, courseId, platform);
        
        Map<String, Object> result;
        
        if ("moodle".equals(platform)) {
            try {
                result = moodleChatService.getChatLogs(token, courseId, studentId);
                
                // Enhanced error handling for Moodle
                if (!(Boolean) result.get("success")) {
                    String error = (String) result.get("error");
                    logger.error("🔧 Moodle: Chat logs retrieval failed for student {}: {}", studentId, error);
                    
                    if (error != null && error.toLowerCase().contains("not found")) {
                        // Student not found - provide helpful response
                        Map<String, Object> notFoundData = new HashMap<>();
                        notFoundData.put("studentId", studentId);
                        notFoundData.put("courseId", courseId);
                        notFoundData.put("entries", Collections.emptyList());
                        notFoundData.put("totalEntries", 0);
                        notFoundData.put("lastUpdated", null);
                        notFoundData.put("platform", "moodle");
                        notFoundData.put("fullContent", "");
                        notFoundData.put("errorType", "student_not_found");
                        
                        Map<String, Object> notFoundResult = new HashMap<>();
                        notFoundResult.put("success", true);
                        notFoundResult.put("data", notFoundData);
                        notFoundResult.put("message", "Student '" + studentId + "' not found in this course");
                        
                        return ResponseEntity.ok(notFoundResult);
                    } else if (error != null && error.toLowerCase().contains("access")) {
                        // Permission issue
                        Map<String, Object> permissionData = new HashMap<>();
                        permissionData.put("studentId", studentId);
                        permissionData.put("courseId", courseId);
                        permissionData.put("entries", Collections.emptyList());
                        permissionData.put("totalEntries", 0);
                        permissionData.put("lastUpdated", null);
                        permissionData.put("platform", "moodle");
                        permissionData.put("fullContent", "");
                        permissionData.put("errorType", "permission_denied");
                        
                        Map<String, Object> permissionResult = new HashMap<>();
                        permissionResult.put("success", true);
                        permissionResult.put("data", permissionData);
                        permissionResult.put("message", "Permission denied accessing student notes");
                        
                        return ResponseEntity.ok(permissionResult);
                    } else {
                        // Generic error - still provide structured response
                        return ResponseEntity.status(500).body(createErrorResponse("Failed to retrieve chat logs: " + error));
                    }
                }
                
                // Success case - add teacher context info
                Map<String, Object> data = (Map<String, Object>) result.get("data");
                if (data != null) {
                    data.put("requestedBy", teacherName);
                    data.put("requestedAt", new Date().toString());
                }
                
                logger.info("✅ ChatLogController: Successfully retrieved {} chat entries for student {} (requested by teacher {})", 
                           data != null ? data.get("totalEntries") : 0, studentId, teacherName);
                
            } catch (Exception moodleError) {
                logger.error("❌ ChatLogController: Exception in Moodle chat logs retrieval for student {}: {}", 
                           studentId, moodleError.getMessage(), moodleError);
                
                // Provide structured error response instead of generic failure
                Map<String, Object> errorData = new HashMap<>();
                errorData.put("studentId", studentId);
                errorData.put("courseId", courseId);
                errorData.put("entries", Collections.emptyList());
                errorData.put("totalEntries", 0);
                errorData.put("lastUpdated", null);
                errorData.put("platform", "moodle");
                errorData.put("fullContent", "");
                errorData.put("errorType", "system_error");
                errorData.put("errorDetails", moodleError.getMessage());
                
                Map<String, Object> errorResult = new HashMap<>();
                errorResult.put("success", true); // Return success with empty data rather than error
                errorResult.put("data", errorData);
                errorResult.put("message", "Unable to retrieve chat logs due to system error");
                
                return ResponseEntity.ok(errorResult);
            }
            
        } else if ("google".equals(platform)) {
            result = googleDriveChatService.getStudentChatLogs(token, courseId, studentId, null);
        } else {
            return ResponseEntity.badRequest().body(createErrorResponse("Unsupported platform: " + platform));
        }
        
        return ResponseEntity.ok(result);
        
    } catch (Exception e) {
        logger.error("❌ ChatLogController: Error getting student chat logs for teacher", e);
        return ResponseEntity.status(500).body(createErrorResponse("Failed to retrieve student chat logs: " + e.getMessage()));
    }
}

    /**
     * Verify chat log status
     */
    @GetMapping("/verify/{courseId}/{studentId}")
    public ResponseEntity<Map<String, Object>> verifyChatLogStatus(
            @RequestHeader("Authorization") String authHeader,
            @PathVariable String courseId,
            @PathVariable String studentId) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid authentication token"
                ));
            }

            String platform = (String) tokenInfo.get("platform");
            System.out.println("🔧 Teacher verifying chat logs for student: " + studentId + " in course: " + courseId);
            System.out.println("🔧 Platform: " + platform);

            Map<String, Object> verificationResult;
            
            if ("google".equals(platform)) {
                // Check if we have any stored metadata for this student
                Map<String, Object> debugInfo = googleDriveChatService.debugSharedFiles(courseId);
                
                verificationResult = Map.of(
                    "success", true,
                    "data", Map.of(
                        "studentId", studentId,
                        "courseId", courseId,
                        "debugInfo", debugInfo,
                        "platform", "google",
                        "hasSharedFiles", debugInfo.get("totalSharedFiles")
                    )
                );
            } else if ("moodle".equals(platform)) {
                verificationResult = Map.of(
                    "success", true,
                    "data", Map.of(
                        "studentId", studentId,
                        "courseId", courseId,
                        "platform", "moodle",
                        "hasSharedFiles", 0,
                        "message", "Chat history logging not yet available for Moodle"
                    )
                );
            } else {
                verificationResult = Map.of(
                    "success", false,
                    "error", "Verification not available for platform: " + platform
                );
            }

            return ResponseEntity.ok(verificationResult);

        } catch (Exception e) {
            System.out.println("🔧 Exception in verifyChatLogStatus: " + e.getMessage());
            e.printStackTrace();
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    /**
     * Debug course chat logs
     */
    @GetMapping("/debug/course/{courseId}")
    public ResponseEntity<Map<String, Object>> debugCourseChatLogs(
            @RequestHeader("Authorization") String authHeader,
            @PathVariable String courseId) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid authentication token"
                ));
            }

            String platform = (String) tokenInfo.get("platform");
            System.out.println("🔧 Debug request for course chat logs: " + courseId);
            System.out.println("🔧 Platform: " + platform);

            Map<String, Object> debugResult;
            
            if ("google".equals(platform)) {
                debugResult = googleDriveChatService.debugSharedFilesWithAuth(token, courseId);
            } else if ("moodle".equals(platform)) {
                debugResult = Map.of(
                    "success", true,
                    "message", "Debug info for Moodle platform",
                    "platform", "moodle",
                    "chatLogsAvailable", false,
                    "note", "Chat history logging is not yet implemented for Moodle"
                );
            } else {
                debugResult = Map.of(
                    "success", true,
                    "message", "Debug not available for platform: " + platform,
                    "platform", platform
                );
            }
            
            return ResponseEntity.ok(Map.of(
                "success", true,
                "debug", debugResult,
                "requestInfo", Map.of(
                    "courseId", courseId,
                    "platform", platform,
                    "userInfo", tokenInfo.get("userInfo"),
                    "storageType", "google".equals(platform) ? "Google Drive API" : "Platform-specific storage"
                )
            ));

        } catch (Exception e) {
            System.out.println("🔧 Exception in debugCourseChatLogs: " + e.getMessage());
            e.printStackTrace();
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    // Helper methods
    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> result = new HashMap<>();
        result.put("success", false);
        result.put("error", error);
        return result;
    }

    private String extractTeacherName(Map<String, Object> userInfo) {
        if (userInfo == null) return "Unknown Teacher";
        
        // Try different fields that might contain the teacher's name
        String[] nameFields = {"fullname", "name", "username", "email"};
        for (String field : nameFields) {
            Object value = userInfo.get(field);
            if (value != null && !value.toString().trim().isEmpty()) {
                return value.toString();
            }
        }
        return "Unknown Teacher";
    }

    private Map<String, Object> sanitizeTokenInfo(Map<String, Object> tokenInfo) {
        if (tokenInfo == null) return new HashMap<>();
        
        Map<String, Object> sanitized = new HashMap<>(tokenInfo);
        // Remove sensitive information
        sanitized.remove("token");
        sanitized.remove("refreshToken");
        sanitized.remove("privateToken");
        
        return sanitized;
    }

    private String extractStudentId(Map<String, Object> userInfo) {
        if (userInfo == null) return "unknown";
        
        // Try different fields that might contain the student identifier
        String[] fields = {"username", "email", "fullname", "id"};
        for (String field : fields) {
            Object value = userInfo.get(field);
            if (value != null) {
                return value.toString();
            }
        }
        return "unknown";
    }
}
