            String url = String.format("%s/webservice/rest/server.php?wstoken=%s&wsfunction=core_enrol_get_enrolled_users&courseid=%s&moodlewsrestformat=json",
                moodleBaseUrl, token, courseId);
            
            logger.debug("🔧 Moodle: Getting enrolled students from: {}", url);
            
            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            JsonNode root = objectMapper.readTree(response.getBody());
            
            // Check for API errors
            if (root.has("exception")) {
                logger.warn("🔧 Moodle: Error getting enrolled students: {}", root.path("message").asText());
                return Collections.emptyList();
            }
            
            List<Map<String, Object>> students = new ArrayList<>();
            
            if (root.isArray()) {
                for (JsonNode studentNode : root) {
                    Map<String, Object> student = new HashMap<>();
                    student.put("id", studentNode.path("id").asInt());
                    student.put("username", studentNode.path("username").asText());
                    student.put("fullname", studentNode.path("fullname").asText());
                    student.put("email", studentNode.path("email").asText());
                    
                    // Only include users with student-like roles (filter out teachers/admins)
                    JsonNode roles = studentNode.path("roles");
                    boolean isStudent = false;
                    if (roles.isArray()) {
                        for (JsonNode role : roles) {
                            String roleName = role.path("shortname").asText().toLowerCase();
                            if (roleName.contains("student") || roleName.contains("learner")) {
                                isStudent = true;
                                break;
                            }
                        }
                    }
                    
                    if (isStudent || roles.size() == 0) { // Include if no roles defined (fallback)
                        students.add(student);
                        logger.debug("✅ Moodle: Added student to list - ID: {}, Username: {}", 
                                    student.get("id"), student.get("username"));
                    }
                }
            }
            
            logger.info("✅ Moodle: Found {} students enrolled in course {}", students.size(), courseId);
            return students;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to get enrolled students", e);
            return Collections.emptyList();
        }
    }

    private List<Map<String, Object>> parseChatLogContentSafely(String content, Integer noteId) {
        List<Map<String, Object>> entries = new ArrayList<>();
        
        try {
            if (content == null || content.trim().isEmpty()) {
                logger.warn("🔧 Moodle: Note {} has empty content", noteId);
                return entries;
            }
            
            String[] lines = content.split("\n");
            Map<String, Object> currentEntry = null;
            StringBuilder currentText = new StringBuilder();
            String currentType = null;
            int lineNumber = 0;
            
            logger.debug("🔧 Moodle: Parsing {} lines from note {}", lines.length, noteId);
            
            for (String line : lines) {
                lineNumber++;
                line = line.trim();
                
                try {
                    if (line.startsWith("[") && line.contains("]")) {
                        // Save previous entry if exists
                        if (currentEntry != null && currentType != null && currentText.length() > 0) {
                            currentEntry.put(currentType, currentText.toString().trim());
                            if (isValidChatEntry(currentEntry)) {
                                entries.add(new HashMap<>(currentEntry)); // Create copy
                                logger.debug("✅ Moodle: Added chat entry with timestamp {}", currentEntry.get("timestamp"));
                            }
                        }
                        
                        // Start new entry
                        try {
                            String timestamp = line.substring(1, line.indexOf("]"));
                            currentEntry = new HashMap<>();
                            currentEntry.put("timestamp", timestamp);
                            currentEntry.put("noteId", noteId);
                            currentText = new StringBuilder();
                            currentType = null;
                            logger.debug("🔧 Moodle: Started new entry with timestamp: {}", timestamp);
                        } catch (Exception timestampError) {
                            logger.warn("🔧 Moodle: Failed to parse timestamp from line {}: {}", lineNumber, line);
                            currentEntry = null;
                        }
                        
                    } else if (line.startsWith("STUDENT:")) {
                        if (currentEntry != null) {
                            if (currentType != null && currentText.length() > 0) {
                                currentEntry.put(currentType, currentText.toString().trim());
                            }
                            currentType = "student";
                            currentText = new StringBuilder(line.substring(8).trim());
                            logger.debug("🔧 Moodle: Found student message in note {}", noteId);
                        }
                        
                    } else if (line.startsWith("CAILA:")) {
                        if (currentEntry != null) {
                            if (currentType != null && currentText.length() > 0) {
                                currentEntry.put(currentType, currentText.toString().trim());
                            }
                            currentType = "caila";
                            currentText = new StringBuilder(line.substring(6).trim());
                            logger.debug("🔧 Moodle: Found CAILA response in note {}", noteId);
                        }
                        
                    } else if (line.equals("---")) {
                        // End of entry marker
                        if (currentEntry != null && currentType != null && currentText.length() > 0) {
                            currentEntry.put(currentType, currentText.toString().trim());
                            if (isValidChatEntry(currentEntry)) {
                                entries.add(new HashMap<>(currentEntry)); // Create copy
                                logger.debug("✅ Moodle: Completed chat entry at line {}", lineNumber);
                            }
                        }
                        currentEntry = null;
                        currentType = null;
                        currentText = new StringBuilder();
                        
                    } else if (!line.isEmpty() && currentText != null && currentType != null) {
                        // Continue current message
                        if (currentText.length() > 0) {
                            currentText.append(" ");
                        }
                        currentText.append(line);
                    }
                    
                } catch (Exception lineError) {
                    logger.warn("🔧 Moodle: Error processing line {} in note {}: {}", lineNumber, noteId, lineError.getMessage());
                    // Continue processing other lines
                }
            }
            
            // Save final entry if exists
            if (currentEntry != null && currentType != null && currentText.length() > 0) {
                currentEntry.put(currentType, currentText.toString().trim());
                if (isValidChatEntry(currentEntry)) {
                    entries.add(currentEntry);
                    logger.debug("✅ Moodle: Added final chat entry from note {}", noteId);
                }
            }
            
            logger.info("🔧 Moodle: Successfully parsed {} chat entries from note {} ({} lines processed)", 
                       entries.size(), noteId, lines.length);
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to parse chat log content from note {}: {}", noteId, e.getMessage());
            // Return empty list instead of throwing exception
        }
        
        return entries;
    }

    private boolean isValidChatEntry(Map<String, Object> entry) {
        if (entry == null) return false;
        
        boolean hasTimestamp = entry.containsKey("timestamp") && entry.get("timestamp") != null;
        boolean hasStudent = entry.containsKey("student") && entry.get("student") != null && !entry.get("student").toString().trim().isEmpty();
        boolean hasCaila = entry.containsKey("caila") && entry.get("caila") != null && !entry.get("caila").toString().trim().isEmpty();
        
        boolean isValid = hasTimestamp && hasStudent && hasCaila;
        
        if (!isValid) {
            logger.debug("🔧 Moodle: Invalid chat entry - timestamp: {}, student: {}, caila: {}", 
                        hasTimestamp, hasStudent, hasCaila);
        }
        
        return isValid;
    }

    private String getExistingChatLogNote(String token, Integer userId, Integer courseId) {
        try {
            List<Map<String, Object>> notes = getChatLogNotes(token, userId, courseId);
            
            if (!notes.isEmpty()) {
                return (String) notes.get(0).get("content");
            }
            
            return null;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to get existing chat log note", e);
            return null;
        }
    }

    private List<Map<String, Object>> getChatLogNotes(String token, Integer userId, Integer courseId) {
        try {
            String url = String.format("%s/webservice/rest/server.php?wstoken=%s&wsfunction=core_notes_get_course_notes&courseid=%d&userid=%d&moodlewsrestformat=json",
                moodleBaseUrl, token, courseId, userId);
            
            logger.info("🔧 Moodle: Getting notes from URL: {}", url);
            
            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            logger.info("🔧 Moodle: Notes API response status: {}", response.getStatusCode());
            logger.info("🔧 Moodle: Notes API response body: {}", response.getBody());
            
            JsonNode root = objectMapper.readTree(response.getBody());
            
            // Check for API errors
            if (root.has("exception")) {
                logger.error("❌ Moodle: Notes API error: {}", root.path("message").asText());
                return Collections.emptyList();
            }
            
            List<Map<String, Object>> chatLogNotes = new ArrayList<>();
            
            // ENHANCED: Check all note types, prioritizing site notes for teacher visibility
            JsonNode[] noteArrays = {root.path("sitenotes"), root.path("personalnotes"), root.path("coursenotes")};
            String[] noteTypes = {"site", "personal", "course"};
            
            for (int i = 0; i < noteArrays.length; i++) {
                JsonNode noteArray = noteArrays[i];
                String noteType = noteTypes[i];
                
                logger.info("🔧 Moodle: Checking {} notes - found {} notes", noteType, noteArray.size());
                
                if (noteArray.isArray()) {
                    for (JsonNode note : noteArray) {
                        String content = note.path("content").asText();
                        logger.debug("🔧 Moodle: Found {} note with content length: {} - Preview: {}", 
                            noteType, content.length(), content.length() > 50 ? content.substring(0, 50) + "..." : content);
                        
                        // Check if this is a CAILA chat log
                        if (content.contains("CAILA Chat Log") || content.contains("CAILA Chat Entry")) {
                            logger.info("✅ Moodle: Found CAILA chat log note in {} notes!", noteType);
                            
                            Map<String, Object> noteMap = new HashMap<>();
                            noteMap.put("id", note.path("id").asInt());
                            noteMap.put("content", content);
                            noteMap.put("userid", note.path("userid").asInt());
                            noteMap.put("lastmodified", note.path("lastmodified").asLong());
                            noteMap.put("noteType", noteType);
                            chatLogNotes.add(noteMap);
                            
                            logger.info("🔧 Moodle: Added chat log note - ID: {}, UserID: {}, Type: {}, Content length: {}", 
                                note.path("id").asInt(), note.path("userid").asInt(), noteType, content.length());
                        } else {
                            logger.debug("🔧 Moodle: Skipping {} note - not a CAILA chat log", noteType);
                        }
                    }
                }
            }
            
            logger.info("🔧 Moodle: Total CAILA chat log notes found: {}", chatLogNotes.size());
            return chatLogNotes;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to get chat log notes", e);
            return Collections.emptyList();
        }
    }

    private Map<String, Object> createNewChatLogNote(String token, Integer userId, Integer courseId, String content) {
        try {
            logger.info("🔧 Moodle: Creating COURSE note for user {} in course {} with content length: {}", 
                userId, courseId, content.length());
            logger.debug("🔧 Moodle: Note content preview: {}", 
                content.length() > 100 ? content.substring(0, 100) + "..." : content);
            
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_FORM_URLENCODED);
            
            // FIXED: Use "site" publishstate instead of "personal" so teachers can see the notes
            // publishstate options: "personal", "course", "site"
            // "site" notes are visible to teachers in the course
            String requestBody = String.format(
                "wstoken=%s&wsfunction=core_notes_create_notes&moodlewsrestformat=json&notes[0][userid]=%d&notes[0][publishstate]=site&notes[0][courseid]=%d&notes[0][text]=%s&notes[0][format]=1",
                token, userId, courseId, URLEncoder.encode(content, StandardCharsets.UTF_8)
            );
            
            logger.debug("🔧 Moodle: Creating SITE note (visible to teachers) with request body length: {}", requestBody.length());
            
            HttpEntity<String> request = new HttpEntity<>(requestBody, headers);
            ResponseEntity<String> response = restTemplate.postForEntity(
                moodleBaseUrl + "/webservice/rest/server.php", request, String.class
            );
            
            logger.info("🔧 Moodle: Note creation response status: {}", response.getStatusCode());
            logger.info("🔧 Moodle: Note creation response: {}", response.getBody());
            
            if (response.getStatusCode() == HttpStatus.OK) {
                // Check if the response contains an error
                try {
                    JsonNode responseJson = objectMapper.readTree(response.getBody());
                    if (responseJson.has("exception")) {
                        logger.error("❌ Moodle: Note creation failed with API error: {}", responseJson.path("message").asText());
                        return createErrorResponse("Note creation API error: " + responseJson.path("message").asText());
                    }
                    
                    logger.info("✅ Moodle: SITE note created successfully! (Teachers can now see this)");
                } catch (Exception parseError) {
                    logger.warn("🔧 Moodle: Could not parse response as JSON, assuming success");
                }
                
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("message", "Chat log stored as Moodle site note (visible to teachers)");
                result.put("platform", "moodle");
                result.put("location", "Moodle site note");
                result.put("logged", true);
                return result;
            } else {
                return createErrorResponse("Failed to create note: " + response.getStatusCode());
            }
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to create new chat log note", e);
            return createErrorResponse("Note creation failed: " + e.getMessage());
        }
    }

    private Map<String, Object> updateExistingNote(String token, Integer userId, Integer courseId, String content) {
        // Note: Moodle doesn't allow updating notes directly via web service
        // So we create a new note with the updated content
        return createNewChatLogNote(token, userId, courseId, content);
    }

    private List<Map<String, Object>> parseChatLogContent(String content) {
        List<Map<String, Object>> entries = new ArrayList<>();
        
        try {
            String[] lines = content.split("\n");
            Map<String, Object> currentEntry = null;
            StringBuilder currentText = new StringBuilder();
            String currentType = null;
            
            for (String line : lines) {
                line = line.trim();
                
                if (line.startsWith("[") && line.contains("]")) {
                    // Save previous entry if exists
                    if (currentEntry != null && currentType != null) {
                        currentEntry.put(currentType, currentText.toString().trim());
                        if (currentType.equals("caila") || (currentEntry.containsKey("student") && currentEntry.containsKey("caila"))) {
                            entries.add(new HashMap<>(currentEntry)); // Create copy
                        }
                    }
                    
                    // Start new entry
                    String timestamp = line.substring(1, line.indexOf("]"));
                    currentEntry = new HashMap<>();
                    currentEntry.put("timestamp", timestamp);
                    currentText = new StringBuilder();
                    currentType = null;
                    
                } else if (line.startsWith("STUDENT:")) {
                    if (currentEntry != null && currentType != null) {
                        currentEntry.put(currentType, currentText.toString().trim());
                    }
                    currentType = "student";
                    currentText = new StringBuilder(line.substring(8).trim());
                    
                } else if (line.startsWith("CAILA:")) {
                    if (currentEntry != null && currentType != null) {
                        currentEntry.put(currentType, currentText.toString().trim());
                    }
                    currentType = "caila";
                    currentText = new StringBuilder(line.substring(6).trim());
                    
                } else if (line.equals("---")) {
                    // End of entry marker
                    if (currentEntry != null && currentType != null) {
                        currentEntry.put(currentType, currentText.toString().trim());
                        if (currentEntry.containsKey("student") && currentEntry.containsKey("caila")) {
                            entries.add(new HashMap<>(currentEntry)); // Create copy
                        }
                    }
                    currentEntry = null;
                    currentType = null;
                    currentText = new StringBuilder();
                    
                } else if (!line.isEmpty() && currentText != null && currentType != null) {
                    if (currentText.length() > 0) {
                        currentText.append(" ");
                    }
                    currentText.append(line);
                }
            }
            
            // Save final entry if exists
            if (currentEntry != null && currentType != null) {
                currentEntry.put(currentType, currentText.toString().trim());
                if (currentEntry.containsKey("student") && currentEntry.containsKey("caila")) {
                    entries.add(currentEntry);
                }
            }
            
            logger.info("🔧 Moodle: Successfully parsed {} chat entries from content", entries.size());
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Failed to parse chat log content", e);
        }
        
        return entries;
    }

    private String extractAssignmentContext(List<Map<String, Object>> entries) {
        // Look for assignment context in the student messages
        for (Map<String, Object> entry : entries) {
            String studentMsg = (String) entry.get("student");
            if (studentMsg != null && studentMsg.contains("CURRENT ASSIGNMENT:")) {
                // Try to extract assignment title
                String[] lines = studentMsg.split("\n");
                for (String line : lines) {
                    if (line.trim().startsWith("Title:")) {
                        return line.trim().substring(6).trim();
                    }
                }
            }
        }
        return "General Course Chat";
    }

    private String formatChatLogEntry(String prompt, String response) {
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME);
        return String.format(
            "[%s]\nSTUDENT: %s\nCAILA: %s\n---",
            timestamp, prompt, response
        );
    }

    private String createChatLogHeader(String studentId) {
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME);
        return String.format(
            "CAILA Chat Log for Student: %s\nCreated: %s\n===",
            studentId, timestamp
        );
    }

    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> result = new HashMap<>();
        result.put("success", false);
        result.put("error", error);
        result.put("platform", "moodle");
        return result;
    }
}
