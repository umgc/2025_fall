// File: src/main/java/com/focusedai/caila_service/service/MoodleExportService.java
package com.focusedai.caila_service.service;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.http.*;

import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.*;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;

@Service
public class MoodleExportService {
    private static final Logger logger = LoggerFactory.getLogger(MoodleExportService.class);
    private final RestTemplate restTemplate = new RestTemplate();
    private final ObjectMapper objectMapper = new ObjectMapper();
    
    @Value("${lms.moodle.base-url:http://18.188.18.80/moodle}")
    private String moodleBaseUrl;
    
    @Autowired
    private AuthService authService;

    /**
     * Export material to Moodle using available web service functions
     */
    public Map<String, Object> exportMaterialToMoodle(String token, String courseId, 
                                                     Map<String, Object> materialData) {
        try {
            logger.info("🔧 Moodle: Exporting material to course {}", courseId);
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"moodle".equals(tokenInfo.get("platform"))) {
                return createErrorResponse("Invalid Moodle authentication token");
            }
            
            String materialType = (String) materialData.get("type");
            String exportType = (String) materialData.get("exportType");
            
            logger.info("🔧 Material type: {}, Export type: {}", materialType, exportType);
            
            // Use the working approach: Enhanced course notes with conversion instructions
            return createEnhancedMoodleExport(token, courseId, materialData, exportType);
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Export failed", e);
            return createErrorResponse("Export failed: " + e.getMessage());
        }
    }

    /**
     * Create enhanced export using available Moodle functions
     */
    private Map<String, Object> createEnhancedMoodleExport(String token, String courseId, 
                                                          Map<String, Object> materialData, String exportType) {
        try {
            logger.info("🔧 Creating enhanced Moodle export");
            
            // First, try to get course structure to provide better context
            Map<String, Object> courseContext = getCourseContext(token, courseId);
            
            // Create the enhanced content with course-specific information
            String enhancedContent = buildContextAwareContent(materialData, exportType, courseId, courseContext);
            
            // Create using the notes API (which usually works)
            Map<String, Object> noteResult = createCourseNote(token, courseId, enhancedContent, materialData);
            
            if ((Boolean) noteResult.get("success")) {
                // Enhance the response with conversion information
                Map<String, Object> data = (Map<String, Object>) noteResult.get("data");
                data.put("exportType", "ready_to_convert");
                data.put("conversionSteps", getDetailedConversionSteps(exportType, courseContext));
                data.put("originalExportType", exportType);
                
                return createSuccessResponse(
                    "Assignment template created in Moodle. Ready for quick conversion to actual assignment.", 
                    data
                );
            } else {
                // Fall back to providing manual instructions
                return createDetailedManualInstructions(materialData, exportType, courseId, courseContext);
            }
            
        } catch (Exception e) {
            logger.error("❌ Enhanced export failed", e);
            return createDetailedManualInstructions(materialData, exportType, courseId, null);
        }
    }

    /**
     * Get course context information
     */
    private Map<String, Object> getCourseContext(String token, String courseId) {
        Map<String, Object> context = new HashMap<>();
        
        try {
            // Try to get course contents using a function that's usually available
            String url = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=core_course_get_contents"
                    + "&courseid=" + courseId
                    + "&moodlewsrestformat=json";
            
            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            
            if (response.getStatusCode() == HttpStatus.OK) {
                JsonNode jsonResponse = objectMapper.readTree(response.getBody());
                
                if (!jsonResponse.has("exception") && jsonResponse.isArray()) {
                    context.put("hasStructureAccess", true);
                    context.put("sectionCount", jsonResponse.size());
                    
                    // Find the best section to add activities
                    int bestSection = 0;
                    for (int i = 0; i < jsonResponse.size(); i++) {
                        JsonNode section = jsonResponse.get(i);
                        if (section.path("visible").asBoolean(true)) {
                            bestSection = i;
                            break;
                        }
                    }
                    context.put("recommendedSection", bestSection);
                    
                    // Check if course has existing assignments
                    boolean hasAssignments = false;
                    for (JsonNode section : jsonResponse) {
                        JsonNode modules = section.path("modules");
                        if (modules.isArray()) {
                            for (JsonNode module : modules) {
                                if ("assign".equals(module.path("modname").asText())) {
                                    hasAssignments = true;
                                    break;
                                }
                            }
                        }
                        if (hasAssignments) break;
                    }
                    context.put("hasExistingAssignments", hasAssignments);
                } else {
                    context.put("hasStructureAccess", false);
                }
            } else {
                context.put("hasStructureAccess", false);
            }
            
        } catch (Exception e) {
            logger.info("🔧 Could not get course context: {}", e.getMessage());
            context.put("hasStructureAccess", false);
        }
        
        // Try to check assignment capabilities
        try {
            String assignUrl = moodleBaseUrl + "/webservice/rest/server.php"
                    + "?wstoken=" + token
                    + "&wsfunction=mod_assign_get_assignments"
                    + "&courseids[0]=" + courseId
                    + "&moodlewsrestformat=json";
            
            ResponseEntity<String> assignResponse = restTemplate.getForEntity(assignUrl, String.class);
            
            if (assignResponse.getStatusCode() == HttpStatus.OK) {
                JsonNode assignJson = objectMapper.readTree(assignResponse.getBody());
                if (!assignJson.has("exception")) {
                    context.put("canAccessAssignments", true);
                } else {
                    context.put("canAccessAssignments", false);
                }
            }
            
        } catch (Exception e) {
            context.put("canAccessAssignments", false);
        }
        
        return context;
    }

    /**
     * Build context-aware content
     */
    private String buildContextAwareContent(Map<String, Object> materialData, String exportType, 
                                          String courseId, Map<String, Object> courseContext) {
        String title = (String) materialData.get("title");
        String content = (String) materialData.get("content");
        
        StringBuilder html = new StringBuilder();
        
        // Dynamic header based on export type
        String headerColor = getHeaderColorForType(exportType);
        String headerIcon = getHeaderIconForType(exportType);
        String headerTitle = getHeaderTitleForType(exportType);
        
        html.append("<div style='border: 3px solid ").append(headerColor).append("; padding: 20px; margin-bottom: 20px; background-color: ").append(headerColor).append("22;'>");
        html.append("<h1 style='color: ").append(headerColor).append("; margin: 0; font-size: 28px;'>").append(headerIcon).append(" ").append(headerTitle).append("</h1>");
        html.append("<h2 style='color: ").append(headerColor).append("; margin: 10px 0 0 0; font-size: 20px;'>").append(title).append("</h2>");
        
        // Course context information
        html.append("<div style='margin-top: 15px; padding: 10px; background-color: #ffffff; border-radius: 4px;'>");
        html.append("<p style='margin: 0; font-size: 14px;'>");
        html.append("<strong>Course ID:</strong> ").append(courseId).append(" | ");
        html.append("<strong>Export Type:</strong> ").append(exportType.toUpperCase()).append(" | ");
        html.append("<strong>Created:</strong> ").append(LocalDateTime.now().format(DateTimeFormatter.ofPattern("MMM dd, yyyy 'at' HH:mm")));
        
        if (courseContext != null && (Boolean) courseContext.getOrDefault("hasStructureAccess", false)) {
            html.append(" | <strong>Sections:</strong> ").append(courseContext.get("sectionCount"));
        }
        
