                        + "&moodlewsrestformat=json";

                @SuppressWarnings("unchecked")
                Map<String, Object> attemptsResponse = restTemplate.getForObject(attemptsUrl, Map.class);
                
                if (attemptsResponse != null && !attemptsResponse.containsKey("exception")) {
                    System.out.println("✅ Strategy 3 success - User attempts obtained");
                    description.append(buildQuizDescriptionFromAttempts(attemptsResponse, token, quizId));
                    foundContent = true;
                } else {
                    System.out.println("⚠️ Strategy 3 failed");
                }
            } catch (Exception e) {
                System.out.println("⚠️ Strategy 3 exception: " + e.getMessage());
            }
        }

        // Strategy 4: Try alternative quiz info endpoint
        if (!foundContent) {
            try {
                System.out.println("🔧 Strategy 4 - Trying alternative quiz info");
                
                // Try different quiz info function
                String infoUrl = moodleBaseUrl + "/webservice/rest/server.php"
                        + "?wstoken=" + token
                        + "&wsfunction=mod_quiz_get_quiz_access_information"
                        + "&quizid=" + quizId
                        + "&moodlewsrestformat=json";

                @SuppressWarnings("unchecked")
                Map<String, Object> infoResponse = restTemplate.getForObject(infoUrl, Map.class);
                
                if (infoResponse != null && !infoResponse.containsKey("exception")) {
                    System.out.println("✅ Strategy 4 success - Quiz access info obtained");
                    description.append(buildQuizDescriptionFromAccessInfo(infoResponse, token, quizId));
                    foundContent = true;
                } else {
                    System.out.println("⚠️ Strategy 4 failed");
                }
            } catch (Exception e) {
                System.out.println("⚠️ Strategy 4 exception: " + e.getMessage());
            }
        }

        // Strategy 5: Use module description as fallback
        if (!foundContent) {
            System.out.println("🔧 Strategy 5 - Using module description fallback");
            description.append(getBasicQuizDescriptionFromModule(module));
        }

        String result = description.toString();
        System.out.println("🔧 Final quiz description length: " + result.length());
        return result;
    }

