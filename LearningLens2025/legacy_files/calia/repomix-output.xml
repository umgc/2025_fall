}


    // Generate Google OAuth URL
    public Map<String, Object> getGoogleAuthUrl() {
        try {
            System.out.println("🔧 Google Client ID: " + 
                (googleClientId != null && !googleClientId.trim().isEmpty() ? 
                    googleClientId.substring(0, Math.min(10, googleClientId.length())) + "..." : "NULL/EMPTY"));
            System.out.println("🔧 Google Client Secret: " + 
                (googleClientSecret != null && !googleClientSecret.trim().isEmpty() ? "***SET***" : "NULL/EMPTY"));
            
            if (googleClientId == null || googleClientId.trim().isEmpty()) {
                return Map.of(
                    "success", false,
                    "error", "Google Client ID is not configured"
                );
            }
            
            if (googleClientSecret == null || googleClientSecret.trim().isEmpty()) {
                return Map.of(
                    "success", false,
                    "error", "Google Client Secret is not configured"
                );
            }
            
            String encodedScopes = URLEncoder.encode(GOOGLE_SCOPES, StandardCharsets.UTF_8);
            String encodedRedirectUri = URLEncoder.encode(googleRedirectUri, StandardCharsets.UTF_8);
            
            String authUrl = "https://accounts.google.com/o/oauth2/v2/auth" +
                    "?client_id=" + googleClientId +
