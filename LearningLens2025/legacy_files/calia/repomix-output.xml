        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
        StringBuilder entry = new StringBuilder();
        
        entry.append("[").append(timestamp).append("]\n");
        entry.append("TEACHER: ").append(prompt).append("\n\n");
        entry.append("CAILA: ").append(response).append("\n\n");
        entry.append("-".repeat(50)).append("\n\n");
        
        return entry.toString();
    }

    /**
     * Build student chat log content
     */
    private String buildChatLogContent(String courseId, String studentId, String prompt, String response) {
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
        StringBuilder content = new StringBuilder();
        
        content.append("CAILA AI Assistant Chat Log\n");
        content.append("=".repeat(60)).append("\n");
        content.append("Student: ").append(studentId).append("\n");
        content.append("Course ID: ").append(courseId).append("\n");
        content.append("Created: ").append(timestamp).append("\n");
        content.append("=".repeat(60)).append("\n\n");
        
        content.append("[").append(timestamp).append("]\n");
        content.append("STUDENT: ").append(prompt).append("\n\n");
        content.append("CAILA: ").append(response).append("\n\n");
        content.append("-".repeat(50)).append("\n\n");
        
        return content.toString();
    }

    /**
     * Build teacher session summary
     */
    private Map<String, Object> buildTeacherSessionSummary(String teacherToken, Map<String, Object> file) {
        try {
            String fileId = (String) file.get("id");
            String fileName = (String) file.get("name");
            
            if (fileId == null || fileName == null) {
                return null;
            }
            
            String sessionId = extractSessionIdFromFileName(fileName);
            String materialType = extractMaterialTypeFromFileName(fileName);
            String courseId = extractCourseIdFromFileName(fileName);
            
            int messageCount = 0;
            String preview = "Chat session ready";
            
            try {
                String content = getFileContent(teacherToken, fileId);
                if (content != null && !content.trim().isEmpty()) {
                    messageCount = (int) content.lines()
                        .filter(line -> line.trim().startsWith("TEACHER:"))
                        .count();
                    preview = extractFirstPromptPreview(content);
                }
            } catch (Exception contentError) {
                System.out.println("⚠️ Could not get content for preview: " + contentError.getMessage());
            }
            
            Map<String, Object> summary = new HashMap<>();
            summary.put("sessionId", sessionId);
            summary.put("fileId", fileId);
            summary.put("title", generateSessionTitle(materialType, courseId));
            summary.put("materialType", materialType);
            summary.put("courseId", courseId);
            summary.put("messageCount", messageCount);
            summary.put("preview", preview);
            summary.put("createdTime", file.get("createdTime"));
            summary.put("lastModified", file.get("modifiedTime"));
            summary.put("fileName", fileName);
            
            return summary;
            
        } catch (Exception e) {
            System.out.println("❌ Error building teacher session summary: " + e.getMessage());
            return null;
        }
    }

    // ========================================
    // UTILITY METHODS
    // ========================================

    /**
     * Sanitize email addresses for Google Drive file names
     */
    private String sanitizeEmailForDrive(String email) {
        if (email == null) return "";
        return email.replaceAll("@", "_AT_")
                   .replaceAll("\\.", "_DOT_")
                   .replaceAll("[^a-zA-Z0-9._-]", "_");
    }

    /**
     * Sanitize general strings for Google Drive
     */
    private String sanitizeForDrive(String input) {
        if (input == null) return "";
        return input.replaceAll("[^a-zA-Z0-9._-]", "_");
    }

    /**
     * Extract session ID from filename
     */
    private String extractSessionIdFromFileName(String fileName) {
        if (fileName == null) return "unknown_session";
        try {
            String[] parts = fileName.split("_");
            if (parts.length >= 6) {
                return parts[parts.length - 1].replace(".txt", "");
            }
        } catch (Exception e) {
            System.out.println("⚠️ Error extracting session ID from: " + fileName);
        }
        return "session_" + System.currentTimeMillis();
    }

    /**
     * Extract material type from filename
     */
    private String extractMaterialTypeFromFileName(String fileName) {
        if (fileName == null) return "Unknown";
        try {
            String[] parts = fileName.split("_");
            if (parts.length >= 4) {
                return parts[3].replace("-", " ");
            }
        } catch (Exception e) {
            System.out.println("⚠️ Error extracting material type from: " + fileName);
        }
        return "Unknown";
    }

    /**
     * Extract course ID from filename
     */
    private String extractCourseIdFromFileName(String fileName) {
        if (fileName == null) return "Unknown";
        try {
            String[] parts = fileName.split("_");
            if (parts.length >= 3) {
                return parts[2];
            }
        } catch (Exception e) {
            System.out.println("⚠️ Error extracting course ID from: " + fileName);
        }
        return "Unknown";
    }

    /**
     * Extract student ID from filename
     */
    private String extractStudentIdFromFileName(String fileName) {
        try {
            if (fileName == null || !fileName.startsWith("CAILA_Chat_")) {
                return null;
            }
            
            String[] parts = fileName.split("_");
            if (parts.length >= 4) {
                StringBuilder studentId = new StringBuilder();
                boolean foundCourse = false;
                
                for (int i = 2; i < parts.length; i++) {
                    if (!foundCourse) {
                        foundCourse = true;
                        continue;
                    }
                    
                    String part = parts[i];
                    
                    if (part.matches("\\d{4}") || part.matches("\\d{2}") || part.endsWith(".txt")) {
                        break;
                    }
                    
                    if (studentId.length() > 0) studentId.append("_");
                    studentId.append(part);
                }
                
                String result = studentId.toString();
                if (result.endsWith(".txt")) {
                    result = result.substring(0, result.length() - 4);
                }
                
                return result.isEmpty() ? null : result;
            }
            return null;
        } catch (Exception e) {
            System.out.println("❌ Error extracting student ID from filename: " + fileName + " - " + e.getMessage());
            return null;
        }
    }

    /**
     * Extract assignment from filename
     */
    private String extractAssignmentFromFileName(String fileName) {
        try {
            if (fileName == null || !fileName.startsWith("CAILA_Chat_")) {
                return "General";
            }
            
            String[] parts = fileName.split("_");
            
            if (parts.length >= 5) {
                for (int i = 4; i < parts.length - 1; i++) {
                    String part = parts[i];
                    if (!part.matches("\\d{4}") && !part.matches("\\d{2}") && !part.endsWith(".txt")) {
                        return part.replace("-", " ");
                    }
                }
            }
            
            return "General Assignment";
        } catch (Exception e) {
            System.out.println("❌ Error extracting assignment from filename: " + e.getMessage());
            return "Unknown Assignment";
        }
    }

    /**
     * Find specific assignment chat file
     */
    private String findStudentAssignmentChatFile(String studentAccessToken, String courseId, 
                                            String studentId, String assignmentId) {
        try {
            List<Map<String, Object>> chatFiles = findStudentOwnChatFiles(studentAccessToken, courseId, studentId);
            
            if (assignmentId != null) {
                String sanitizedAssignmentId = sanitizeForDrive(assignmentId);
                
                for (Map<String, Object> file : chatFiles) {
                    String fileName = (String) file.get("name");
                    
                    if (fileName != null && fileName.contains(sanitizedAssignmentId)) {
                        return (String) file.get("id");
                    }
                    
                    String description = (String) file.get("description");
                    if (description != null && description.contains(assignmentId)) {
                        return (String) file.get("id");
                    }
                }
            }
            
            if (!chatFiles.isEmpty()) {
                System.out.println("🔍 No specific assignment file found, using most recent chat file");
                return (String) chatFiles.get(0).get("id");
            }
            
            return null;
        } catch (Exception e) {
            System.out.println("❌ Error finding assignment chat file: " + e.getMessage());
            e.printStackTrace();
            return null;
        }
    }

    /**
     * Extract content metadata helpers
     */
    private String extractMaterialTypeFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Material Type:")) {
                    return line.substring("Material Type:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractCourseIdFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Course ID:")) {
                    return line.substring("Course ID:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractTeacherIdFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Teacher:")) {
                    return line.substring("Teacher:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractCreatedAtFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Created:")) {
                    return line.substring("Created:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return LocalDateTime.now().toString();
    }

    private String extractFirstPromptPreview(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.trim().startsWith("TEACHER:")) {
                    String prompt = line.substring(line.indexOf("TEACHER:") + 8).trim();
                    if (prompt.length() > 100) {
                        return prompt.substring(0, 100) + "...";
                    }
                    return prompt;
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Chat session ready";
    }

    private String generateSessionTitle(String materialType, String courseId) {
        if (materialType != null && !materialType.equals("Unknown")) {
            return materialType + " - Course " + courseId;
        }
        return "Chat Session - Course " + courseId;
    }

    /**
     * File naming helpers
     */
    private String generateFileName(String courseId, String studentId) {
        String sanitizedCourseId = sanitizeForDrive(courseId);
        String sanitizedStudentId = sanitizeEmailForDrive(studentId);
        String date = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd"));
        return "CAILA_Chat_" + sanitizedCourseId + "_" + sanitizedStudentId + "_" + date + ".txt";
    }

    private String generateChatFileBaseName(String courseId, String studentId) {
        String sanitizedCourseId = sanitizeForDrive(courseId);
        String sanitizedStudentId = sanitizeEmailForDrive(studentId);
        return "CAILA_Chat_" + sanitizedCourseId + "_" + sanitizedStudentId;
    }

    private String buildFileDescription(String courseId, String studentId) {
        return String.format("CAILA AI Assistant chat log for student %s in course %s. " +
                           "Generated automatically by CAILA system.",
                           studentId, courseId);
    }

    /**
     * Teacher email resolution
     */
    private String getTeacherEmailImproved(String accessToken, String courseId) {
        String mappedEmail = courseTeacherMappingService.getTeacherForCourse(courseId);
        if (mappedEmail != null && !mappedEmail.trim().isEmpty()) {
            return mappedEmail;
        }
        
        String defaultEmail = getDefaultTeacherEmailForCourse(courseId);
        if (defaultEmail != null && !defaultEmail.trim().isEmpty()) {
            return defaultEmail;
        }
        
        return null;
    }

    private String getDefaultTeacherEmailForCourse(String courseId) {
        String courseSpecificEmail = environment.getProperty("caila.course." + courseId + ".teacher.email");
        if (courseSpecificEmail != null && !courseSpecificEmail.trim().isEmpty()) {
            return courseSpecificEmail;
        }
        
        if (defaultTeacherEmail != null && !defaultTeacherEmail.trim().isEmpty()) {
            return defaultTeacherEmail;
        }
        
        return null;
    }

    /**
     * Access verification helpers
     */
    private int getMessageCountFromFileSafe(String accessToken, String fileId) {
        try {
            String content = getFileContent(accessToken, fileId);
            if (content != null && !content.trim().isEmpty()) {
                return (int) content.lines()
                    .filter(line -> line.trim().startsWith("STUDENT:"))
                    .count();
            }
            return 0;
        } catch (Exception e) {
            System.out.println("❌ Error getting message count from file " + fileId + ": " + e.getMessage());
            return 0;
        }
    }
    
    private boolean verifyTeacherAccess(String teacherAccessToken, String fileId) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + teacherAccessToken);
            HttpEntity<String> entity = new HttpEntity<>(headers);

            ResponseEntity<Map> response = restTemplate.exchange(
                "https://www.googleapis.com/drive/v3/files/" + fileId + "?fields=id,name",
                HttpMethod.GET, entity, Map.class
            );

            return response.getStatusCode() == HttpStatus.OK;
        } catch (Exception e) {
            return false;
        }
    }

    /**
     * Create error response helper
     */
    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> result = new HashMap<>();
        result.put("success", false);
        result.put("error", error);
        return result;
    }

    // ========================================
    // DEBUG METHODS
    // ========================================

    public Map<String, Object> debugSharedFiles(String courseId) {
        return Map.of("success", true, "message", "Debug method for course: " + courseId);
    }

    public Map<String, Object> debugSharedFilesWithAuth(String token, String courseId) {
        return Map.of("success", true, "message", "Debug method with auth for course: " + courseId);
    }
}
