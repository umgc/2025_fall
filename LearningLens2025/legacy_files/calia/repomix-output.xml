package com.focusedai.caila_service.service;

import com.focusedai.caila_service.model.GeneratedMaterial;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.*;
import java.util.concurrent.ConcurrentHashMap;

@Service
public class MaterialService {
    
    // In-memory storage for now - in production, use a database
    private final Map<String, GeneratedMaterial> materials = new ConcurrentHashMap<>();
    private final Map<String, List<String>> teacherMaterials = new ConcurrentHashMap<>();
    
    public GeneratedMaterial createMaterial(String teacherId, String courseId, String courseName, 
                                          String title, String type, String content, String prompt) {
        GeneratedMaterial material = new GeneratedMaterial();
        material.setId(UUID.randomUUID().toString());
        material.setTeacherId(teacherId);
        material.setCourseId(courseId);
        material.setCourseName(courseName);
        material.setTitle(title);
        material.setType(type);
        material.setContent(content);
        material.setPrompt(prompt);
        
        // Add first version
        GeneratedMaterial.MaterialVersion firstVersion = new GeneratedMaterial.MaterialVersion(1, content, prompt);
        material.getVersions().add(firstVersion);
        
        materials.put(material.getId(), material);
        
        // Track materials by teacher
        teacherMaterials.computeIfAbsent(teacherId, k -> new ArrayList<>()).add(material.getId());
        
        return material;
    }
    
    public GeneratedMaterial updateMaterial(String materialId, String newContent, String newPrompt) {
        GeneratedMaterial material = materials.get(materialId);
        if (material == null) {
            throw new RuntimeException("Material not found");
        }
        
        // Create new version
        int nextVersion = material.getVersion() + 1;
        GeneratedMaterial.MaterialVersion newVersion = new GeneratedMaterial.MaterialVersion(nextVersion, newContent, newPrompt);
        
        material.setContent(newContent);
        material.setPrompt(newPrompt);
        material.setVersion(nextVersion);
        material.setUpdatedAt(LocalDateTime.now());
        material.getVersions().add(newVersion);
        
        return material;
    }
    
    public List<GeneratedMaterial> getTeacherMaterials(String teacherId) {
        List<String> materialIds = teacherMaterials.getOrDefault(teacherId, new ArrayList<>());
        return materialIds.stream()
                .map(materials::get)
                .filter(Objects::nonNull)
                .sorted(Comparator.comparing(GeneratedMaterial::getUpdatedAt).reversed())
                .toList();
    }
    
    public GeneratedMaterial getMaterial(String materialId) {
        GeneratedMaterial material = materials.get(materialId);
        if (material == null) {
            throw new RuntimeException("Material not found");
        }
        return material;
    }
    
    public List<GeneratedMaterial> getMaterialsByCourse(String teacherId, String courseId) {
        return getTeacherMaterials(teacherId).stream()
                .filter(material -> courseId.equals(material.getCourseId()))
                .toList();
    }
    
    public List<GeneratedMaterial> getMaterialsByType(String teacherId, String type) {
        return getTeacherMaterials(teacherId).stream()
                .filter(material -> type.equals(material.getType()))
                .toList();
    }
}
