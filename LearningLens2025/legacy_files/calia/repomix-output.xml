    /**
     * Find teacher chat files using simple listing
     */
    private List<Map<String, Object>> findTeacherChatFiles(String teacherToken, String teacherId) {
        List<Map<String, Object>> teacherFiles = new ArrayList<>();
        
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.set("Authorization", "Bearer " + teacherToken);
            HttpEntity<String> entity = new HttpEntity<>(headers);
            
            String url = "https://www.googleapis.com/drive/v3/files?" +
                        "fields=files(id,name,createdTime,modifiedTime,description,properties)" +
                        "&pageSize=1000" +
                        "&orderBy=modifiedTime desc";
            
            ResponseEntity<Map> response = restTemplate.exchange(url, HttpMethod.GET, entity, Map.class);
            
            if (response.getStatusCode() == HttpStatus.OK && response.getBody() != null) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> files = (List<Map<String, Object>>) response.getBody().get("files");
                
                if (files != null) {
                    String sanitizedTeacherId = sanitizeEmailForDrive(teacherId);
                    
                    for (Map<String, Object> file : files) {
                        String fileName = (String) file.get("name");
                        if (fileName != null && 
                            fileName.startsWith("CAILA_Teacher_") && 
                            fileName.contains(sanitizedTeacherId) &&
                            fileName.endsWith(".txt")) {
                            teacherFiles.add(file);
                        }
                    }
                    System.out.println("✅ Found " + teacherFiles.size() + " teacher chat files");
                }
            }
            
        } catch (Exception e) {
            System.out.println("❌ Error listing teacher chat files: " + e.getMessage());
            e.printStackTrace();
        }
        
        return teacherFiles;
    }

