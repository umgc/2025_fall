import org.springframework.http.*;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.client.RestTemplate;

@RestController
@RequestMapping("/api/moodle")
public class MoodleService {

    private final RestTemplate restTemplate = new RestTemplate();
    private final String BASE_URL = "http://18.188.18.80/moodle/webservice/rest/server.php";

    private String buildUrl(String token, String function, String extraParams) {
        return BASE_URL + "?wstoken=" + token
                         + "&wsfunction=" + function
                         + "&moodlewsrestformat=json"
                         + (extraParams != null ? "&" + extraParams : "");
    }

    @GetMapping("/courses")
    public ResponseEntity<String> getCourses(@RequestParam String token) {
        String url = buildUrl(token, "core_course_get_courses", null);
        return restTemplate.getForEntity(url, String.class);
    }

    @GetMapping("/user-courses")
    public ResponseEntity<String> getUserCourses(@RequestParam String token, @RequestParam int userid) {
        String url = buildUrl(token, "core_enrol_get_users_courses", "userid=" + userid);
        return restTemplate.getForEntity(url, String.class);
    }

    @GetMapping("/course-users")
    public ResponseEntity<String> getEnrolledUsers(@RequestParam String token, @RequestParam int courseid) {
        String url = buildUrl(token, "core_enrol_get_enrolled_users", "courseid=" + courseid);
        return restTemplate.getForEntity(url, String.class);
    }

    @GetMapping("/assignments")
    public ResponseEntity<String> getAssignments(@RequestParam String token) {
        String url = buildUrl(token, "mod_assign_get_assignments", null);
        return restTemplate.getForEntity(url, String.class);
    }

    @GetMapping("/submissions")
    public ResponseEntity<String> getSubmissions(@RequestParam String token, @RequestParam int assignmentid) {
        String extra = "assignmentids[0]=" + assignmentid;
        String url = buildUrl(token, "mod_assign_get_submissions", extra);
        return restTemplate.getForEntity(url, String.class);
    }

    @GetMapping("/files")
    public ResponseEntity<String> getFiles(@RequestParam String token,
                                           @RequestParam int contextid,
                                           @RequestParam(required = false) String component,
                                           @RequestParam(required = false) String filearea,
                                           @RequestParam(required = false) int itemid,
                                           @RequestParam(required = false) String filepath,
                                           @RequestParam(required = false) String filename) {
        StringBuilder extra = new StringBuilder("contextid=" + contextid);
        if (component != null) extra.append("&component=").append(component);
        if (filearea != null) extra.append("&filearea=").append(filearea);
        if (itemid > 0) extra.append("&itemid=").append(itemid);
        if (filepath != null) extra.append("&filepath=").append(filepath);
        if (filename != null) extra.append("&filename=").append(filename);
        String url = buildUrl(token, "core_files_get_files", extra.toString());
        return restTemplate.getForEntity(url, String.class);
    }
}
