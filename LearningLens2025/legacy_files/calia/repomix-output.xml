        if (module.containsKey("dates")) {
            @SuppressWarnings("unchecked")
            List<Map<String, Object>> dates = (List<Map<String, Object>>) module.get("dates");
            
            for (Map<String, Object> date : dates) {
                String label = (String) date.get("label");
                Object timestamp = date.get("timestamp");
                
                if (timestamp instanceof Number && ((Number) timestamp).longValue() > 0) {
                    LocalDateTime dateTime = LocalDateTime.ofEpochSecond(
                        ((Number) timestamp).longValue(), 0, java.time.ZoneOffset.UTC);
                    String formattedDate = dateTime.format(DateTimeFormatter.ISO_LOCAL_DATE_TIME);
                    
                    // Map different date types
                    if (label != null) {
                        if (label.toLowerCase().contains("due") || label.toLowerCase().contains("close")) {
                            assignment.put("dueDate", formattedDate);
                        } else if (label.toLowerCase().contains("open") || label.toLowerCase().contains("available")) {
                            assignment.put("availableDate", formattedDate);
                        }
                    }
                }
            }
        }
    }

    // Helper methods
    private String getActivityTypeDisplay(String modname) {
        if (modname == null) return "Activity";
        
        switch (modname) {
            case "assign": return "Assignment";
            case "quiz": return "Quiz";
            case "workshop": return "Workshop";
            case "forum": return "Forum";
            case "lesson": return "Lesson";
            case "scorm": return "SCORM Package";
            case "h5pactivity": return "Interactive Content";
            case "choice": return "Choice";
            case "feedback": return "Feedback";
            case "survey": return "Survey";
            case "glossary": return "Glossary";
            case "wiki": return "Wiki";
            case "data": return "Database";
            default: return "Activity";
