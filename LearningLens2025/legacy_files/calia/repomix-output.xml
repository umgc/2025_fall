package com.focusedai.caila_service.service;

import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.http.*;
import com.fasterxml.jackson.databind.ObjectMapper;

import org.springframework.beans.factory.annotation.Autowired;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import com.focusedai.caila_service.service.AuthService;

import java.util.*;

@Service
public class GoogleFormsService {
    private final RestTemplate restTemplate = new RestTemplate();
    private final ObjectMapper objectMapper = new ObjectMapper();

    private static final Logger logger = LoggerFactory.getLogger(GoogleFormsService.class);
    
    @Autowired
    private AuthService authService;  

    public Map<String, Object> createGoogleForm(String authToken, Map<String, Object> formData) {
        try {
            String accessToken = extractAccessToken(authToken);
            
            // Step 1: Create the form with ONLY the title
            Map<String, Object> formRequest = new HashMap<>();
            Map<String, Object> info = new HashMap<>();
            info.put("title", formData.get("title"));
            formRequest.put("info", info);
            
            // Create the form
            String createUrl = "https://forms.googleapis.com/v1/forms";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> createRequest = new HttpEntity<>(formRequest, headers);
            
            ResponseEntity<Map> createResponse = restTemplate.postForEntity(createUrl, createRequest, Map.class);
            
            if (!createResponse.getStatusCode().is2xxSuccessful()) {
                return createErrorResponse("Failed to create form: " + createResponse.getBody());
            }
            
            String formId = (String) createResponse.getBody().get("formId");
            String responderUri = (String) createResponse.getBody().get("responderUri");
            
            // Step 2: Add description using batchUpdate
            if (formData.get("description") != null) {
                updateFormDescription(accessToken, formId, (String) formData.get("description"));
            }
            
            // Step 3: Add questions if this has content to parse
            if (formData.containsKey("content")) {
                String content = (String) formData.get("content");
                addQuestionsFromContent(accessToken, formId, content);
            }
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("formId", formId);
            result.put("formUrl", responderUri);
            result.put("message", "Google Form created successfully");
            
            return result;
            
        } catch (Exception e) {
            logger.error("Error creating Google Form", e);
            return createErrorResponse("Error creating form: " + e.getMessage());
        }
    }

    private Map<String, Object> createErrorResponse(String error) {
        Map<String, Object> response = new HashMap<>();
        response.put("success", false);
        response.put("error", error);
        return response;
    }

    private String extractAccessToken(String authToken) {
        try {
            // Get token info from your auth service
            Map<String, Object> tokenInfo = authService.getTokenInfo(authToken);
            if (tokenInfo == null) {
                throw new RuntimeException("Invalid auth token");
            }
            
            // Check if it's a Google token
            String platform = (String) tokenInfo.get("platform");
            if (!"google".equals(platform)) {
                throw new RuntimeException("Token is not for Google platform");
            }
            
            // The access token is stored directly as "token" in your AuthService
            String accessToken = (String) tokenInfo.get("token");
            
            if (accessToken == null || accessToken.trim().isEmpty()) {
                throw new RuntimeException("No Google access token found");
            }
            
            // Check if token is expired
            Boolean expired = (Boolean) tokenInfo.get("expired");
            if (expired != null && expired) {
                // Try to refresh the token
                String refreshToken = (String) tokenInfo.get("refreshToken");
                if (refreshToken != null) {
                    Map<String, Object> refreshResult = authService.refreshGoogleToken(refreshToken);
                    if ((Boolean) refreshResult.get("success")) {
                        accessToken = (String) refreshResult.get("token");
                    } else {
                        throw new RuntimeException("Token expired and refresh failed");
                    }
                } else {
                    throw new RuntimeException("Token expired and no refresh token available");
                }
            }
            
            return accessToken;
            
        } catch (Exception e) {
            logger.error("Failed to extract access token", e);
            throw new RuntimeException("Failed to extract access token: " + e.getMessage());
        }
    }

    public Map<String, Object> updateGoogleForm(String accessToken, String formId, Map<String, Object> updateData) {
        try {
            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_JSON);
            headers.set("Authorization", "Bearer " + accessToken);

            HttpEntity<Map<String, Object>> entity = new HttpEntity<>(updateData, headers);

            ResponseEntity<Map> response = restTemplate.postForEntity(
                "https://forms.googleapis.com/v1/forms/" + formId + ":batchUpdate",
                entity,
                Map.class
            );

            if (response.getStatusCode() == HttpStatus.OK) {
                return Map.of(
                    "success", true,
                    "data", response.getBody()
                );
            } else {
                return Map.of(
                    "success", false,
                    "error", "Form update failed with status: " + response.getStatusCode()
                );
            }

        } catch (Exception e) {
            return Map.of(
                "success", false,
                "error", "Form update failed: " + e.getMessage()
            );
        }
    }

    public Map<String, Object> createClassroomAssignment(String authToken, String courseId, Map<String, Object> assignmentData) {
        try {
            // Extract the actual access token using AuthService
            String accessToken = extractAccessToken(authToken);
            
            // Fixed structure for Google Classroom courseWork
            Map<String, Object> courseWork = new HashMap<>();
            courseWork.put("title", assignmentData.get("title"));
            courseWork.put("description", assignmentData.get("description"));
            courseWork.put("workType", "ASSIGNMENT");
            courseWork.put("state", "PUBLISHED");
            
            // Add materials if provided
            if (assignmentData.containsKey("materials")) {
                courseWork.put("materials", assignmentData.get("materials"));
            }
            
            // Add max points if provided
            if (assignmentData.containsKey("maxPoints")) {
                courseWork.put("maxPoints", assignmentData.get("maxPoints"));
            }
            
            // Add topic if provided
            if (assignmentData.containsKey("topicId")) {
                courseWork.put("topicId", assignmentData.get("topicId"));
            }

            HttpHeaders headers = new HttpHeaders();
            headers.setContentType(MediaType.APPLICATION_JSON);
            headers.set("Authorization", "Bearer " + accessToken);

            HttpEntity<Map<String, Object>> entity = new HttpEntity<>(courseWork, headers);

            ResponseEntity<Map> response = restTemplate.postForEntity(
                "https://classroom.googleapis.com/v1/courses/" + courseId + "/courseWork",
                entity,
                Map.class
            );

            if (response.getStatusCode() == HttpStatus.OK) {
                Map<String, Object> result = new HashMap<>();
                result.put("success", true);
                result.put("data", response.getBody());
                result.put("assignmentUrl", "https://classroom.google.com/c/" + courseId);
                return result;
            } else {
                logger.error("Classroom assignment creation failed with status: {} and body: {}", 
                    response.getStatusCode(), response.getBody());
                return Map.of(
                    "success", false,
                    "error", "Assignment creation failed with status: " + response.getStatusCode()
                );
            }

        } catch (Exception e) {
            logger.error("Error creating classroom assignment", e);
            return Map.of(
                "success", false,
                "error", "Assignment creation failed: " + e.getMessage()
            );
        }
    }

    public Map<String, Object> createInteractiveQuiz(String authToken, String courseId, Map<String, Object> quizData) {
        try {
            String accessToken = extractAccessToken(authToken);
            
            // Step 1: Create the form with ONLY the title
            Map<String, Object> formRequest = new HashMap<>();
            Map<String, Object> info = new HashMap<>();
            info.put("title", quizData.get("title"));
            formRequest.put("info", info);
            
            // Create the form first
            String createUrl = "https://forms.googleapis.com/v1/forms";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> createRequest = new HttpEntity<>(formRequest, headers);
            
            ResponseEntity<Map> createResponse = restTemplate.postForEntity(createUrl, createRequest, Map.class);
            
            if (!createResponse.getStatusCode().is2xxSuccessful()) {
                return createErrorResponse("Failed to create quiz form");
            }
            
            String formId = (String) createResponse.getBody().get("formId");
            String responderUri = (String) createResponse.getBody().get("responderUri");
            
            // Step 2: Enable quiz mode using batchUpdate
            enableQuizMode(accessToken, formId);
            
            // Step 3: Add description using batchUpdate
            if (quizData.get("description") != null) {
                updateFormDescription(accessToken, formId, (String) quizData.get("description"));
            }
            
            // Step 4: Add questions to the form
            @SuppressWarnings("unchecked")
            List<Map<String, Object>> questions = (List<Map<String, Object>>) quizData.get("questions");
            
            if (questions != null && !questions.isEmpty()) {
                addQuizQuestionsToForm(accessToken, formId, questions);
            }
            
            // Step 5: Create Google Classroom assignment if courseId provided
            if (courseId != null && !courseId.isEmpty()) {
                createClassroomAssignmentForForm(accessToken, courseId, formId, responderUri, (String) quizData.get("title"));
            }
            
            Map<String, Object> result = new HashMap<>();
            result.put("success", true);
            result.put("formId", formId);
            result.put("formUrl", responderUri);
            result.put("message", "Interactive quiz created successfully");
            
            return result;
            
        } catch (Exception e) {
            logger.error("Error creating interactive quiz", e);
            return createErrorResponse("Error creating quiz: " + e.getMessage());
        }
    }

    private void enableQuizMode(String accessToken, String formId) {
        try {
            Map<String, Object> request = new HashMap<>();
            Map<String, Object> requests = new HashMap<>();
            Map<String, Object> updateSettings = new HashMap<>();
            Map<String, Object> settings = new HashMap<>();
            Map<String, Object> quizSettings = new HashMap<>();
            
            quizSettings.put("isQuiz", true);
            settings.put("quizSettings", quizSettings);
            updateSettings.put("settings", settings);
            updateSettings.put("updateMask", "quizSettings.isQuiz");
            
            requests.put("updateSettings", updateSettings);
            request.put("requests", List.of(requests));
            
            String url = "https://forms.googleapis.com/v1/forms/" + formId + ":batchUpdate";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> requestEntity = new HttpEntity<>(request, headers);
            restTemplate.postForEntity(url, requestEntity, Map.class);
            
        } catch (Exception e) {
            logger.error("Failed to enable quiz mode", e);
        }
    }

    private void updateFormDescription(String accessToken, String formId, String description) {
        try {
            Map<String, Object> request = new HashMap<>();
            Map<String, Object> requests = new HashMap<>();
            Map<String, Object> updateFormInfo = new HashMap<>();
            Map<String, Object> info = new HashMap<>();
            
            info.put("description", description);
            updateFormInfo.put("info", info);
            updateFormInfo.put("updateMask", "description");
            
            requests.put("updateFormInfo", updateFormInfo);
            request.put("requests", List.of(requests));
            
            String url = "https://forms.googleapis.com/v1/forms/" + formId + ":batchUpdate";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> requestEntity = new HttpEntity<>(request, headers);
            restTemplate.postForEntity(url, requestEntity, Map.class);
            
        } catch (Exception e) {
            logger.error("Failed to update form description", e);
        }
    }

    private void addQuizQuestionsToForm(String accessToken, String formId, List<Map<String, Object>> questions) {
        try {
            for (int i = 0; i < questions.size(); i++) {
                Map<String, Object> questionData = questions.get(i);
                addSingleQuestionToForm(accessToken, formId, questionData, i);
                
                // Add a small delay between requests to avoid rate limiting
                Thread.sleep(100);
            }
        } catch (Exception e) {
            logger.error("Error adding questions to form", e);
        }
    }

    private void addSingleQuestionToForm(String accessToken, String formId, Map<String, Object> questionData, int index) {
        try {
            String questionText = (String) questionData.get("question");
            @SuppressWarnings("unchecked")
            List<String> options = (List<String>) questionData.get("options");
            
            if (questionText == null || questionText.trim().isEmpty()) {
                logger.warn("Skipping empty question at index " + index);
                return;
            }
            
            // Clean up the question text further
            questionText = cleanQuestionText(questionText);
            
            // FIXED: Build the correct Google Forms API structure
            Map<String, Object> request = new HashMap<>();
            List<Map<String, Object>> requests = new ArrayList<>();
            Map<String, Object> createItem = new HashMap<>();
            Map<String, Object> item = new HashMap<>();
            Map<String, Object> questionItem = new HashMap<>();
            Map<String, Object> question = new HashMap<>();
            
            // FIXED: The question title should be set at the item level, not inside question object
            item.put("title", questionText);
            question.put("required", true);
            
            // Add multiple choice options if they exist and are valid
            if (options != null && !options.isEmpty() && hasValidOptions(options)) {
                Map<String, Object> choiceQuestion = new HashMap<>();
                choiceQuestion.put("type", "RADIO");
                
                List<Map<String, Object>> choiceOptions = new ArrayList<>();
                for (String option : options) {
                    if (option != null && !option.trim().isEmpty() && !isExampleText(option)) {
                        Map<String, Object> choiceOption = new HashMap<>();
                        choiceOption.put("value", option.trim());
                        choiceOptions.add(choiceOption);
                    }
                }
                
                if (!choiceOptions.isEmpty()) {
                    choiceQuestion.put("options", choiceOptions);
                    question.put("choiceQuestion", choiceQuestion);
                } else {
                    // Fall back to text question if no valid options
                    Map<String, Object> textQuestion = new HashMap<>();
                    textQuestion.put("paragraph", true); // Use paragraph for essay questions
                    question.put("textQuestion", textQuestion);
                }
            } else {
                // Text question for open-ended questions
                Map<String, Object> textQuestion = new HashMap<>();
                textQuestion.put("paragraph", true); // Use paragraph for essay-style questions
                question.put("textQuestion", textQuestion);
            }
            
            questionItem.put("question", question);
            item.put("questionItem", questionItem);
            createItem.put("item", item);
            createItem.put("location", Map.of("index", index));
            
            requests.add(Map.of("createItem", createItem));
            request.put("requests", requests);
            
            // Make the API call
            String url = "https://forms.googleapis.com/v1/forms/" + formId + ":batchUpdate";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> requestEntity = new HttpEntity<>(request, headers);
            
            ResponseEntity<Map> response = restTemplate.postForEntity(url, requestEntity, Map.class);
            
            if (response.getStatusCode().is2xxSuccessful()) {
                logger.info("✅ Successfully added question " + (index + 1) + ": " + questionText);
            } else {
                logger.error("❌ Failed to add question " + (index + 1) + ": " + response.getBody());
            }
            
        } catch (Exception e) {
            logger.error("Question creation failed: " + e.getMessage(), e);
        }
    }

    private String cleanQuestionText(String questionText) {
        // Remove common formatting and metadata
        return questionText
            .replaceAll("\\*\\*", "") // Remove bold formatting
            .replaceAll("^#+\\s*", "") // Remove markdown headers
            .replaceAll("^Question\\s*\\d*[\\:\\.]?\\s*", "") // Remove "Question N:"
            .replaceAll("\\(Example.*?\\)", "") // Remove example text in parentheses
            .replaceAll("\\*\\(.*?\\)\\*", "") // Remove italic example text
            .trim();
    }

    private boolean hasValidOptions(List<String> options) {
        if (options == null || options.isEmpty()) {
            return false;
        }
        
        int validCount = 0;
        for (String option : options) {
            if (option != null && !option.trim().isEmpty() && !isExampleText(option)) {
                validCount++;
            }
        }
        
        return validCount >= 2; // Need at least 2 valid options for multiple choice
    }

    private boolean isExampleText(String text) {
        if (text == null) return false;
        String lower = text.toLowerCase();
        return lower.contains("example") || 
               lower.contains("optional") || 
               lower.contains("follow-up") ||
               text.startsWith("*") ||
               text.startsWith("(") && text.endsWith(")");
    }

    private void addQuestionsFromContent(String accessToken, String formId, String content) {
        // Parse the content to extract questions
        List<Map<String, Object>> questions = parseQuestionsFromContent(content);
        addQuizQuestionsToForm(accessToken, formId, questions);
    }

    private List<Map<String, Object>> parseQuestionsFromContent(String content) {
        List<Map<String, Object>> questions = new ArrayList<>();
        String[] lines = content.split("\n");
        
        String currentQuestion = null;
        List<String> currentOptions = new ArrayList<>();
        
        for (String line : lines) {
            line = line.trim();
            if (line.isEmpty()) continue;
            
            // Detect question (contains number and question mark, or starts with "Question")
            if (line.matches(".*\\d+\\..*\\?.*") || line.toLowerCase().startsWith("question")) {
                // Save previous question if exists
                if (currentQuestion != null) {
                    Map<String, Object> questionMap = new HashMap<>();
                    questionMap.put("question", currentQuestion);
                    questionMap.put("options", new ArrayList<>(currentOptions));
                    questions.add(questionMap);
                }
                
                // Start new question
                currentQuestion = line;
                currentOptions.clear();
            } 
            // Detect options (a), b), c), d) or A), B), C), D))
            else if (line.matches("^[a-dA-D]\\).*")) {
                String option = line.substring(2).trim(); // Remove "a) " or "A) "
                currentOptions.add(option);
            }
        }
        
        // Add the last question
        if (currentQuestion != null) {
            Map<String, Object> questionMap = new HashMap<>();
            questionMap.put("question", currentQuestion);
            questionMap.put("options", new ArrayList<>(currentOptions));
            questions.add(questionMap);
        }
        
        return questions;
    }

    private void createClassroomAssignmentForForm(String accessToken, String courseId, String formId, String formUrl, String title) {
        try {
            // Create Google Classroom assignment that links to the form
            Map<String, Object> assignment = new HashMap<>();
            assignment.put("title", title);
            assignment.put("description", "Complete this quiz by clicking the link below:\n\n" + formUrl);
            assignment.put("workType", "ASSIGNMENT");
            assignment.put("state", "PUBLISHED");
            assignment.put("maxPoints", 100.0); // Changed to double
            
            // Use "link" material type instead of "form"
            List<Map<String, Object>> materials = new ArrayList<>();
            Map<String, Object> material = new HashMap<>();
            Map<String, Object> link = new HashMap<>();
            link.put("url", formUrl);
            link.put("title", title + " - Quiz Form");
            material.put("link", link);
            materials.add(material);
            assignment.put("materials", materials);
            
            String url = "https://classroom.googleapis.com/v1/courses/" + courseId + "/courseWork";
            
            HttpHeaders headers = new HttpHeaders();
            headers.setBearerAuth(accessToken);
            headers.setContentType(MediaType.APPLICATION_JSON);
            
            HttpEntity<Map<String, Object>> request = new HttpEntity<>(assignment, headers);
            
            ResponseEntity<Map> response = restTemplate.postForEntity(url, request, Map.class);
            
            if (response.getStatusCode().is2xxSuccessful()) {
                logger.info("✅ Classroom assignment created successfully");
            } else {
                logger.error("❌ Failed to create classroom assignment: " + response.getBody());
            }
            
        } catch (Exception e) {
            logger.error("Error creating classroom assignment for form", e);
        }
    }
}
