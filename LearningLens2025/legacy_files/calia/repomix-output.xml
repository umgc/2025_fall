    private Integer getStudentUserIdFromEnrollment(String token, String courseId, String studentId) {
        try {
            logger.info("🔧 Moodle: Getting student user ID from enrollment data for: {}", studentId);
            
            // Get enrolled students for this course
            List<Map<String, Object>> enrolledStudents = getEnrolledStudents(token, courseId);
            
            for (Map<String, Object> student : enrolledStudents) {
                Integer userId = (Integer) student.get("id");
                String username = (String) student.get("username");
                String fullname = (String) student.get("fullname");
                String email = (String) student.get("email");
                
                logger.debug("🔧 Moodle: Checking student - ID: {}, Username: {}, Fullname: {}, Email: {}", 
                            userId, username, fullname, email);
                
                // Check if any of the student fields match the requested studentId
                if (studentId.equals(username) || 
                    studentId.equals(fullname) || 
                    studentId.equals(email) ||
                    studentId.equals(String.valueOf(userId))) {
                    
                    logger.info("✅ Moodle: Found matching student - {} matches user ID {}", studentId, userId);
                    return userId;
                }
            }
            
            logger.warn("❌ Moodle: No enrolled student found matching identifier: {}", studentId);
            
            // DEBUG: Log all available students for troubleshooting
            logger.info("🔧 Moodle: Available students in course {}:", courseId);
            for (Map<String, Object> student : enrolledStudents) {
                logger.info("  - ID: {}, Username: {}, Fullname: {}", 
                           student.get("id"), student.get("username"), student.get("fullname"));
            }
            
            return null;
            
        } catch (Exception e) {
            logger.error("❌ Moodle: Exception while getting student user ID from enrollment: {}", e.getMessage());
            return null;
        }
    }

