                content.append("<p style='margin: 5px 0 0 0;'>This is an assignment that was converted from CAILA AI Assistant</p>");
                content.append("</div>");
                
                if (intro != null && !intro.trim().isEmpty()) {
                    content.append("<div style='margin-bottom: 20px;'>");
                    content.append("<h4>Assignment Instructions:</h4>");
                    content.append(intro);
                    content.append("</div>");
                }
                
