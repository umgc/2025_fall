    private Map<String, Object> buildTeacherSessionSummary(Map<String, Object> note) {
        try {
            String content = (String) note.get("content");
            if (content == null || content.trim().isEmpty()) {
                return null;
            }
            
            // Extract session metadata
            String sessionId = extractSessionIdFromContent(content);
            String materialType = extractMaterialTypeFromContent(content);
            String courseId = extractCourseIdFromContent(content);
            
            // Count messages
            long messageCount = content.lines()
                .filter(line -> line.trim().startsWith("TEACHER:"))
                .count();
            
            // Get preview of first prompt
            String preview = extractFirstPromptPreview(content);
            
            // Get timestamps
            Long lastModified = (Long) note.get("lastmodified");
            String createdAt = extractCreatedAtFromContent(content);
            
            Map<String, Object> summary = new HashMap<>();
            summary.put("sessionId", sessionId);
            summary.put("noteId", note.get("id"));
            summary.put("title", generateSessionTitle(materialType, courseId));
            summary.put("materialType", materialType);
            summary.put("courseId", courseId);
            summary.put("messageCount", (int) messageCount);
            summary.put("preview", preview);
            summary.put("lastModified", lastModified);
            summary.put("createdAt", createdAt);
            summary.put("platform", "moodle");
            
            return summary;
            
        } catch (Exception e) {
            logger.error("❌ Error building teacher session summary", e);
            return null;
        }
    }

    private Map<String, Object> parseTeacherChatSession(String content, String sessionId) {
        List<Map<String, Object>> messages = new ArrayList<>();
        String[] lines = content.split("\n");
        
        String currentRole = null;
        StringBuilder currentMessage = new StringBuilder();
        String currentTimestamp = null;
        
        for (String line : lines) {
            line = line.trim();
            
            if (line.startsWith("[") && line.endsWith("]")) {
                // Save previous message
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                // Start new message
                currentTimestamp = line.substring(1, line.length() - 1);
                currentRole = null;
                currentMessage = new StringBuilder();
                
            } else if (line.startsWith("TEACHER:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                currentRole = "teacher";
                currentMessage = new StringBuilder(line.substring(8).trim());
                
            } else if (line.startsWith("CAILA:")) {
                if (currentRole != null && currentMessage.length() > 0) {
                    Map<String, Object> message = new HashMap<>();
                    message.put("role", currentRole);
                    message.put("content", currentMessage.toString().trim());
                    message.put("timestamp", currentTimestamp);
                    messages.add(message);
                }
                
                currentRole = "caila";
                currentMessage = new StringBuilder(line.substring(6).trim());
                
            } else if (!line.equals("--------------------------------------------------") && 
                      !line.equals("==================================================") &&
                      !line.isEmpty() && currentRole != null) {
                if (currentMessage.length() > 0) currentMessage.append(" ");
                currentMessage.append(line);
            }
        }
        
        // Save final message
        if (currentRole != null && currentMessage.length() > 0) {
            Map<String, Object> message = new HashMap<>();
            message.put("role", currentRole);
            message.put("content", currentMessage.toString().trim());
            message.put("timestamp", currentTimestamp);
            messages.add(message);
        }
        
        // Extract metadata
        String materialType = extractMaterialTypeFromContent(content);
        String courseId = extractCourseIdFromContent(content);
        String teacherId = extractTeacherIdFromContent(content);
        String createdAt = extractCreatedAtFromContent(content);
        
        Map<String, Object> sessionData = new HashMap<>();
        sessionData.put("sessionId", sessionId);
        sessionData.put("teacherId", teacherId);
        sessionData.put("courseId", courseId);
        sessionData.put("materialType", materialType);
        sessionData.put("createdAt", createdAt);
        sessionData.put("messages", messages);
        sessionData.put("messageCount", messages.size());
        sessionData.put("platform", "moodle");
        
        return sessionData;
    }

    // Helper methods for content parsing
    private String extractSessionIdFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Session ID:")) {
                    return line.substring("Session ID:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "session_" + System.currentTimeMillis();
    }

    private String extractMaterialTypeFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Material Type:")) {
                    return line.substring("Material Type:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractCourseIdFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Course ID:")) {
                    return line.substring("Course ID:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractTeacherIdFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Teacher ID:")) {
                    return line.substring("Teacher ID:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "Unknown";
    }

    private String extractCreatedAtFromContent(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.startsWith("Created:")) {
                    return line.substring("Created:".length()).trim();
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return LocalDateTime.now().toString();
    }

    private String extractFirstPromptPreview(String content) {
        try {
            String[] lines = content.split("\n");
            for (String line : lines) {
                if (line.trim().startsWith("TEACHER:")) {
                    String prompt = line.substring(line.indexOf("TEACHER:") + 8).trim();
                    if (prompt.length() > 100) {
                        return prompt.substring(0, 100) + "...";
                    }
                    return prompt;
                }
            }
        } catch (Exception e) {
            // Fallback
        }
        return "No preview available";
    }

    private String generateSessionTitle(String materialType, String courseId) {
        if (materialType != null && !materialType.equals("Unknown")) {
            return materialType + " - Course " + courseId;
        }
        return "Chat Session - Course " + courseId;
    }

