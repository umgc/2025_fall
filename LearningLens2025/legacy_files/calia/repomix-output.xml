package com.focusedai.caila_service.controller;

import com.focusedai.caila_service.service.AuthService;
import com.focusedai.caila_service.service.MoodleExportService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.HashMap;
import java.util.Map;

@RestController
@RequestMapping("/api/moodle-export")
@CrossOrigin(origins = "*")
public class MoodleExportController {

    @Autowired
    private MoodleExportService moodleExportService;

    @Autowired
    private AuthService authService;

    /**
     * Export material to Moodle
     */
    @PostMapping("/export")
    public ResponseEntity<Map<String, Object>> exportToMoodle(
            @RequestHeader("Authorization") String authHeader,
            @RequestBody Map<String, Object> exportData) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"moodle".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid or missing Moodle authentication token"
                ));
            }

            // Extract required data
            String courseId = (String) exportData.get("courseId");
            if (courseId == null || courseId.trim().isEmpty()) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Course ID is required"
                ));
            }

            // Export the material
            Map<String, Object> result = moodleExportService.exportMaterialToMoodle(token, courseId, exportData);
            
            if ((Boolean) result.get("success")) {
                return ResponseEntity.ok(result);
            } else {
                return ResponseEntity.badRequest().body(result);
            }

        } catch (Exception e) {
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    /**
     * Get available export options for a material type
     */
    @GetMapping("/export-options")
    public ResponseEntity<Map<String, Object>> getExportOptions(
            @RequestHeader("Authorization") String authHeader,
            @RequestParam String materialType) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"moodle".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid Moodle authentication token"
                ));
            }

            // Return export options based on material type
            Map<String, Object> options = getExportOptionsForMaterialType(materialType);
            
            return ResponseEntity.ok(Map.of(
                "success", true,
                "materialType", materialType,
                "options", options
            ));

        } catch (Exception e) {
            return ResponseEntity.internalServerError().body(Map.of(
                "success", false,
                "error", "Server error: " + e.getMessage()
            ));
        }
    }

    /**
     * Test Moodle connection and permissions
     */
    @GetMapping("/test-connection")
    public ResponseEntity<Map<String, Object>> testMoodleConnection(
            @RequestHeader("Authorization") String authHeader,
            @RequestParam String courseId) {
        
        try {
            String token = authHeader.replace("Bearer ", "");
            
            // Validate authentication
            Map<String, Object> tokenInfo = authService.getTokenInfo(token);
            if (tokenInfo == null || !"moodle".equals(tokenInfo.get("platform"))) {
                return ResponseEntity.badRequest().body(Map.of(
                    "success", false,
                    "error", "Invalid Moodle authentication token"
                ));
            }

            // Test connection by trying to get course info
