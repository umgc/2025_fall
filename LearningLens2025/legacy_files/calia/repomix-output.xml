    /**
     * Extract teacher ID from user info with better fallback logic
     */
    private String extractTeacherId(Map<String, Object> userInfo) {
        if (userInfo == null) {
            logger.warn("❌ User info is null, using fallback teacher ID");
            return "unknown_teacher_" + System.currentTimeMillis();
        }
        
        // Try email first (most reliable)
        String email = (String) userInfo.get("email");
        if (email != null && !email.trim().isEmpty()) {
            logger.debug("✅ Using email as teacher ID: {}", email);
            return email;
        }
        
        // Try username
        String username = (String) userInfo.get("username");
        if (username != null && !username.trim().isEmpty()) {
            logger.debug("✅ Using username as teacher ID: {}", username);
            return username;
        }
        
        // Try fullname
        String fullname = (String) userInfo.get("fullname");
        if (fullname != null && !fullname.trim().isEmpty()) {
            logger.debug("✅ Using fullname as teacher ID: {}", fullname);
            return fullname;
        }
        
        // Try userId
        Object userId = userInfo.get("userId");
        if (userId != null) {
            String userIdStr = userId.toString();
            if (!userIdStr.trim().isEmpty()) {
                logger.debug("✅ Using userId as teacher ID: {}", userIdStr);
                return userIdStr;
            }
        }
        
        // Last resort - generate unique ID
        String fallbackId = "teacher_" + System.currentTimeMillis();
        logger.warn("❌ Could not extract teacher ID from user info, using fallback: {}", fallbackId);
        return fallbackId;
    }

    /**
     * Build contextual prompt for chat continuation
     */
    private String buildContextualPrompt(String newPrompt, List<Map<String, Object>> previousMessages, String materialType) {
        StringBuilder contextPrompt = new StringBuilder();
        
        contextPrompt.append("You are CAILA, an AI assistant helping teachers create educational materials. ");
        contextPrompt.append("This is a continuation of a previous conversation about creating a ").append(materialType).append(".\n\n");
        
        // Add recent context (last 3 exchanges)
        if (previousMessages != null && !previousMessages.isEmpty()) {
            contextPrompt.append("PREVIOUS CONVERSATION CONTEXT:\n");
            int startIndex = Math.max(0, previousMessages.size() - 6); // Last 3 teacher-ai exchanges
            
            for (int i = startIndex; i < previousMessages.size(); i++) {
                Map<String, Object> message = previousMessages.get(i);
                String role = (String) message.get("role");
                String content = (String) message.get("content");
                
                if (content != null) {
                    if ("teacher".equals(role)) {
                        contextPrompt.append("TEACHER: ").append(content).append("\n");
                    } else if ("caila".equals(role)) {
                        // Truncate long AI responses for context
                        String truncatedContent = content.length() > 200 ? 
                            content.substring(0, 200) + "..." : content;
                        contextPrompt.append("CAILA: ").append(truncatedContent).append("\n");
                    }
                }
            }
        }
        
        contextPrompt.append("\nCURRENT REQUEST:\n");
        contextPrompt.append("TEACHER: ").append(newPrompt).append("\n\n");
        contextPrompt.append("Please respond as CAILA, taking into account the previous conversation context and maintaining continuity with the ongoing discussion about the ").append(materialType).append(":");
        
        return contextPrompt.toString();
    }

