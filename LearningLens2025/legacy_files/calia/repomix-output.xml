                System.out.println("⚠️ Strategy 2 exception: " + e.getMessage());
            }
        }

        // Strategy 3: Try to get user attempts to infer quiz info
        if (!foundContent) {
            try {
                System.out.println("🔧 Strategy 3 - Trying user attempts");
                
                String attemptsUrl = moodleBaseUrl + "/webservice/rest/server.php"
                        + "?wstoken=" + token
                        + "&wsfunction=mod_quiz_get_user_attempts"
