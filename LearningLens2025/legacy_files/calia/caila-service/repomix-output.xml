    private final Map<String, GeneratedMaterial> materials = new ConcurrentHashMap<>();
    private final Map<String, List<String>> teacherMaterials = new ConcurrentHashMap<>();
    
    public GeneratedMaterial createMaterial(String jwt, String prompt, String materialType, String courseId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        if (!session.isTeacher()) {
            throw new SecurityException("Only teachers can create materials");
        }
        
        GeneratedMaterial material = cailaService.generateMaterial(jwt, prompt, materialType, courseId);
        
        // Store material
        materials.put(material.getId(), material);
        teacherMaterials.computeIfAbsent(session.getUserId(), k -> new ArrayList<>()).add(material.getId());
        
        return material;
    }
    
    public List<GeneratedMaterial> getTeacherMaterials(String jwt) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        List<String> materialIds = teacherMaterials.getOrDefault(session.getUserId(), List.of());
        return materialIds.stream()
            .map(materials::get)
            .filter(Objects::nonNull)
            .sorted(Comparator.comparing(GeneratedMaterial::getCreatedAt).reversed())
            .collect(java.util.stream.Collectors.toList());
    }
    
    public GeneratedMaterial getMaterial(String jwt, String materialId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        GeneratedMaterial material = materials.get(materialId);
        if (material == null) {
            throw new NoSuchElementException("Material not found: " + materialId);
        }
        
        // Check ownership for teachers, or if it's from the same course for students
        if (session.isTeacher() && !session.getUserId().equals(material.getTeacherId())) {
            throw new SecurityException("Access denied to material");
        }
        
        return material;
    }
}
