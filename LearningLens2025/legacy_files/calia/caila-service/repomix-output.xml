<file path="services/ai/CailaService.java">
package com.caila.lms.services.ai;

import com.caila.lms.clients.deepseek.DeepSeekClient;
import com.caila.lms.models.domain.ChatMessage;
import com.caila.lms.models.domain.GeneratedMaterial;
import com.caila.lms.models.domain.SessionContext;
import com.caila.lms.services.session.SessionContextService;
import com.caila.lms.services.lms.ChatLogService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import lombok.extern.slf4j.Slf4j;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Map;
import java.util.UUID;

@Service
@Slf4j
public class CailaService {
    
    @Autowired
    private DeepSeekClient deepSeekClient;
    
    @Autowired
    private SessionContextService sessionService;
    
    @Autowired
    private ChatLogService chatLogService;
    
    public String generateSimpleResponse(String prompt) {
        return deepSeekClient.generateContent(prompt);
    }
    
    public ChatMessage chatWithContext(String jwt, String prompt, String courseId, String assignmentId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        // Get conversation history if available
        List<Map<String, String>> history = chatLogService.getChatHistory(jwt, courseId, assignmentId);
        
        // Generate response with context
        String response = deepSeekClient.generateConversationalResponse(prompt, history);
        
        // Create chat message
        ChatMessage message = ChatMessage.builder()
            .id(UUID.randomUUID().toString())
            .userMessage(prompt)
            .aiResponse(response)
            .userId(session.getUserId())
            .courseId(courseId)
            .assignmentId(assignmentId)
            .timestamp(LocalDateTime.now())
            .platform(session.getPlatform().name())
            .build();
        
        // Store chat log
        chatLogService.storeChatMessage(jwt, message);
        
        return message;
    }
    
    public GeneratedMaterial generateMaterial(String jwt, String prompt, String materialType, String courseId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        if (!session.isTeacher()) {
            throw new SecurityException("Only teachers can generate materials");
        }
        
        // Build enhanced prompt based on material type
        String enhancedPrompt = buildMaterialPrompt(prompt, materialType);
        
        // Generate content
        String content = deepSeekClient.generateContent(enhancedPrompt);
        
        return GeneratedMaterial.builder()
            .id(UUID.randomUUID().toString())
            .teacherId(session.getUserId())
            .courseId(courseId)
            .materialType(materialType)
            .content(content)
            .prompt(prompt)
            .createdAt(LocalDateTime.now())
            .platform(session.getPlatform().name())
            .build();
    }
    
    private String buildMaterialPrompt(String basePrompt, String materialType) {
        String typeSpecificInstructions = switch (materialType.toLowerCase()) {
            case "quiz" -> "Create a quiz with multiple choice questions, including answer explanations.";
            case "assignment" -> "Create a detailed assignment with clear instructions and grading criteria.";
            case "lesson" -> "Create a comprehensive lesson plan with objectives and activities.";
            case "rubric" -> "Create a detailed grading rubric with clear criteria and performance levels.";
            default -> "Create educational content that is clear and well-structured.";
        };
        
        return String.format("%s\n\n%s\n\nBase request: %s", 
            typeSpecificInstructions,
            "Make the content professional and appropriate for an educational setting.",
            basePrompt
        );
    }
}
</file>

