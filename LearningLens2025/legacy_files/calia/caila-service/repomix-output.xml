package com.caila.lms.services.lms;

import com.caila.lms.models.domain.ChatMessage;
import com.caila.lms.models.domain.SessionContext;
import com.caila.lms.services.session.SessionContextService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import lombok.extern.slf4j.Slf4j;

import java.util.List;
import java.util.Map;
import java.util.concurrent.ConcurrentHashMap;

@Service
@Slf4j
public class ChatLogService {
    
    @Autowired
    private SessionContextService sessionService;
    
    // In-memory storage for demo purposes
    // In production, use a proper database
    private final Map<String, List<ChatMessage>> chatStorage = new ConcurrentHashMap<>();
    
    public void storeChatMessage(String jwt, ChatMessage message) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        try {
            // Store locally
            String key = generateChatKey(session.getUserId(), message.getCourseId(), message.getAssignmentId());
            chatStorage.computeIfAbsent(key, k -> new java.util.ArrayList<>()).add(message);
            
            // Store in platform-specific way
            switch (session.getPlatform()) {
                case GOOGLE -> storeInGoogleDrive(session, message);
                case MOODLE -> storeInMoodleNotes(session, message);
            }
            
        } catch (Exception e) {
            log.error("Failed to store chat message: {}", e.getMessage());
            // Don't fail the chat if logging fails
        }
    }
    
    public List<Map<String, String>> getChatHistory(String jwt, String courseId, String assignmentId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        String key = generateChatKey(session.getUserId(), courseId, assignmentId);
        
        return chatStorage.getOrDefault(key, List.of()).stream()
            .map(msg -> Map.of(
                "role", "user",
                "content", msg.getUserMessage()
            ))
            .collect(java.util.stream.Collectors.toList());
    }
    
    private String generateChatKey(String userId, String courseId, String assignmentId) {
        return String.format("%s_%s_%s", userId, courseId, assignmentId != null ? assignmentId : "general");
    }
    
    private void storeInGoogleDrive(SessionContext session, ChatMessage message) {
        // Implementation would use GoogleDriveClient to store chat logs
        log.info("Storing chat in Google Drive for user: {}", session.getUserId());
    }
    
    private void storeInMoodleNotes(SessionContext session, ChatMessage message) {
        // Implementation would use MoodleClient to store chat as notes
        log.info("Storing chat in Moodle notes for user: {}", session.getUserId());
    }
}
