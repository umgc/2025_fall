package com.caila.lms.services.session;

import com.caila.lms.models.domain.SessionContext;
import com.caila.lms.adapters.SessionContextAdapter;
import com.focused_ai.utils.JwtUtil;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import lombok.extern.slf4j.Slf4j;

@Service
@Slf4j
public class SessionContextService {
    
    @Autowired
    private SessionContextAdapter sessionAdapter;
    
    @Autowired
    private JwtUtil jwtUtil;
    
    /**
     * Extract session context from JWT token
     * NOTE: JWT validation is handled by parent project - we just extract data
     */
    public SessionContext extractSessionContext(String authorizationHeader) {
        try {
            String jwt = cleanJwtToken(authorizationHeader);
            return sessionAdapter.fromJwt(jwt);
        } catch (Exception e) {
            log.error("Failed to extract session context from JWT: {}", e.getMessage());
            throw new RuntimeException("Invalid session token: " + e.getMessage());
        }
    }
    
    /**
     * Get platform-specific token for API calls
     */
    public String getPlatformToken(String authorizationHeader) {
        SessionContext context = extractSessionContext(authorizationHeader);
        return context.getAccessToken();
    }
    
    /**
     * Clean JWT token from Authorization header
     */
    private String cleanJwtToken(String authorizationHeader) {
        if (authorizationHeader == null) {
            throw new IllegalArgumentException("Authorization header is required");
        }
        
        return authorizationHeader.startsWith("Bearer ") 
            ? authorizationHeader.substring(7) 
            : authorizationHeader;
    }
    
    /**
     * Check if user is using Google Classroom
     */
    public boolean isGoogleUser(String authorizationHeader) {
        try {
            String jwt = cleanJwtToken(authorizationHeader);
            return jwtUtil.isGoogleUser(jwt);
        } catch (Exception e) {
            return false;
        }
    }
    
    /**
     * Check if user is using Moodle
     */
    public boolean isMoodleUser(String authorizationHeader) {
        try {
            String jwt = cleanJwtToken(authorizationHeader);
            return jwtUtil.isMoodleUser(jwt);
        } catch (Exception e) {
            return false;
        }
    }
}
