package com.caila.lms.adapters;

import com.caila.lms.models.domain.SessionContext;
import com.caila.lms.models.domain.Platform;
import com.focused_ai.utils.JwtUtil;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

@Component
public class SessionContextAdapter {
    
    @Autowired
    private JwtUtil jwtUtil;
    
    /**
     * Convert from parent project's JWT to internal SessionContext
     * Assumes JWT is already validated by parent project
     */
    public SessionContext fromJwt(String jwt) {
        try {
            // Extract data using parent project's JWT util - corrected method names
            String lms = jwtUtil.extractLMS(jwt);
            String userId = jwtUtil.extractUserId(jwt);
            String userIdentifier = jwtUtil.extractUserIdentifier(jwt);
            String userRole = jwtUtil.extractUserRole(jwt);
            
            // Map platform from parent project naming
            Platform platform = mapPlatformFromLms(lms);
            
            // Extract platform-specific tokens based on LMS type
            String accessToken = extractAccessToken(jwt, platform);
            String refreshToken = extractRefreshToken(jwt, platform);
            
            return SessionContext.builder()
                .userId(userId)
                .platform(platform)
                .accessToken(accessToken)
                .refreshToken(refreshToken)
                .userRole(userRole)
                .userEmail(lms.equals("googleClassroom") ? userIdentifier : null)
                .userName(lms.equals("moodle") ? userIdentifier : userIdentifier)
                .build();
                
        } catch (Exception e) {
            throw new RuntimeException("Failed to extract session context from JWT: " + e.getMessage(), e);
        }
    }
    
    private Platform mapPlatformFromLms(String lms) {
        return switch (lms) {
            case "googleClassroom" -> Platform.GOOGLE;
            case "moodle" -> Platform.MOODLE;
            default -> throw new IllegalArgumentException("Unknown LMS platform: " + lms);
        };
    }
    
    private String extractAccessToken(String jwt, Platform platform) {
        return switch (platform) {
            case GOOGLE -> jwtUtil.extractGoogleAccessToken(jwt);
            case MOODLE -> jwtUtil.extractwebServiceToken(jwt); // Note: method name from provided JwtUtil
            default -> throw new IllegalArgumentException("Unknown platform: " + platform);
        };
    }
    
    private String extractRefreshToken(String jwt, Platform platform) {
        if (platform == Platform.GOOGLE) {
            return jwtUtil.extractGoogleRefreshToken(jwt);
        }
        return null; // Moodle doesn't have refresh tokens in the provided JwtUtil
    }
}
