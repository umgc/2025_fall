package com.caila.lms.clients.google;

import com.caila.lms.models.domain.Course;
import com.caila.lms.models.domain.Assignment;
import com.caila.lms.exceptions.LmsException;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.core.ParameterizedTypeReference;
import org.springframework.http.*;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestTemplate;
import lombok.extern.slf4j.Slf4j;

import java.net.http.HttpHeaders;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

@Component
@Slf4j
public class GoogleClassroomClient {
    
    private static final String CLASSROOM_API_BASE = "https://classroom.googleapis.com/v1";
    
    @Autowired
    private RestTemplate restTemplate;
    
    private HttpHeaders createAuthHeaders(String accessToken) {
        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.setBearerAuth(accessToken);
        return headers;
    }
    
    public List<Course> getCourses(String accessToken) {
    try {
        HttpEntity<String> entity = new HttpEntity<>(createAuthHeaders(accessToken));
        
        ResponseEntity<Map<String, Object>> response = restTemplate.exchange(
            CLASSROOM_API_BASE + "/courses?courseStates=ACTIVE",
            HttpMethod.GET,
            entity,
            new ParameterizedTypeReference<Map<String, Object>>() {}
        );
        
        Map<String, Object> responseBody = response.getBody();
        if (responseBody != null && responseBody.containsKey("courses")) {
            @SuppressWarnings("unchecked")
            List<Map<String, Object>> googleCourses = (List<Map<String, Object>>) responseBody.get("courses");
            
            return googleCourses.stream()
                .<Course>map(this::mapGoogleCourseToDomain)  // Explicit type declaration
                .collect(Collectors.toList());
        }
        
        return List.of();
        
    } catch (Exception e) {
        log.error("Failed to get Google Classroom courses: {}", e.getMessage());
        throw new LmsException("Failed to retrieve courses from Google Classroom", e);
    }
}
    
    public List<Assignment> getAssignments(String accessToken, String courseId) {
    try {
        HttpEntity<String> entity = new HttpEntity<>(createAuthHeaders(accessToken));
        
        ResponseEntity<Map<String, Object>> response = restTemplate.exchange(
            CLASSROOM_API_BASE + "/courses/{courseId}/courseWork",
            HttpMethod.GET,
            entity,
            new ParameterizedTypeReference<Map<String, Object>>() {},
            courseId
        );
        
        Map<String, Object> responseBody = response.getBody();
        if (responseBody != null && responseBody.containsKey("courseWork")) {
            @SuppressWarnings("unchecked")
            List<Map<String, Object>> courseWork = (List<Map<String, Object>>) responseBody.get("courseWork");
            
            return courseWork.stream()
                .<Assignment>map(work -> mapGoogleCourseWorkToDomain(work, courseId))  // Explicit type declaration
                .collect(Collectors.toList());
        }
        
        return List.of();
        
    } catch (Exception e) {
        log.error("Failed to get Google Classroom assignments for course {}: {}", courseId, e.getMessage());
        throw new LmsException("Failed to retrieve assignments from Google Classroom", e);
    }
}
    
    public void createAssignment(String accessToken, String courseId, Assignment assignment) {
        try {
            HttpHeaders headers = createAuthHeaders(accessToken);
            
            Map<String, Object> courseWork = Map.of(
                "title", assignment.getName(),
                "description", assignment.getDescription(),
                "workType", "ASSIGNMENT",
                "state", "PUBLISHED",
                "maxPoints", assignment.getMaxScore() != null ? assignment.getMaxScore() : 100
            );
            
            HttpEntity<Map<String, Object>> entity = new HttpEntity<>(courseWork, headers);
            
            ResponseEntity<Map> response = restTemplate.exchange(
                CLASSROOM_API_BASE + "/courses/{courseId}/courseWork",
                HttpMethod.POST,
                entity,
                Map.class,
                courseId
            );
            
            if (!response.getStatusCode().is2xxSuccessful()) {
                throw new LmsException("Failed to create assignment in Google Classroom");
            }
            
        } catch (Exception e) {
            log.error("Failed to create Google Classroom assignment: {}", e.getMessage());
            throw new LmsException("Failed to create assignment in Google Classroom", e);
        }
    }
    
    private Course mapGoogleCourseToDomain(Map<String, Object> googleCourse) {
        return Course.builder()
            .id((String) googleCourse.get("id"))
            .name((String) googleCourse.get("name"))
            .description((String) googleCourse.get("description"))
            .platform("GOOGLE")
            .instructor((String) googleCourse.get("ownerId"))
            .build();
    }
    
    private Assignment mapGoogleCourseWorkToDomain(Map<String, Object> work, String courseId) {
        Assignment assignment = Assignment.builder()
            .id((String) work.get("id"))
            .courseId(courseId)
            .name((String) work.get("title"))
            .description((String) work.get("description"))
            .platform("GOOGLE")
            .status("PUBLISHED")
            .build();
            
        if (work.containsKey("maxPoints")) {
            assignment.setMaxScore(((Number) work.get("maxPoints")).doubleValue());
        }
        
        return assignment;
    }
}
