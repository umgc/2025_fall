package com.caila.lms.clients.moodle;

import com.caila.lms.models.domain.Course;
import com.caila.lms.models.domain.Assignment;
import com.caila.lms.exceptions.LmsException;
import com.focused_ai.utils.JwtUtil;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.core.ParameterizedTypeReference;
import org.springframework.http.*;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestTemplate;
import lombok.extern.slf4j.Slf4j;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

@Component
@Slf4j
public class MoodleClient {
    
    @Value("${moodle.base.url:http://18.188.18.80/moodle}")
    private String defaultMoodleBaseUrl;
    
    @Autowired
    private RestTemplate restTemplate;
    
    @Autowired
    private ObjectMapper objectMapper;
    
    @Autowired
    private JwtUtil jwtUtil;
    
    private String getMoodleBaseUrl(String jwt) {
        try {
            // Try to extract Moodle domain from JWT first
            String moodleDomain = jwtUtil.extractMoodleDomain(jwt);
            if (moodleDomain != null && !moodleDomain.trim().isEmpty()) {
                return moodleDomain;
            }
        } catch (Exception e) {
            log.warn("Could not extract Moodle domain from JWT, using default: {}", e.getMessage());
        }
        
        // Fallback to configured default
        return defaultMoodleBaseUrl;
    }
    
    private String buildMoodleUrl(String function, String token, Map<String, String> params, String jwt) {
        String baseUrl = getMoodleBaseUrl(jwt);
        StringBuilder url = new StringBuilder(baseUrl)
            .append("/webservice/rest/server.php")
            .append("?wstoken=").append(token)
            .append("&wsfunction=").append(function)
            .append("&moodlewsrestformat=json");
            
        if (params != null) {
            params.forEach((key, value) -> url.append("&").append(key).append("=").append(value));
        }
        
        return url.toString();
    }
    
    public List<Course> getCourses(String webServiceToken, String jwt) {
    try {
        String url = buildMoodleUrl("core_course_get_courses", webServiceToken, null, jwt);
        
        ResponseEntity<List<Map<String, Object>>> response = restTemplate.exchange(
            url,
            HttpMethod.GET,
            null,
            new ParameterizedTypeReference<List<Map<String, Object>>>() {}
        );
        
        List<Map<String, Object>> moodleCourses = response.getBody();
        if (moodleCourses != null) {
            return moodleCourses.stream()
                .<Course>map(this::mapMoodleCourseToDomain)  // Explicit type declaration
                .collect(Collectors.toList());
        }
        
        return List.of();
        
    } catch (Exception e) {
        log.error("Failed to get Moodle courses: {}", e.getMessage());
        throw new LmsException("Failed to retrieve courses from Moodle", e);
    }
}
    
    public List<Assignment> getAssignments(String webServiceToken, String courseId, String jwt) {
        try {
            Map<String, String> params = Map.of("courseids[0]", courseId);
            String url = buildMoodleUrl("mod_assign_get_assignments", webServiceToken, params, jwt);
            
            ResponseEntity<Map<String, Object>> response = restTemplate.exchange(
                url,
                HttpMethod.GET,
                null,
                new ParameterizedTypeReference<Map<String, Object>>() {}
            );
            
            Map<String, Object> responseBody = response.getBody();
            if (responseBody != null && responseBody.containsKey("courses")) {
                @SuppressWarnings("unchecked")
                List<Map<String, Object>> courses = (List<Map<String, Object>>) responseBody.get("courses");
                
                return courses.stream()
                    .filter(course -> courseId.equals(String.valueOf(course.get("id"))))
                    .flatMap(course -> {
                        @SuppressWarnings("unchecked")
                        List<Map<String, Object>> assignments = (List<Map<String, Object>>) course.get("assignments");
                        return assignments != null ? assignments.stream() : List.<Map<String, Object>>of().stream();
                    })
                    .map(assignment -> mapMoodleAssignmentToDomain(assignment, courseId))
                    .collect(Collectors.toList());
            }
            
            return List.of();
            
        } catch (Exception e) {
            log.error("Failed to get Moodle assignments for course {}: {}", courseId, e.getMessage());
            throw new LmsException("Failed to retrieve assignments from Moodle", e);
        }
    }
    
    private Course mapMoodleCourseToDomain(Map<String, Object> moodleCourse) {
        return Course.builder()
            .id(String.valueOf(moodleCourse.get("id")))
            .name((String) moodleCourse.get("fullname"))
            .description((String) moodleCourse.get("summary"))
            .platform("MOODLE")
            .build();
    }
    
    private Assignment mapMoodleAssignmentToDomain(Map<String, Object> moodleAssignment, String courseId) {
        Assignment assignment = Assignment.builder()
            .id(String.valueOf(moodleAssignment.get("id")))
            .courseId(courseId)
            .name((String) moodleAssignment.get("name"))
            .description((String) moodleAssignment.get("intro"))
            .platform("MOODLE")
            .status("ACTIVE")
            .build();
            
        if (moodleAssignment.containsKey("grade")) {
            assignment.setMaxScore(((Number) moodleAssignment.get("grade")).doubleValue());
        }
        
        return assignment;
    }
}
