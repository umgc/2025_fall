package com.caila.lms.controllers;

import com.caila.lms.models.domain.Assignment;
import com.caila.lms.models.dto.ApiResponse;
import com.caila.lms.models.dto.CreateAssignmentRequest;
import com.caila.lms.services.lms.AssignmentService;
import com.caila.lms.services.session.SessionContextService;
import com.caila.lms.exceptions.AuthenticationException;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import lombok.extern.slf4j.Slf4j;

import java.util.List;

@RestController
@RequestMapping("/api/courses/{courseId}/assignments")
@CrossOrigin(origins = "*")
@Slf4j
public class AssignmentController {
    
    @Autowired
    private AssignmentService assignmentService;
    
    @Autowired
    private SessionContextService sessionContextService;
    
    @GetMapping
    public ResponseEntity<ApiResponse<List<Assignment>>> getAssignments(
            @RequestHeader("Authorization") String jwt,
            @PathVariable String courseId) {
        
        try {
            // Validate session using parent project's JWT system
            if (!sessionContextService.isValidSession(jwt)) {
                return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                    .body(ApiResponse.error("Invalid or expired session"));
            }
            
            List<Assignment> assignments = assignmentService.getAssignments(jwt, courseId);
            return ResponseEntity.ok(ApiResponse.success("Assignments retrieved successfully", assignments));
            
        } catch (AuthenticationException e) {
            return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                .body(ApiResponse.error("Authentication failed"));
        } catch (Exception e) {
            log.error("Get assignments failed", e);
            return ResponseEntity.badRequest()
                .body(ApiResponse.error("Failed to retrieve assignments: " + e.getMessage()));
        }
    }
    
    @GetMapping("/{assignmentId}")
    public ResponseEntity<ApiResponse<Assignment>> getAssignment(
            @RequestHeader("Authorization") String jwt,
            @PathVariable String courseId,
            @PathVariable String assignmentId) {
        
        try {
            if (!sessionContextService.isValidSession(jwt)) {
                return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                    .body(ApiResponse.error("Invalid or expired session"));
            }
            
            Assignment assignment = assignmentService.getAssignment(jwt, courseId, assignmentId);
            return ResponseEntity.ok(ApiResponse.success("Assignment retrieved successfully", assignment));
            
        } catch (AuthenticationException e) {
            return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                .body(ApiResponse.error("Authentication failed"));
        } catch (Exception e) {
            log.error("Get assignment failed", e);
            return ResponseEntity.badRequest()
                .body(ApiResponse.error("Failed to retrieve assignment: " + e.getMessage()));
        }
    }
    
    @PostMapping
    public ResponseEntity<ApiResponse<String>> createAssignment(
            @RequestHeader("Authorization") String jwt,
            @PathVariable String courseId,
            @RequestBody CreateAssignmentRequest request) {
        
        try {
            if (!sessionContextService.isValidSession(jwt)) {
                return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                    .body(ApiResponse.error("Invalid or expired session"));
            }
            
            Assignment assignment = Assignment.builder()
                .name(request.getName())
                .description(request.getDescription())
                .maxScore(request.getMaxScore())
                .courseId(courseId)
                .build();
            
            assignmentService.createAssignment(jwt, courseId, assignment);
            return ResponseEntity.ok(ApiResponse.success("Assignment created successfully", "Assignment created"));
            
        } catch (AuthenticationException e) {
            return ResponseEntity.status(HttpStatus.UNAUTHORIZED)
                .body(ApiResponse.error("Authentication failed"));
        } catch (Exception e) {
            log.error("Create assignment failed", e);
            return ResponseEntity.badRequest()
                .body(ApiResponse.error("Failed to create assignment: " + e.getMessage()));
        }
    }
}
