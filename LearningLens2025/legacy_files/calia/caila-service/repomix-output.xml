package com.caila.lms.services.lms;

import com.caila.lms.clients.google.GoogleClassroomClient;
import com.caila.lms.clients.moodle.MoodleClient;
import com.caila.lms.models.domain.Assignment;
import com.caila.lms.models.domain.Platform;
import com.caila.lms.models.domain.SessionContext;
import com.caila.lms.services.session.SessionContextService;
import com.caila.lms.exceptions.LmsException;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import lombok.extern.slf4j.Slf4j;

import java.util.List;

@Service
@Slf4j
public class AssignmentService {
    
    @Autowired
    private GoogleClassroomClient googleClient;
    
    @Autowired
    private MoodleClient moodleClient;
    
    @Autowired
    private SessionContextService sessionService;
    
    public List<Assignment> getAssignments(String jwt, String courseId) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        return switch (session.getPlatform()) {
            case GOOGLE -> googleClient.getAssignments(session.getAccessToken(), courseId);
            case MOODLE -> moodleClient.getAssignments(session.getAccessToken(), courseId);
            default -> throw new LmsException("Unsupported platform: " + session.getPlatform());
        };
    }
    
    public Assignment getAssignment(String jwt, String courseId, String assignmentId) {
        List<Assignment> assignments = getAssignments(jwt, courseId);
        return assignments.stream()
            .filter(assignment -> assignmentId.equals(assignment.getId()))
            .findFirst()
            .orElseThrow(() -> new LmsException("Assignment not found: " + assignmentId));
    }
    
    public void createAssignment(String jwt, String courseId, Assignment assignment) {
        SessionContext session = sessionService.extractSessionContext(jwt);
        
        if (!session.isTeacher()) {
            throw new LmsException("Only teachers can create assignments");
        }
        
        switch (session.getPlatform()) {
            case GOOGLE -> googleClient.createAssignment(session.getAccessToken(), courseId, assignment);
            case MOODLE -> throw new LmsException("Assignment creation not yet supported for Moodle");
            default -> throw new LmsException("Unsupported platform: " + session.getPlatform());
        }
    }
}
