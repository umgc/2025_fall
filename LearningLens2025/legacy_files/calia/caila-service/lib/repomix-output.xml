          ),
        ),
      ],
    );
  }

  Widget _buildHistoryView() {
    return Column(
      children: [
        const Header(
          title: AppStrings.chatHistory,
          subtitle: 'Your previous conversations with CAILA',
        ),
        Expanded(
          child: Center(
