{
  "name": "flutter_docker",
  "context": "..",
  "dockerFile": "../docker/Dockerfile",
  "remoteUser": "root",
  "settings": {
    "terminal.integrated.shell.linux": null
  },
  "runArgs": ["--privileged"],
  "extensions": ["dart-code.flutter"],
  "workspaceMount": "source=${localWorkspaceFolder}/teamA,target=/home/root/teamA,type=bind,consistency=delegated",
  "workspaceFolder": "/home/root/teamA"
}
